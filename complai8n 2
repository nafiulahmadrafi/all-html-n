  z.innerHTML = '<option value="">— জেলা নির্বাচন করুন —</option>';
  u.innerHTML = '<option value="">— প্রথমে জেলা —</option>';
  u.disabled = true;
  if (!div) { z.disabled = true; return; }
  z.disabled = false;
  Object.keys(BD[div]).forEach(function (k) {
    var o = document.createElement('option');
    o.value = k; o.textContent = k;
    z.appendChild(o);
  });
}

function loadUpazila() {
  var div = document.getElementById('division').value;
  var zila = document.getElementById('zila').value;
  var u = document.getElementById('upazila');
  u.innerHTML = '<option value="">— উপজেলা নির্বাচন করুন —</option>';
  if (!zila) { u.disabled = true; return; }
  u.disabled = false;
  BD[div][zila].forEach(function (k) {
    var o = document.createElement('option');
    o.value = k; o.textContent = k;
    u.appendChild(o);
  });
}

// ── Error Cleanup Listeners ───────────────────────
['division','zila','upazila','name','complaintType','message'].forEach(function (id) {
  var el = document.getElementById(id);
  if (!el) return;
  ['change','input'].forEach(function (ev) {
    el.addEventListener(ev, function () { el.classList.remove('error'); });
  });
});

// ── File Upload ───────────────────────────────────
var selectedFiles = [];

function handleFiles(files) {
  Array.from(files).forEach(function (f) {
    if (selectedFiles.length >= 5) return;
    if (f.size > 25 * 1024 * 1024) {
      alert(f.name + ' ফাইলটি ২৫MB এর বেশি!');
      return;
    }
    selectedFiles.push(f);
  });
  renderPreviews();
  // Reset input so same file can be re-added after removal
  document.getElementById('fileInput').value = '';
}

function renderPreviews() {
  var g = document.getElementById('previewGrid');
  g.innerHTML = '';
  selectedFiles.forEach(function (f, i) {
    var item = document.createElement('div');
    item.className = 'preview-item';
    var url = URL.createObjectURL(f);
    if (f.type.startsWith('image/')) {
      item.innerHTML = '<img src="' + url + '" alt="' + f.name + '"><div class="file-name">' + f.name + '</div>';
    } else {
      item.innerHTML = '<video src="' + url + '" muted></video><div class="file-name">' + f.name + '</div>';
    }
    var rm = document.createElement('button');
    rm.className = 'remove-btn';
    rm.innerHTML = '&times;';
    rm.type = 'button';
    rm.setAttribute('aria-label', f.name + ' সরান');
    rm.addEventListener('click', (function (idx) {
      return function () { selectedFiles.splice(idx, 1); renderPreviews(); };
    })(i));
    item.appendChild(rm);
    g.appendChild(item);
  });
}

// Drag & drop
var zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
zone.addEventListener('drop', function (e) {
  e.preventDefault(); zone.classList.remove('dragover');
  handleFiles(e.dataTransfer.files);
});

// ── Character Counter ─────────────────────────────
function updateCharCount() {
  document.getElementById('charCount').textContent = document.getElementById('message').value.length;
}

// ── Form Submit ───────────────────────────────────
document.getElementById('complaintForm').addEventListener('submit', function (e) {
  e.preventDefault();

  var division = document.getElementById('division').value;
  var zila = document.getElementById('zila').value;
  var upazila = document.getElementById('upazila').value;
  var name = document.getElementById('name').value.trim();
  var contact = document.getElementById('contact').value.trim();
  var complaintType = document.getElementById('complaintType').value;
  var message = document.getElementById('message').value.trim();

  var valid = true;
  [['division', division], ['zila', zila], ['upazila', upazila],
   ['name', name], ['complaintType', complaintType], ['message', message]]
    .forEach(function (p) {
      var el = document.getElementById(p[0]);
      if (!p[1]) { el.classList.add('error'); valid = false; }
      else { el.classList.remove('error'); }
    });

  if (!valid) {
    // Scroll to first error on mobile
    var firstError = document.querySelector('.error');
    if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  var btn = document.getElementById('submitBtn');
  btn.classList.add('loading');
  btn.disabled = true;

  var refNo = 'REF-' + Date.now().toString(36).toUpperCase();
  var body = 'জাতীয় নাগরিক অভিযোগ\n' +
    '========================================\n\n' +
    'রেফারেন্স: ' + refNo + '\n' +
    'তারিখ: ' + new Date().toLocaleString('bn-BD') + '\n\n' +
    'বিভাগ: ' + division + '\nজেলা: ' + zila + '\nউপজেলা: ' + upazila + '\n\n' +
    'নাম: ' + name + '\n' +
    'যোগাযোগ: ' + (contact || 'প্রদান করা হয়নি') + '\n\n' +
    'ধরন: ' + complaintType + '\n\n' +
    'বিবরণ:\n' + message + '\n\n' +
    'ফাইল: ' + (selectedFiles.length > 0 ? selectedFiles.map(function (f) { return f.name; }).join(', ') : 'নেই');

  setTimeout(function () {
    window.location.href =
      'mailto:nagorikcomplain@gmail.com' +
      '?subject=' + encodeURIComponent('[অভিযোগ] ' + complaintType + ' - ' + division + ', ' + zila + ' | ' + refNo) +
      '&body=' + encodeURIComponent(body);

    btn.classList.remove('loading');
    btn.disabled = false;

    document.getElementById('refNumber').textContent = 'রেফারেন্স নম্বর: ' + refNo;
    document.getElementById('successModal').classList.add('show');

    // Reset form
    document.getElementById('complaintForm').reset();
    selectedFiles = [];
    renderPreviews();
    document.getElementById('charCount').textContent = '0';
    document.getElementById('zila').disabled = true;
    document.getElementById('upazila').disabled = true;
  }, 800);
});

function closeModal() {
  document.getElementById('successModal').classList.remove('show');
}

// Close modal on backdrop click
document.getElementById('successModal').addEventListener('click', function (e) {
  if (e.target === this) closeModal();
});

// Close modal on Escape key
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') closeModal();
});
</script>
</body>
