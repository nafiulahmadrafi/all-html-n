<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
<meta name="theme-color" content="#0d47a1">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>জাতীয় নাগরিক অভিযোগ বাক্স — নাগরিক ফোরাম বাংলাদেশ</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Tiro+Bangla:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #0d47a1;
  --primary-light: #1976d2;
  --primary-soft: rgba(13,71,161,0.08);
  --gold: #d4af37;
  --gold-soft: rgba(212,175,55,0.12);
  --text-dark: #0a1b33;
  --text-mid: #37475f;
  --text-soft: #6b7fa3;
  --text-muted: #a1b0c7;
  --border: #c2d1e6;
  --border-soft: rgba(13,71,161,0.1);
  --bg-field: rgba(255,255,255,0.88);
  --bg-card: rgba(255,255,255,0.76);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 18px;
  --radius-xl: 24px;
  --shadow-card: 0 4px 30px rgba(13,71,161,0.07), 0 1px 6px rgba(0,0,0,0.04);
  --shadow-btn: 0 5px 22px rgba(13,71,161,0.22);
  --transition: 0.2s cubic-bezier(0.4,0,0.2,1);
  --font-bn: 'Hind Siliguri', sans-serif;
  --font-title: 'Tiro Bangla', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

body {
  font-family: var(--font-bn);
  background: linear-gradient(160deg, #e3f2fd 0%, #ffffff 40%, #fffde7 70%, #fff9c4 100%);
  min-height: 100vh;
  min-height: 100dvh;
  padding: 28px 16px 48px;
  position: relative;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 10% 15%, rgba(13,71,161,0.05) 0%, transparent 65%),
    radial-gradient(ellipse 60% 55% at 90% 85%, rgba(212,175,55,0.06) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

/* ─── Layout ─────────────────────────────────────── */
.page-wrap {
  width: 100%;
  max-width: 760px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

/* ─── Hero Header ────────────────────────────────── */
.hero-header {
  text-align: center;
  margin-bottom: 22px;
  animation: fadeDown 0.55s ease both;
}

@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.flag-strip {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 14px;
  gap: 0;
}
.flag-bar { background: var(--primary); height: 5px; width: 52px; border-radius: 3px; }
.flag-circle {
  background: var(--gold);
  width: 24px; height: 24px;
  border-radius: 50%;
  margin: 0 9px;
  box-shadow: 0 2px 10px rgba(212,175,55,0.38);
}

.hero-icon { font-size: 46px; line-height: 1; margin-bottom: 10px; }

.hero-title {
  font-family: var(--font-title);
  font-size: clamp(20px, 5vw, 28px);
  font-weight: 700;
  color: #0a2142;
  line-height: 1.35;
}
.hero-title span {
  background: linear-gradient(120deg, var(--primary) 30%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(12px, 3.2vw, 13.5px);
  color: var(--text-mid);
  margin-top: 8px;
  line-height: 1.75;
}

.privacy-strip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--primary-soft);
  border: 1px solid var(--border-soft);
  color: var(--primary);
  font-size: 11.5px;
  font-weight: 600;
  padding: 6px 16px;
  border-radius: 20px;
  margin-top: 12px;
  letter-spacing: 0.3px;
}

/* ─── Form Card ──────────────────────────────────── */
.form-card {
  background: var(--bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-xl);
  padding: clamp(20px, 5vw, 36px) clamp(16px, 5vw, 32px);
  box-shadow: var(--shadow-card);
  animation: fadeUp 0.65s ease 0.1s both;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Section Labels ─────────────────────────────── */
.section-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--primary);
  margin-bottom: 12px;
  margin-top: 26px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-label:first-of-type { margin-top: 0; }
.section-label::before {
  content: '';
  width: 3px; height: 14px;
  background: linear-gradient(180deg, var(--primary) 0%, var(--gold) 100%);
  border-radius: 2px;
  flex-shrink: 0;
}

.section-divider {
  border: none;
  border-top: 1px solid rgba(13,71,161,0.08);
  margin: 8px 0 0;
}

/* ─── Location Grid ──────────────────────────────── */
.location-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12px;
}

.name-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* ─── Field ──────────────────────────────────────── */
.field-wrap { display: flex; flex-direction: column; gap: 5px; }

.field-label {
  font-size: 11.5px;
  color: var(--text-mid);
  font-weight: 600;
}

/* ─── Inputs ─────────────────────────────────────── */
input, select, textarea {
  width: 100%;
  background: var(--bg-field);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-dark);
  font-family: var(--font-bn);
  font-size: 15px; /* 16px prevents iOS zoom, keep ≥ 16 to be safe — but 15px is fine on Android */
  padding: 11px 14px;
  transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  /* Tap highlight */
  -webkit-tap-highlight-color: transparent;
}

/* Prevent iOS zoom on focus (need font-size ≥ 16px or this trick) */
@supports (-webkit-overflow-scrolling: touch) {
  input, select, textarea { font-size: 16px; }
}

input:focus, select:focus, textarea:focus {
  border-color: var(--primary);
  background: rgba(255,255,255,0.98);
  box-shadow: 0 0 0 3px rgba(13,71,161,0.1);
}

input.error, select.error, textarea.error {
  border-color: #e53935;
  box-shadow: 0 0 0 3px rgba(229,57,53,0.09);
}

input::placeholder, textarea::placeholder { color: var(--text-muted); }
select option { background: #fff; color: var(--text-dark); }
select:disabled { opacity: 0.4; cursor: not-allowed; }

/* Touch targets: minimum 44px height for accessibility */
input, select {
  min-height: 44px;
}

.select-wrap { position: relative; }
.select-wrap select { padding-right: 34px; cursor: pointer; }
.select-wrap::after {
  content: '▾';
  position: absolute;
  right: 12px; top: 50%;
  transform: translateY(-50%);
  color: var(--primary);
  pointer-events: none;
  font-size: 13px;
}

.privacy-note {
  font-size: 10.5px;
  color: var(--primary);
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 2px;
  opacity: 0.75;
}

textarea {
  resize: vertical;
  min-height: 130px;
  line-height: 1.65;
}

.char-count {
  font-size: 11px;
  color: var(--text-soft);
  text-align: right;
  margin-top: 4px;
}

/* ─── Upload Zone ────────────────────────────────── */
.upload-zone {
  border: 2px dashed var(--border);
  border-radius: var(--radius-md);
  padding: 22px 16px;
  text-align: center;
  cursor: pointer;
  transition: border-color var(--transition), background var(--transition);
  background: rgba(235,243,253,0.55);
  position: relative;
  color: var(--text-mid);
  -webkit-tap-highlight-color: transparent;
  min-height: 90px;
}
.upload-zone:hover, .upload-zone.dragover {
  border-color: var(--primary);
  background: rgba(13,71,161,0.04);
}
.upload-zone input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%; height: 100%;
  border: none; background: transparent; padding: 0;
  font-size: 0; /* hide file dialog label on some browsers */
}
.upload-zone input[type="file"]:focus { box-shadow: none; }
.upload-icon { font-size: 30px; margin-bottom: 5px; }
.upload-text { font-size: 13.5px; font-weight: 500; }
.upload-sub { font-size: 11px; color: var(--text-soft); margin-top: 3px; line-height: 1.5; }

/* ─── Preview ────────────────────────────────────── */
.preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 12px;
}
.preview-item {
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1px solid var(--border);
  background: #f1f7fe;
  flex-shrink: 0;
}
.preview-item img, .preview-item video {
  width: 84px; height: 66px;
  object-fit: cover;
  display: block;
}
.preview-item .remove-btn {
  position: absolute;
  top: 3px; right: 3px;
  width: 22px; height: 22px;
  background: rgba(229,57,53,0.9);
  border: none; border-radius: 50%;
  color: #fff; font-size: 13px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  -webkit-tap-highlight-color: transparent;
}
.preview-item .file-name {
  font-size: 9px; color: var(--text-mid);
  padding: 3px 5px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 84px;
}

/* ─── Submit Button ──────────────────────────────── */
.submit-btn {
  width: 100%;
  margin-top: 28px;
  background: linear-gradient(120deg, var(--primary) 0%, var(--primary-light) 45%, var(--gold) 100%);
  background-size: 200% 100%;
  background-position: 0% 0%;
  border: none;
  border-radius: var(--radius-md);
  color: #fff;
  font-family: var(--font-bn);
  font-size: 16px;
  font-weight: 700;
  padding: 15px 24px;
  min-height: 52px;
  cursor: pointer;
  transition: background-position 0.45s ease, transform 0.15s, box-shadow 0.2s;
  box-shadow: var(--shadow-btn);
  letter-spacing: 0.3px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.submit-btn:hover {
  background-position: 100% 0%;
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(13,71,161,0.28);
}
.submit-btn:active { transform: scale(0.97); }
.submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.spinner {
  width: 20px; height: 20px;
  border: 2.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: none;
  flex-shrink: 0;
}
.submit-btn.loading .spinner { display: block; }
.submit-btn.loading .btn-text { display: none; }

@keyframes spin { to { transform: rotate(360deg); } }

/* ─── Modal ──────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.42);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal-overlay.show { opacity: 1; pointer-events: all; }

.modal-box {
  background: rgba(255,255,255,0.98);
  border: 1.5px solid rgba(13,71,161,0.14);
  border-radius: var(--radius-xl);
  padding: clamp(26px, 6vw, 40px) clamp(20px, 6vw, 36px);
  text-align: center;
  max-width: 400px;
  width: 100%;
  transform: scale(0.88);
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 20px 60px rgba(13,71,161,0.18);
}
.modal-overlay.show .modal-box { transform: scale(1); }
.modal-icon { font-size: 56px; margin-bottom: 12px; }
.modal-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--primary);
  font-family: var(--font-title);
  margin-bottom: 10px;
}
.modal-text {
  font-size: 13.5px;
  color: var(--text-mid);
  line-height: 1.8;
}
.modal-text strong { color: var(--primary); }
.modal-ref {
  font-size: 12.5px;
  color: #5c789e;
  margin-top: 10px;
  font-weight: 600;
}
.modal-close {
  margin-top: 22px;
  background: linear-gradient(120deg, var(--primary), var(--primary-light));
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  font-family: var(--font-bn);
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 4px 14px rgba(13,71,161,0.22);
  min-height: 46px;
  -webkit-tap-highlight-color: transparent;
}
.modal-close:hover { transform: scale(1.04); box-shadow: 0 6px 20px rgba(13,71,161,0.28); }

/* ─── Responsive ─────────────────────────────────── */

/* Tablet (600px–900px) */
@media (min-width: 600px) and (max-width: 899px) {
  .location-row { grid-template-columns: 1fr 1fr 1fr; }
  .name-row { grid-template-columns: 1fr 1fr; }
}

/* Mobile (< 600px) */
@media (max-width: 599px) {
  body { padding: 18px 12px 40px; }

  .hero-header { margin-bottom: 18px; }
  .hero-subtitle br { display: none; }

  .form-card { padding: 20px 16px; border-radius: var(--radius-lg); }

  .location-row { grid-template-columns: 1fr; gap: 10px; }
  .name-row { grid-template-columns: 1fr; gap: 10px; }

  .section-label { font-size: 10.5px; margin-top: 22px; }

  input, select { font-size: 16px !important; } /* CRITICAL: prevents iOS auto-zoom */
  textarea { font-size: 16px !important; min-height: 120px; }

  .submit-btn { font-size: 15.5px; padding: 14px 18px; }

  .preview-item img, .preview-item video { width: 76px; height: 60px; }
  .preview-item .file-name { max-width: 76px; }

  /* Stack privacy note inline on small screens */
  .privacy-note { font-size: 10px; }
}

/* Small mobile (< 380px) */
@media (max-width: 379px) {
  .hero-icon { font-size: 38px; }
  .privacy-strip { font-size: 10.5px; padding: 5px 12px; }
  .form-card { padding: 16px 13px; }
}

/* Large desktop (> 900px) */
@media (min-width: 900px) {
  body { padding: 38px 24px 60px; }
  .page-wrap { max-width: 780px; }
  .form-card { padding: 40px 38px; border-radius: 26px; }
  .hero-header { margin-bottom: 28px; }
  .section-label { font-size: 11.5px; }
  textarea { min-height: 145px; }
}

/* ─── Accessibility ──────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}

/* Focus visible for keyboard navigation */
input:focus-visible, select:focus-visible, textarea:focus-visible, button:focus-visible {
  outline: 3px solid var(--primary);
  outline-offset: 2px;
}

/* Safe area insets for notched phones */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
  body { padding-bottom: calc(48px + env(safe-area-inset-bottom)); }
}
</style>
</head>
<body>
<div class="page-wrap">

  <!-- Header -->
  <div class="hero-header">
    <div class="flag-strip">
      <div class="flag-bar"></div>
      <div class="flag-circle"></div>
      <div class="flag-bar"></div>
    </div>
    <div class="hero-icon">🗳️</div>
    <h1 class="hero-title">জাতীয় নাগরিক <span>অভিযোগ বাক্স</span></h1>
    <p class="hero-subtitle">আপনার এলাকার যেকোনো সমস্যা, দুর্নীতি বা অনিয়মের কথা জানান।<br>আপনার পরিচয় সম্পূর্ণ গোপন রাখা হবে।</p>
    <div class="privacy-strip">🔒 আপনার পরিচয় সম্পূর্ণ গোপন ও সুরক্ষিত</div>
  </div>

  <!-- Form Card -->
  <div class="form-card">
    <form id="complaintForm" novalidate>

      <!-- Location -->
      <div class="section-label">📍 আপনার এলাকা নির্বাচন করুন</div>
      <div class="location-row">
        <div class="field-wrap">
          <label class="field-label" for="division">বিভাগ *</label>
          <div class="select-wrap">
            <select id="division" onchange="loadZila()" required aria-required="true">
              <option value="">— বিভাগ —</option>
            </select>
          </div>
        </div>
        <div class="field-wrap">
          <label class="field-label" for="zila">জেলা *</label>
          <div class="select-wrap">
            <select id="zila" onchange="loadUpazila()" disabled required aria-required="true">
              <option value="">— প্রথমে বিভাগ —</option>
            </select>
          </div>
        </div>
        <div class="field-wrap">
          <label class="field-label" for="upazila">উপজেলা *</label>
          <div class="select-wrap">
            <select id="upazila" disabled required aria-required="true">
              <option value="">— প্রথমে জেলা —</option>
            </select>
          </div>
        </div>
      </div>

      <hr class="section-divider">

      <!-- Identity -->
      <div class="section-label">👤 পরিচয় তথ্য</div>
      <div class="name-row">
        <div class="field-wrap">
          <label class="field-label" for="name">আপনার নাম *</label>
          <input type="text" id="name" placeholder="পূর্ণ নাম লিখুন" required aria-required="true" autocomplete="off" inputmode="text">
          <div class="privacy-note">🔒 আপনার পরিচয় গোপন থাকবে</div>
        </div>
        <div class="field-wrap">
          <label class="field-label" for="contact">মোবাইল / সোশ্যাল মিডিয়া লিংক</label>
          <input type="text" id="contact" placeholder="+880... বা fb.com/yourprofile" autocomplete="off" inputmode="text">
          <div class="privacy-note">🔒 শুধুমাত্র যোগাযোগের জন্য</div>
        </div>
      </div>

      <hr class="section-divider" style="margin-top:20px;">

      <!-- Complaint Type -->
      <div class="section-label" style="margin-top:18px;">📋 অভিযোগের ধরন</div>
      <div class="field-wrap">
        <label class="field-label" for="complaintType">ধরন নির্বাচন করুন *</label>
        <div class="select-wrap">
          <select id="complaintType" required aria-required="true">
            <option value="">— অভিযোগের ধরন নির্বাচন করুন —</option>
            <option>দুর্নীতি ও ঘুষ</option>
            <option>রাস্তাঘাট ও অবকাঠামো</option>
            <option>শিক্ষা প্রতিষ্ঠান</option>
            <option>স্বাস্থ্যসেবা</option>
            <option>পানি ও বিদ্যুৎ</option>
            <option>আইনশৃঙ্খলা</option>
            <option>পরিবেশ দূষণ</option>
            <option>ভূমি সমস্যা</option>
            <option>অন্যান্য</option>
          </select>
        </div>
      </div>

      <hr class="section-divider" style="margin-top:20px;">

      <!-- Message -->
      <div class="section-label" style="margin-top:18px;">✍️ অভিযোগের বিবরণ</div>
      <div class="field-wrap">
        <label class="field-label" for="message">বিস্তারিত বিবরণ *</label>
        <textarea
          id="message"
          placeholder="বিস্তারিত লিখুন — কী ঘটেছে, কখন ঘটেছে, কোথায় ঘটেছে এবং কারা জড়িত..."
          maxlength="2000"
          oninput="updateCharCount()"
          required
          aria-required="true"
          inputmode="text"
        ></textarea>
        <div class="char-count"><span id="charCount">0</span> / 2000</div>
      </div>

