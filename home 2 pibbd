      <div class="intel-card-body">
        <div class="intel-card-date">${item.date}</div>
        <h3 class="intel-card-title">${item.title}</h3>
        <p class="intel-card-excerpt">${item.excerpt}</p>
        <span class="intel-card-link">READ FULL →</span>
      </div>
    </a>
  `).join('');
}

/* ---------- SEARCH ---------- */
function filterIntel(q) {
  const term = q.toLowerCase().trim();
  if (!term) { renderIntel(intelligenceData); return; }
  const filtered = intelligenceData.filter(d =>
    d.title.toLowerCase().includes(term) ||
    d.excerpt.toLowerCase().includes(term) ||
    d.type.toLowerCase().includes(term)
  );
  renderIntel(filtered);
}

