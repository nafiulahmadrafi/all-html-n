<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Political Insights BD | Research & Strategy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;700;800&family=Noto+Serif+Bengali:wght@400;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================================
   TOKENS
============================================================ */
:root {
  --red:     #c4303a;
  --red-dark:#9e1f28;
  --black:   #0a0a0a;
  --ink:     #111111;
  --white:   #ffffff;
  --cream:   #f7f5f0;
  --gray:    #666666;
  --border:  2px solid var(--ink);
  --header-h: 88px;
  --hdr-small: 64px;
  --radius: 0px;
  --shadow-hover: 8px 8px 0 var(--red);
  --shadow-hover-b: 8px 8px 0 var(--black);
  --transition: 0.3s cubic-bezier(0.4,0,0.2,1);
}

/* ============================================================
   RESET & BASE
============================================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;font-size:16px;}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--cream);
  color:var(--ink);
  overflow-x:hidden;
  padding-top:var(--header-h);
}
img{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}

/* ============================================================
   FIXED TRANSPARENT HEADER
============================================================ */
#header {
  position:fixed;
  top:0;left:0;right:0;
  height:var(--header-h);
  z-index:9999;
  display:flex;
  align-items:center;
  /* transparent over hero */
  background:transparent;
  transition:background var(--transition), height var(--transition), box-shadow var(--transition), border-bottom var(--transition);
  border-bottom:2px solid transparent;
}

/* once user scrolls: white frosted with border */
#header.scrolled {
  background:rgba(255,255,255,0.96);
  backdrop-filter:blur(16px) saturate(180%);
  -webkit-backdrop-filter:blur(16px) saturate(180%);
  height:var(--hdr-small);
  border-bottom:var(--border);
  box-shadow:0 4px 0 var(--ink);
}

.hdr-inner {
  max-width:1300px;
  width:90%;
  margin:0 auto;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:2rem;
}

/* Logo */
.hdr-logo img {
  height:58px;
  width:auto;
  transition:height var(--transition), filter var(--transition);
  filter:brightness(0) invert(1); /* white on transparent header */
}
#header.scrolled .hdr-logo img {
  height:44px;
  filter:none; /* natural color on white header */
}

/* Nav */
.hdr-nav {display:flex;align-items:center;gap:2rem;}
.hdr-nav a {
  font-size:11px;
  font-weight:800;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.9);
  position:relative;
  padding-bottom:3px;
  transition:color var(--transition);
}
#header.scrolled .hdr-nav a {color:var(--ink);}
.hdr-nav a::after {
  content:'';
  position:absolute;
  bottom:0;left:0;
  width:0;height:2px;
  background:var(--red);
  transition:width .25s ease;
}
.hdr-nav a:hover::after {width:100%;}
.hdr-nav a:hover {color:var(--red)!important;}

/* CTA button */
.hdr-cta {
  background:var(--red);
  color:#fff!important;
  padding:10px 22px;
  font-size:10px;
  font-weight:900;
  letter-spacing:.14em;
  text-transform:uppercase;
  border:2px solid rgba(255,255,255,0.5);
  transition:background var(--transition),border-color var(--transition),transform .15s;
  white-space:nowrap;
}
#header.scrolled .hdr-cta {border-color:var(--ink);}
.hdr-cta:hover {background:var(--red-dark);transform:translateY(-2px);}
.hdr-cta::after{display:none!important;}

/* Hamburger */
.hamburger {
  display:none;
  flex-direction:column;
  gap:6px;
  cursor:pointer;
  background:none;
  border:none;
  padding:4px;
}
.hamburger span {
  display:block;width:28px;height:2px;
  background:#fff;
  transition:background var(--transition),transform .3s;
  border-radius:1px;
}
#header.scrolled .hamburger span {background:var(--ink);}

/* Mobile nav */
.mobile-nav {
  display:none;
  position:fixed;
  top:var(--hdr-small);left:0;right:0;
  background:#fff;
  border-bottom:var(--border);
  padding:1.5rem 5vw 2rem;
  flex-direction:column;
  gap:0;
  z-index:9998;
  box-shadow:0 8px 0 var(--ink);
}
.mobile-nav.open {display:flex;}
.mobile-nav a {
  font-size:.9rem;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.08em;
  color:var(--ink);
  padding:.9rem 0;
  border-bottom:1px solid #e0e0e0;
}
.mobile-nav a:last-child{border:none;}

/* ============================================================
   TICKER / MARQUEE
============================================================ */
.ticker-wrap {
  background:var(--red);
  border-bottom:var(--border);
  overflow:hidden;
  height:38px;
  display:flex;
  align-items:center;
}
.ticker-inner {
  display:flex;
  white-space:nowrap;
  animation:ticker 28s linear infinite;
  gap:0;
}
.ticker-inner span {
  font-size:10px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
  color:#fff;
  padding:0 40px;
}
.ticker-inner span::before {
  content:'●';
  margin-right:16px;
  opacity:.6;
}
@keyframes ticker {
  from{transform:translateX(0);}
  to{transform:translateX(-50%);}
}

/* ============================================================
   HERO
============================================================ */
#hero {
  background:#fff;
  border-bottom:var(--border);
  position:relative;
  overflow:hidden;
  min-height:calc(100vh - var(--header-h));
  display:flex;
  flex-direction:column;
}

/* The big editorial top strip */
.hero-top {
  border-bottom:var(--border);
  display:grid;
  grid-template-columns:1fr 2fr 1fr;
}
.hero-column {border-right:var(--border);}
.hero-column:last-child{border-right:none;}

.hero-label {
  padding:1rem 1.5rem;
  font-size:9px;
  font-weight:900;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--gray);
  border-bottom:var(--border);
}

.hero-main {
  padding:4rem 2rem 3rem;
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.hero-kicker {
  display:inline-flex;
  align-items:center;
  gap:10px;
  font-size:10px;
  font-weight:900;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--red);
  margin-bottom:1.5rem;
}
.hero-kicker::before {
  content:'';
  display:block;
  width:32px;height:2px;
  background:var(--red);
}

.hero-title {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:clamp(2.8rem,5.5vw,5.5rem);
  font-weight:900;
  line-height:1.02;
  letter-spacing:-.02em;
  color:var(--ink);
  margin-bottom:1.5rem;
}
.hero-title em {
  font-style:italic;
  color:var(--red);
}

.hero-desc {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:1.05rem;
  line-height:1.75;
  color:var(--gray);
  max-width:540px;
  margin-bottom:2.5rem;
}

.hero-actions {display:flex;gap:1rem;flex-wrap:wrap;}

.btn-solid {
  background:var(--ink);
  color:#fff;
  padding:14px 28px;
  font-size:11px;
  font-weight:900;
  letter-spacing:.12em;
  text-transform:uppercase;
  border:2px solid var(--ink);
  cursor:pointer;
  display:inline-flex;align-items:center;gap:8px;
  transition:all var(--transition);
}
.btn-solid:hover {background:var(--red);border-color:var(--red);transform:translate(-3px,-3px);box-shadow:6px 6px 0 var(--ink);}

.btn-ghost {
  background:transparent;
  color:var(--ink);
  padding:14px 28px;
  font-size:11px;
  font-weight:900;
  letter-spacing:.12em;
  text-transform:uppercase;
  border:2px solid var(--ink);
  cursor:pointer;
  display:inline-flex;align-items:center;gap:8px;
  transition:all var(--transition);
}
.btn-ghost:hover {transform:translate(-3px,-3px);box-shadow:6px 6px 0 var(--ink);}

/* Hero right column: stats */
.hero-stats {
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding:2rem 1.5rem;
  gap:0;
}
.hero-stat {
  padding:1.5rem 0;
  border-bottom:1px solid #e0e0e0;
}
.hero-stat:last-child{border-bottom:none;}
.hero-stat-num {
  font-family:'Playfair Display',serif;
  font-size:3rem;
  font-weight:900;
  color:var(--ink);
  line-height:1;
}
.hero-stat-num sup {color:var(--red);font-size:1.5rem;}
.hero-stat-label {
  font-size:9px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
  color:var(--gray);
  margin-top:.3rem;
}

/* Hero left column: feature card */
.hero-feature {
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:1.5rem;
  gap:0;
  background:var(--ink);
  color:#fff;
  position:relative;
  overflow:hidden;
}
.hero-feature::before {
  content:'POLITICAL\AINSIGHTS';
  white-space:pre;
  position:absolute;
  top:-1rem;left:-1rem;
  font-family:'Playfair Display',serif;
  font-size:5rem;
  font-weight:900;
  color:rgba(255,255,255,0.04);
  line-height:.9;
  pointer-events:none;
}
.hero-feature-tag {
  font-size:9px;
  font-weight:900;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--red);
  margin-bottom:.7rem;
}
.hero-feature-title {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.1rem;
  font-weight:900;
  color:#fff;
  line-height:1.3;
  margin-bottom:.6rem;
}
.hero-feature-desc {
  font-size:.78rem;
  color:rgba(255,255,255,.5);
  line-height:1.5;
}

/* ============================================================
   STATS BAR
============================================================ */
.stats-bar {
  background:var(--ink);
  border-bottom:var(--border);
  display:grid;
  grid-template-columns:repeat(4,1fr);
}
.stats-bar-item {
  padding:2rem 2.5rem;
  border-right:1px solid rgba(255,255,255,.1);
  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
}
.stats-bar-item:last-child{border-right:none;}
.stats-bar-num {
  font-family:'Playfair Display',serif;
  font-size:2.8rem;
  font-weight:900;
  color:#fff;
  line-height:1;
}
.stats-bar-num span{color:var(--red);}
.stats-bar-lbl {
  font-size:9px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
  color:rgba(255,255,255,.4);
  margin-top:.4rem;
}

/* ============================================================
   SECTION UTILS
============================================================ */
.section {padding:80px 5%;}
.section-alt {background:#fff;}
.section-dark {background:var(--ink);}

.s-label {
  display:inline-flex;
  align-items:center;
  gap:10px;
  font-size:9px;
  font-weight:900;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--red);
  margin-bottom:.8rem;
}
.s-label::before {content:'';width:24px;height:2px;background:var(--red);}

.s-heading {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:clamp(2rem,4vw,3.5rem);
  font-weight:900;
  line-height:1.1;
  letter-spacing:-.02em;
  color:var(--ink);
}
.s-heading-white {color:#fff;}

.s-sub {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.95rem;
  color:var(--gray);
  line-height:1.7;
  margin-top:.8rem;
  max-width:560px;
}
.s-sub-white{color:rgba(255,255,255,.55);}

.section-head {margin-bottom:3.5rem;}

/* ============================================================
   INTELLIGENCE HUB (RESEARCH + BLOG)
============================================================ */
.intel-search {
  width:100%;
  max-width:700px;
  padding:16px 22px;
  border:var(--border);
  background:#fff;
  font-family:'DM Sans',sans-serif;
  font-size:14px;
  font-weight:700;
  letter-spacing:.06em;
  outline:none;
  margin:1.5rem 0 3rem;
  display:block;
  transition:box-shadow var(--transition);
}
.intel-search:focus {box-shadow:6px 6px 0 var(--red);}
.intel-search::placeholder{color:#aaa;text-transform:uppercase;letter-spacing:.1em;}

.intel-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
  gap:0;
  border-top:var(--border);
  border-left:var(--border);
}

.intel-card {
  border-right:var(--border);
  border-bottom:var(--border);
  background:#fff;
  transition:transform var(--transition), box-shadow var(--transition);
  position:relative;
  overflow:hidden;
}
.intel-card:hover {
  transform:translate(-4px,-4px);
  box-shadow:var(--shadow-hover);
  z-index:2;
}

.intel-card-img {
  height:210px;
  overflow:hidden;
  border-bottom:var(--border);
  background:var(--cream);
  position:relative;
}
.intel-card-img img {
  width:100%;height:100%;
  object-fit:cover;
  transition:transform .5s ease;
}
.intel-card:hover .intel-card-img img {transform:scale(1.05);}

.intel-card-type {
  position:absolute;
  top:1rem;left:1rem;
  background:var(--red);
  color:#fff;
  font-size:9px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
  padding:5px 10px;
}

.intel-card-body {padding:1.8rem 1.6rem 2rem;}
.intel-card-date {
  font-size:10px;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--gray);
  margin-bottom:.6rem;
}
.intel-card-title {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.25rem;
  font-weight:900;
  line-height:1.3;
  color:var(--ink);
  margin-bottom:.8rem;
}
.intel-card-excerpt {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.83rem;
  color:var(--gray);
  line-height:1.65;
  margin-bottom:1.2rem;
  display:-webkit-box;
  -webkit-line-clamp:3;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.intel-card-link {
  font-size:10px;
  font-weight:900;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--ink);
  border-bottom:2px solid var(--red);
  padding-bottom:2px;
  display:inline-flex;
  align-items:center;
  gap:6px;
  transition:color var(--transition), gap var(--transition);
}
.intel-card:hover .intel-card-link {color:var(--red);gap:12px;}

.intel-no-results {
  grid-column:1/-1;
  text-align:center;
  padding:4rem 2rem;
  border-right:var(--border);
  border-bottom:var(--border);
}
.intel-no-results h3 {
  font-family:'Playfair Display',serif;
  font-size:1.5rem;
  font-weight:900;
  color:var(--gray);
}

/* ============================================================
   SERVICES
============================================================ */
.services-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  border-top:var(--border);
  border-left:var(--border);
  margin-top:3rem;
}
.service-cell {
  border-right:var(--border);
  border-bottom:var(--border);
  padding:2.5rem 2rem;
  background:#fff;
  position:relative;
  overflow:hidden;
  transition:background var(--transition);
  cursor:default;
}
.service-cell::after {
  content:'';
  position:absolute;
  bottom:0;left:0;right:0;
  height:4px;
  background:var(--red);
  transform:scaleX(0);
  transform-origin:left;
  transition:transform .35s ease;
}
.service-cell:hover::after {transform:scaleX(1);}
.service-cell:hover {background:var(--cream);}
.service-num {
  font-family:'Playfair Display',serif;
  font-size:4.5rem;
  font-weight:900;
  color:#e8e4dc;
  line-height:1;
  margin-bottom:1rem;
  transition:color var(--transition);
}
.service-cell:hover .service-num {color:#d4cec3;}
.service-icon {
  width:46px;height:46px;
  background:var(--red);
  display:flex;align-items:center;justify-content:center;
  font-size:1.3rem;
  margin-bottom:1.2rem;
}
.service-title {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.1rem;
  font-weight:900;
  margin-bottom:1rem;
}
.service-list {list-style:none;display:flex;flex-direction:column;gap:.5rem;}
.service-list li {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.82rem;
  color:var(--gray);
  padding-left:1.1rem;
  position:relative;
  line-height:1.5;
}
.service-list li::before {content:'→';position:absolute;left:0;color:var(--red);font-weight:900;}

/* ============================================================
   ELECTION RESULTS
============================================================ */
.election-layout {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:0;
  border:var(--border);
  background:var(--ink);
}
.election-info {
  padding:3.5rem;
  border-right:1px solid rgba(255,255,255,.1);
}
.election-results {padding:3.5rem;}

.result-card {
  display:flex;
  align-items:center;
  gap:1.5rem;
  padding:1.4rem;
  border:1px solid rgba(255,255,255,.08);
  margin-bottom:1rem;
  position:relative;
  overflow:hidden;
  transition:border-color var(--transition);
}
.result-card::before {
  content:'';
  position:absolute;
  left:0;top:0;bottom:0;
  width:4px;
}
.result-card.winner::before {background:#d4a017;}
.result-card.opposition::before {background:var(--red);}
.result-card.others::before {background:rgba(255,255,255,.2);}
.result-card:hover {border-color:rgba(255,255,255,.2);}

.result-seats {
  font-family:'Playfair Display',serif;
  font-size:3rem;
  font-weight:900;
  line-height:1;
  color:#fff;
  min-width:90px;
}
.result-seats.gold {color:#d4a017;}
.result-seats.crimson {color:#ff6b6b;}
.result-party {font-size:.92rem;font-weight:800;color:#fff;margin-bottom:.3rem;}
.result-status {font-size:.72rem;color:rgba(255,255,255,.4);letter-spacing:.08em;}

.bar-wrap {margin-top:2rem;}
.bar-label {font-size:9px;font-weight:900;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:.5rem;}
.bar-track {height:8px;background:rgba(255,255,255,.06);display:flex;border-radius:0;overflow:hidden;}
.bar-fill-1 {background:#d4a017;width:70.7%;}
.bar-fill-2 {background:var(--red);width:25.7%;}
.bar-fill-3 {background:rgba(255,255,255,.15);width:3.6%;}
.bar-legend {display:flex;gap:1.5rem;margin-top:.7rem;}
.bar-legend-item {display:flex;align-items:center;gap:6px;font-size:10px;color:rgba(255,255,255,.4);font-weight:700;letter-spacing:.06em;}
.bar-legend-dot {width:8px;height:8px;}
.status-badge {
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(0,53,128,.25);
  border:1px solid rgba(0,53,128,.5);
  color:#7eb3ff;
  font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;
  padding:.45rem 1rem;
  margin-bottom:1.5rem;
}
.status-badge::before {
  content:'';width:6px;height:6px;border-radius:50%;
  background:#7eb3ff;
  animation:blink 1.5s ease infinite;
}
@keyframes blink{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(1.5);}}

/* ============================================================
   ABOUT
============================================================ */
.about-layout {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:0;
  border-top:var(--border);
  border-left:var(--border);
}
.about-col {
  border-right:var(--border);
  border-bottom:var(--border);
  padding:3rem;
}
.about-quote {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.15rem;
  font-style:italic;
  line-height:1.7;
  border-left:4px solid var(--red);
  padding:1.2rem 1.5rem;
  background:var(--cream);
  margin:1.5rem 0;
  color:var(--ink);
}
.about-para {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.92rem;
  color:var(--gray);
  line-height:1.8;
  margin-bottom:1.2rem;
}
.check-list {list-style:none;display:flex;flex-direction:column;gap:.65rem;margin-top:.8rem;}
.check-list li {
  display:flex;align-items:center;gap:.75rem;
  font-size:.87rem;font-weight:700;color:var(--ink);
}
.check-list li::before {
  content:'✓';
  flex-shrink:0;
  width:22px;height:22px;
  background:var(--red);
  color:#fff;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;font-weight:900;
}
.research-card {
  border:var(--border);
  padding:1.3rem;
  background:#fff;
  margin-bottom:1rem;
  transition:transform var(--transition),box-shadow var(--transition);
}
.research-card:hover {transform:translate(-4px,-4px);box-shadow:var(--shadow-hover-b);}
.research-card h4 {
  font-size:.87rem;font-weight:900;color:var(--ink);margin-bottom:.4rem;
  display:flex;align-items:center;gap:8px;
}
.research-card h4::before {content:'';width:6px;height:6px;border-radius:50%;background:var(--red);flex-shrink:0;}
.research-card p {font-family:'Noto Serif Bengali',sans-serif;font-size:.78rem;color:var(--gray);line-height:1.5;}

/* ============================================================
   BOOKS
============================================================ */
.books-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:0;
  border-top:var(--border);
  border-left:var(--border);
  margin-top:3rem;
}
.book-card {
  border-right:var(--border);
  border-bottom:var(--border);
  background:#fff;
  overflow:hidden;
  transition:transform var(--transition),box-shadow var(--transition);
}
.book-card:hover {transform:translate(-4px,-4px);box-shadow:var(--shadow-hover);z-index:2;position:relative;}
.book-cover {
  aspect-ratio:2/3;
  overflow:hidden;
  border-bottom:var(--border);
  background:var(--cream);
}
.book-cover img {width:100%;height:100%;object-fit:cover;transition:transform .5s ease;}
.book-card:hover .book-cover img {transform:scale(1.04);}
.book-info {padding:1.5rem 1.3rem 1.8rem;}
.book-title {
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.05rem;font-weight:900;
  color:var(--ink);margin-bottom:.5rem;
}
.book-desc {font-size:.8rem;color:var(--gray);line-height:1.55;}
.view-more-wrap {text-align:center;margin-top:3rem;}

/* ============================================================
   FAQ
============================================================ */
.faq-list {border-top:var(--border);}
.faq-item {border-bottom:var(--border);}
.faq-q {
  width:100%;text-align:left;background:none;border:none;cursor:pointer;
  padding:1.4rem 0;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  font-family:'DM Sans',sans-serif;
  font-size:.97rem;font-weight:800;color:var(--ink);
  transition:color var(--transition);
}
.faq-q:hover {color:var(--red);}
.faq-icon {
  width:30px;height:30px;
  border:2px solid var(--ink);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;font-weight:900;color:var(--ink);
  flex-shrink:0;
  transition:transform .3s,background var(--transition),color var(--transition);
}
.faq-item.open .faq-icon {transform:rotate(45deg);background:var(--red);border-color:var(--red);color:#fff;}
.faq-answer {
  max-height:0;overflow:hidden;
  transition:max-height .4s ease,padding-bottom .3s;
}
.faq-item.open .faq-answer {max-height:200px;padding-bottom:1.2rem;}
.faq-answer p {
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.88rem;color:var(--gray);line-height:1.75;
}

