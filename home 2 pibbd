/* ---------- RENDER INTEL ---------- */
function renderIntel(data) {
  const grid = document.getElementById('intel-grid');
  if (!data.length) {
    grid.innerHTML = `<div class="intel-no-results"><h3>No results found.</h3></div>`;
    return;
  }
  grid.innerHTML = data.map(item => `
    <a href="${item.link}" class="intel-card">
      <div class="intel-card-img">
        <img src="${item.img}" alt="${item.title}" loading="lazy">
        <div class="intel-card-type">${item.type}</div>
