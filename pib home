    policyEl.innerHTML = pData.map(p => makeCard(p,'badge-policy','POLICY')).join('');
  } else {
    const fb = fallbackPosts.filter(p=>p.type==='policy').slice(0,3);
    policyEl.innerHTML = (fb.length ? fb : fallbackPosts.slice(0,3)).map(p=>makeCard(p,'badge-policy','POLICY')).join('');
  }

  /* Research */
  const researchEl = document.getElementById('researchGrid');
  const rData = await fetchCategory('research', 4);
  if (rData && rData.length) {
    researchEl.innerHTML = rData.map(p => makeCard(p,'badge-research','RESEARCH')).join('');
  } else {
    researchEl.innerHTML = fallbackPosts.filter(p=>p.type==='research').slice(0,4).map(p=>makeCard(p,'badge-research','RESEARCH')).join('');
  }

  /* Report */
  const reportEl = document.getElementById('reportGrid');
  const rpData = await fetchCategory('report', 3);
  if (rpData && rpData.length) {
    reportEl.innerHTML = rpData.map(p => makeCard(p,'badge-report','REPORT')).join('');
  } else {
    reportEl.innerHTML = fallbackPosts.filter(p=>p.type==='report').slice(0,3).map(p=>makeCard(p,'badge-report','REPORT')).join('');
  }

  /* All Insights */
  const insightsEl = document.getElementById('insightsGrid');
  try {
    const iRes = await fetch(`${WP}/posts?_embed&per_page=4&_fields=id,title,excerpt,date,link,_embedded`);
    if (iRes.ok) {
      const iData = await iRes.json();
      insightsEl.innerHTML = iData.map(p => makeCard(p,'badge-insights','INSIGHTS')).join('');
    } else throw new Error();
  } catch(e) {
    insightsEl.innerHTML = fallbackPosts.slice(0,4).map(p=>makeCard(p,'badge-insights','INSIGHTS')).join('');
  }
}

/* ─── PUBLICATIONS / BOOKS ─── */
async function loadBooks() {
  const el = document.getElementById('booksGrid');
  // Try WP custom post type 'books' or 'book'
  let loaded = false;
  try {
    const res = await fetch(`${WP}/books?_embed&per_page=3`);
    if (res.ok) {
      const data = await res.json();
      if (data.length) {
        el.innerHTML = data.map(b => makeBookCard({
          title: b.title?.rendered || b.title,
          desc: b.excerpt?.rendered?.replace(/<[^>]*>/g,'').slice(0,100)||'',
          img: b._embedded?.['wp:featuredmedia']?.[0]?.source_url||fallbackBooks[0].img,
          link: b.link
        })).join('');
        loaded = true;
      }
    }
  } catch(e){}
  if (!loaded) {
    el.innerHTML = fallbackBooks.slice(0,3).map(b=>makeBookCard(b)).join('');
  }
}

/* ─── HEADER SCROLL ─── */
const hdr = document.getElementById('hdr');
window.addEventListener('scroll', () => {
  hdr.classList.toggle('scrolled', window.scrollY > 80);
  document.getElementById('scrollTopBtn').classList.toggle('vis', window.scrollY > 500);
});

/* ─── HAMBURGER ─── */
const hamBtn = document.getElementById('hamBtn');
const mobNav = document.getElementById('mobNav');
hamBtn.addEventListener('click', () => {
  hamBtn.classList.toggle('open');
  mobNav.classList.toggle('open');
});
mobNav.querySelectorAll('a').forEach(a => a.addEventListener('click',() => {
  hamBtn.classList.remove('open');
  mobNav.classList.remove('open');
}));

/* ─── FAQ ─── */
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  });
});

/* ─── SCROLL REVEAL ─── */
const revObs = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => entry.target.classList.add('in'), i * 80);
      revObs.unobserve(entry.target);
    }
  });
}, { threshold: 0.07 });
document.querySelectorAll('[data-r]').forEach(el => revObs.observe(el));

