.ft-social{display:flex;gap:.8rem;margin-top:1.2rem;}
.ft-soc-btn{
  width:34px;height:34px;border-radius:var(--radius-sm);
  background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);
  display:flex;align-items:center;justify-content:center;
  font-size:.9rem;color:rgba(255,255,255,.5);
  transition:all var(--T);text-decoration:none;
}
.ft-soc-btn:hover{background:var(--green);color:#fff;border-color:var(--green);}
.ft-h{font-size:9px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:.9rem;}
.ft-links{list-style:none;display:flex;flex-direction:column;gap:.55rem;}
.ft-links a{font-size:.82rem;color:rgba(255,255,255,.45);transition:color var(--T);}
.ft-links a:hover{color:#fff;}
.ft-bottom{
  max-width:1360px;width:92%;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.4rem 0;font-size:.75rem;
  color:rgba(255,255,255,.22);flex-wrap:wrap;gap:.8rem;
}
.ft-bottom a{color:var(--green);}
.ft-flag-bar{
  display:flex;align-items:center;gap:6px;
}
.ft-flag-g{width:16px;height:10px;background:var(--green);border-radius:1px;}
.ft-flag-r{width:10px;height:10px;border-radius:50%;background:var(--red);}

/* Scroll top */
#scrollTopBtn{
  position:fixed;bottom:1.8rem;right:1.8rem;
  width:44px;height:44px;border-radius:var(--radius-sm);
  background:var(--green);color:#fff;
  border:none;font-size:1rem;font-weight:900;
  display:flex;align-items:center;justify-content:center;
  opacity:0;transform:translateY(12px);
  transition:all var(--T);z-index:900;
  box-shadow:0 4px 16px rgba(0,106,78,.35);
}
#scrollTopBtn.vis{opacity:1;transform:none;}
#scrollTopBtn:hover{background:var(--green-d);transform:translateY(-2px)!important;}

/* Reveal animation */
[data-r]{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease;}
[data-r].in{opacity:1;transform:none;}

