<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Political Insights BD — রাজনৈতিক বিশ্লেষণ ও কৌশলগত গবেষণা</title>
<meta name="description" content="Bangladesh's leading political analysis, policy research, and strategic consulting platform. Data-driven insights for democratic transition.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;700;800&family=Noto+Serif+Bengali:wght@400;600;700&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════
   DESIGN TOKENS — BD FLAG LIGHT THEME
═══════════════════════════════════════════ */
:root {
  --green:      #006A4E;   /* Bangladesh flag green */
  --green-d:    #004f3a;
  --green-l:    #e6f2ee;
  --green-ll:   #f0f8f5;
  --red:        #F42A41;   /* Bangladesh flag red (circle) */
  --red-d:      #c41f31;
  --red-l:      #fff0f1;
  --white:      #ffffff;
  --off-white:  #f9fafb;
  --cream:      #f5f3ef;
  --ink:        #0d1117;
  --ink-soft:   #1a2332;
  --gray:       #5a6474;
  --gray-l:     #8a95a3;
  --border:     1px solid #dee2e8;
  --border-d:   2px solid var(--ink);
  --shadow-sm:  0 2px 8px rgba(0,0,0,.07);
  --shadow-md:  0 8px 32px rgba(0,0,0,.10);
  --shadow-lg:  0 20px 60px rgba(0,0,0,.12);
  --radius-sm:  4px;
  --radius:     8px;
  --radius-lg:  14px;
  --header-h:   84px;
  --header-s:   62px;
  --T:          0.3s cubic-bezier(.4,0,.2,1);
}

/* ═══════════════════════════════════════════  RESET  */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;font-size:16px;}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--white);
  color:var(--ink);
  overflow-x:hidden;
  padding-top:var(--header-h);
}
img{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}
button{cursor:pointer;font-family:inherit;}

/* ═══════════════════════════════════════════
   FIXED TRANSPARENT HEADER
═══════════════════════════════════════════ */
#hdr {
  position:fixed;
  top:0;left:0;right:0;
  height:var(--header-h);
  z-index:9999;
  background:transparent;
  transition:background var(--T), height var(--T), box-shadow var(--T), border-bottom var(--T);
  border-bottom:1px solid transparent;
}
#hdr.scrolled {
  background:rgba(255,255,255,.97);
  backdrop-filter:blur(18px) saturate(180%);
  -webkit-backdrop-filter:blur(18px) saturate(180%);
  height:var(--header-s);
  border-bottom:var(--border);
  box-shadow:0 2px 20px rgba(0,106,78,.08);
}
.hdr-inner{
  max-width:1360px;width:92%;
  margin:0 auto;height:100%;
  display:flex;align-items:center;
  justify-content:space-between;gap:2rem;
}
/* Logo */
.hdr-logo img{
  height:54px;width:auto;
  transition:height var(--T),filter var(--T);
  filter:brightness(0) invert(1);
}
#hdr.scrolled .hdr-logo img{height:42px;filter:none;}

/* Nav links */
.hdr-nav{display:flex;align-items:center;gap:1.6rem;}
.hdr-nav a{
  font-size:11.5px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;
  color:rgba(255,255,255,.92);
  position:relative;padding-bottom:3px;
  white-space:nowrap;
  transition:color var(--T);
}
#hdr.scrolled .hdr-nav a{color:var(--ink);}
.hdr-nav a::after{
  content:'';position:absolute;bottom:0;left:0;
  width:0;height:2px;background:var(--green);
  transition:width .25s ease;
}
.hdr-nav a:hover::after{width:100%;}
.hdr-nav a:hover{color:var(--green)!important;}
/* Active link */
.hdr-nav a.active{color:var(--green)!important;}
.hdr-nav a.active::after{width:100%;}

/* CTA */
.hdr-cta{
  background:var(--red);color:#fff!important;
  padding:9px 20px;
  font-size:11px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  border-radius:var(--radius-sm);
  border:none;
  transition:background var(--T),transform .15s;
  white-space:nowrap;
}
.hdr-cta::after{display:none!important;}
.hdr-cta:hover{background:var(--red-d);transform:translateY(-2px);}

/* Hamburger */
.ham-btn{
  display:none;flex-direction:column;
  gap:5px;background:none;border:none;
  padding:6px;
}
.ham-btn span{
  display:block;width:26px;height:2px;
  background:#fff;border-radius:2px;
  transition:background var(--T),transform .3s;
}
#hdr.scrolled .ham-btn span{background:var(--ink);}
.ham-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.ham-btn.open span:nth-child(2){opacity:0;}
.ham-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* ── MOBILE SOCIAL ICONS (left of logo) ── */
.hdr-mob-social{
  display:none;
  align-items:center;
  gap:.4rem;
  flex-shrink:0;
}
.hdr-mob-icon{
  width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;text-decoration:none;
  border:1.5px solid rgba(0,0,0,.12);
  color:var(--ink);
  background:rgba(255,255,255,.75);
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  transition:all var(--T);
  flex-shrink:0;
}
#hdr.scrolled .hdr-mob-icon{
  background:var(--green-ll);
  border-color:var(--green-l);
  color:var(--ink);
}
.hdr-mob-icon.call-icon:hover,.hdr-mob-icon.call-icon:active{
  background:var(--green);border-color:var(--green);color:#fff;
  transform:scale(1.08);
}
.hdr-mob-icon.wa-icon:hover,.hdr-mob-icon.wa-icon:active{
  background:#25d366;border-color:#25d366;color:#fff;
  transform:scale(1.08);
}

/* Mobile Nav */
.mob-nav{
  display:none;position:fixed;
  top:var(--header-s);left:0;right:0;
  background:#fff;
  border-bottom:2px solid var(--green);
  box-shadow:var(--shadow-md);
  flex-direction:column;padding:1rem 5%;
  z-index:9998;
  animation:slideDown .25s ease;
}
.mob-nav.open{display:flex;}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:none;}}
.mob-nav a{
  font-size:.9rem;font-weight:700;
  text-transform:uppercase;letter-spacing:.06em;
  color:var(--ink);padding:.8rem 0;
  border-bottom:var(--border);
  display:flex;align-items:center;gap:.6rem;
}
.mob-nav a:last-child{border:none;}
.mob-nav a:hover{color:var(--green);}

/* ═══════════════════════════════════════════
   NEWS TICKER
═══════════════════════════════════════════ */
.ticker{
  background:var(--green);
  overflow:hidden;height:36px;
  display:flex;align-items:center;
  border-bottom:2px solid var(--green-d);
  position:relative;
}
.ticker-label{
  flex-shrink:0;background:var(--red);
  color:#fff;font-size:9px;font-weight:900;
  letter-spacing:.2em;text-transform:uppercase;
  padding:0 1.2rem;height:100%;
  display:flex;align-items:center;gap:6px;
  white-space:nowrap;
  z-index:2;
}
.ticker-label::after{
  content:'';position:absolute;
  left:68px;top:0;bottom:0;width:24px;
  background:linear-gradient(90deg,var(--red),transparent);
  pointer-events:none;
}
.ticker-track{overflow:hidden;flex:1;}
.ticker-inner{
  display:inline-flex;white-space:nowrap;
  animation:ticker 36s linear infinite;
  gap:0;
}
.ticker-inner span{
  font-size:11px;font-weight:700;letter-spacing:.06em;
  color:rgba(255,255,255,.92);padding:0 28px;
  display:flex;align-items:center;gap:8px;
}
.ticker-inner span::before{
  content:'●';font-size:6px;color:var(--red);opacity:.8;
}
@keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ═══════════════════════════════════════════
   HERO — LIGHT BILINGUAL BOLD
═══════════════════════════════════════════ */

/* Header nav adapts to light hero */
#hdr:not(.scrolled) .hdr-nav a { color: var(--ink) !important; }
#hdr:not(.scrolled) .hdr-logo img { filter: none !important; }
#hdr:not(.scrolled) .ham-btn span { background: var(--ink) !important; }

#hero {
  background: var(--white);
  min-height: calc(100vh - var(--header-h));
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  border-bottom: 3px solid var(--green);
}

/* BD flag colour wash — very subtle */
#hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 70% at 85% 30%, rgba(0,106,78,.07) 0%, transparent 70%),
    radial-gradient(ellipse 45% 55% at 10% 80%, rgba(244,42,65,.05) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

/* Large ghost letter watermark */
#hero::after {
  content: 'PIBD';
  position: absolute;
  right: -2rem;
  bottom: -1rem;
  font-family: 'Playfair Display', serif;
  font-size: clamp(8rem, 18vw, 18rem);
  font-weight: 900;
  color: rgba(0,106,78,.04);
  line-height: 1;
  pointer-events: none;
  z-index: 0;
  letter-spacing: -.04em;
}

/* Top accent stripe — BD flag */
.hero-flag-stripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
  background: linear-gradient(90deg, var(--green) 60%, var(--red) 60%);
  z-index: 1;
}

.hero-grid {
  max-width: 1360px;
  width: 92%;
  margin: 0 auto;
  flex: 1;
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 0;
  align-items: center;
  padding: 4.5rem 0 4rem;
  position: relative;
  z-index: 1;
}

/* ─── LEFT COLUMN ─── */
.hero-left {
  padding-right: 4.5rem;
  border-right: 1.5px solid var(--green-l);
}

/* Bilingual eyebrow */
.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: .7rem;
  margin-bottom: 1.6rem;
  flex-wrap: wrap;
}
.hero-eyebrow-bn {
  font-family: 'Noto Serif Bengali', serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--green);
  letter-spacing: .02em;
}
.hero-eyebrow-divider {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--red);
  flex-shrink: 0;
}
.hero-eyebrow-en {
  font-size: 10px;
  font-weight: 900;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gray);
}

/* The bilingual stacked title */
.hero-title {
  margin-bottom: 1.6rem;
  line-height: 1;
}
.ht-line-en {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  font-weight: 900;
  letter-spacing: -.03em;
  color: var(--ink);
  line-height: .95;
}
.ht-line-en .hl-g { color: var(--green); }
.ht-line-en .hl-r { color: var(--red); font-style: italic; }
.ht-line-bn {
  display: block;
  font-family: 'Noto Serif Bengali', serif;
  font-size: clamp(1.5rem, 2.8vw, 2.6rem);
  font-weight: 700;
  color: var(--gray);
  line-height: 1.4;
  margin-top: .35rem;
  letter-spacing: .01em;
}
.ht-line-bn strong {
  font-weight: 900;
  color: var(--green);
}

/* Divider rule */
.hero-rule {
  display: flex;
  align-items: center;
  gap: .8rem;
  margin: 1.6rem 0;
}
.hero-rule-line {
  height: 2px;
  background: linear-gradient(90deg, var(--green), transparent);
  flex: 1;
  max-width: 120px;
}
.hero-rule-circle {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--red);
  flex-shrink: 0;
  box-shadow: 0 0 0 4px rgba(244,42,65,.15);
}

/* Bilingual description */
.hero-sub {
  margin-bottom: 2.2rem;
}
.hero-sub-en {
  font-size: .96rem;
  font-weight: 500;
  color: var(--gray);
  line-height: 1.7;
  margin-bottom: .5rem;
}
.hero-sub-bn {
  font-family: 'Noto Serif Bengali', sans-serif;
  font-size: .88rem;
  color: var(--gray-l);
  line-height: 1.75;
}

.hero-btns { display: flex; gap: .9rem; flex-wrap: wrap; }

.btn-g {
  background: var(--green); color: #fff;
  padding: 13px 26px; font-size: 11px; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm);
  border: 2px solid var(--green);
  display: inline-flex; align-items: center; gap: 7px;
  transition: all var(--T);
  box-shadow: 0 4px 14px rgba(0,106,78,.2);
}
.btn-g:hover { background: var(--green-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,106,78,.3); }

.btn-ghost-w {
  background: transparent; color: var(--ink);
  padding: 13px 26px; font-size: 11px; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm);
  border: 2px solid var(--ink);
  display: inline-flex; align-items: center; gap: 7px;
  transition: all var(--T);
}
.btn-ghost-w:hover { border-color: var(--green); color: var(--green); transform: translateY(-2px); }

/* ─── RIGHT COLUMN ─── */
.hero-right {
  padding-left: 3.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

/* Stat row */
.hero-stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: .8rem;
}
.hstat {
  background: var(--white);
  border: 1.5px solid var(--green-l);
  border-radius: var(--radius);
  padding: 1.2rem .8rem;
  text-align: center;
  transition: all var(--T);
  position: relative;
  overflow: hidden;
}
.hstat::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--green);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s ease;
}
.hstat:hover { border-color: var(--green); box-shadow: 0 6px 18px rgba(0,106,78,.1); transform: translateY(-3px); }
.hstat:hover::after { transform: scaleX(1); }
.hstat-n {
  font-family: 'Playfair Display', serif;
  font-size: 2rem; font-weight: 900;
  color: var(--green); line-height: 1;
}
.hstat-n sup { font-size: .9rem; color: var(--red); }
.hstat-l { font-size: 9px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--gray); margin-top: .3rem; }

/* Feature cards */
.hero-feat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: .8rem; }
.hfc {
  background: var(--white);
  border: 1.5px solid var(--green-l);
  border-radius: var(--radius);
  padding: 1.2rem 1rem;
  transition: all var(--T);
  position: relative;
  overflow: hidden;
}
.hfc::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px; height: 0;
  background: var(--green);
  transition: height .3s ease;
}
.hfc:hover::before { height: 100%; }
.hfc:hover { border-color: var(--green); box-shadow: 0 6px 18px rgba(0,106,78,.1); transform: translateY(-3px); }
.hfc-icon { font-size: 1.4rem; margin-bottom: .5rem; }
.hfc-num { font-size: 9px; font-weight: 900; letter-spacing: .16em; color: var(--red); margin-bottom: .3rem; }
.hfc-t { font-size: .84rem; font-weight: 800; color: var(--ink); margin-bottom: .2rem; }
.hfc-d { font-size: .74rem; color: var(--gray); line-height: 1.45; font-family: 'Noto Serif Bengali', sans-serif; }

/* Floating badge — "Live" */
.hero-live-tag {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: var(--red-l);
  border: 1px solid rgba(244,42,65,.25);
  color: var(--red);
  font-size: 9px; font-weight: 900;
  letter-spacing: .16em; text-transform: uppercase;
  padding: .38rem .9rem;
  border-radius: 20px;
  margin-bottom: 1rem;
}
.hero-live-tag::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--red);
  flex-shrink: 0;
  animation: pls 1.5s ease infinite;
}

@keyframes pls { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(1.6);} }

/* ═══════════════════════════════════════════
   IMPACT STATS BAR
═══════════════════════════════════════════ */
.impact-bar{
  background:var(--green);
  border-bottom:3px solid var(--green-d);
}
.impact-inner{
  max-width:1360px;width:92%;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);
}
.impact-item{
  padding:2rem 1.5rem;text-align:center;
  border-right:1px solid rgba(255,255,255,.15);
  position:relative;
}
.impact-item:last-child{border-right:none;}
.impact-num{
  font-family:'Playfair Display',serif;
  font-size:2.6rem;font-weight:900;color:#fff;line-height:1;
}
.impact-num span{color:#a8f3d8;}
.impact-lbl{font-size:9px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-top:.35rem;}
.impact-desc{font-family:'Noto Serif Bengali',sans-serif;font-size:.76rem;color:rgba(255,255,255,.4);margin-top:.3rem;line-height:1.4;}

/* ═══════════════════════════════════════════
   SECTION UTILS
═══════════════════════════════════════════ */
.sec{padding:72px 0;}
.sec-alt{background:var(--off-white);}
.sec-green{background:var(--green-ll);}
.sec-dark{background:var(--ink-soft);}
.sec-w{background:#fff;}
.wrap{max-width:1360px;width:92%;margin:0 auto;}

.sec-tag{
  display:inline-flex;align-items:center;gap:9px;
  font-size:9px;font-weight:900;letter-spacing:.2em;text-transform:uppercase;
  color:var(--green);margin-bottom:.7rem;
}
.sec-tag::before{content:'';width:22px;height:2px;background:var(--green);}

.sec-title{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:clamp(1.9rem,3.5vw,3rem);
  font-weight:900;line-height:1.12;
  letter-spacing:-.02em;color:var(--ink);
}
.sec-title .hl-r{color:var(--red);}
.sec-title .hl-g{color:var(--green);}
.sec-sub{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.94rem;color:var(--gray);line-height:1.75;
  margin-top:.7rem;max-width:560px;
}
.sec-head{margin-bottom:2.8rem;}

/* View More btn */
.vm-wrap{text-align:center;margin-top:2.2rem;}
.btn-vm{
  display:inline-flex;align-items:center;gap:8px;
  background:#fff;color:var(--green);
  padding:11px 28px;font-size:11px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  border:2px solid var(--green);border-radius:var(--radius-sm);
  transition:all var(--T);
}
.btn-vm:hover{background:var(--green);color:#fff;transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,106,78,.2);}

/* Section title row: heading + "view all" link */
.sec-head-row{
  display:flex;align-items:flex-end;
  justify-content:space-between;gap:2rem;
  flex-wrap:wrap;margin-bottom:2.8rem;
}
.view-all-link{
  font-size:11px;font-weight:800;letter-spacing:.1em;
  text-transform:uppercase;color:var(--green);
  display:inline-flex;align-items:center;gap:6px;
  border-bottom:2px solid var(--green);padding-bottom:2px;
  white-space:nowrap;transition:color var(--T),gap var(--T);
}
.view-all-link:hover{color:var(--red);border-color:var(--red);gap:10px;}

/* ═══════════════════════════════════════════
   WHAT WE DO — 4 PILLAR CARDS
═══════════════════════════════════════════ */
.pillars-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:0;
  border:2px solid var(--ink);
}
.pillar-card{
  padding:2rem 1.6rem;
  border-right:1px solid var(--ink);
  background:#fff;
  position:relative;overflow:hidden;
  transition:background var(--T);
}
.pillar-card:last-child{border-right:none;}
.pillar-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;
  height:4px;background:var(--green);
  transform:scaleX(0);transform-origin:left;
  transition:transform .35s ease;
}
.pillar-card:hover::after{transform:scaleX(1);}
.pillar-card:hover{background:var(--green-ll);}
.pillar-icon{
  width:48px;height:48px;border-radius:var(--radius-sm);
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;margin-bottom:1rem;
  background:var(--green-l);
  transition:background var(--T);
}
.pillar-card:hover .pillar-icon{background:var(--green);filter:grayscale(0);}
.pillar-num{
  font-family:'Playfair Display',serif;font-size:3rem;font-weight:900;
  color:var(--green-l);line-height:1;margin-bottom:.8rem;
  transition:color var(--T);
}
.pillar-card:hover .pillar-num{color:var(--green-ll);}
.pillar-label{
  font-size:9px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;
  color:var(--red);margin-bottom:.5rem;
}
.pillar-title{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1rem;font-weight:900;color:var(--ink);margin-bottom:.8rem;
}
.pillar-desc{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.8rem;color:var(--gray);line-height:1.6;
}
.pillar-link{
  display:inline-flex;align-items:center;gap:5px;
  margin-top:1rem;font-size:10px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--green);border-bottom:1px solid var(--green);
  padding-bottom:1px;transition:color var(--T),gap var(--T);
}
.pillar-link:hover{color:var(--red);border-color:var(--red);gap:9px;}

/* ═══════════════════════════════════════════
   CONTENT CARDS — UNIVERSAL
═══════════════════════════════════════════ */
.cards-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:1.4rem;
}
.cards-grid-4{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:1.4rem;
}
.post-card{
  background:#fff;
  border:var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  transition:transform var(--T),box-shadow var(--T),border-color var(--T);
  display:flex;flex-direction:column;
}
.post-card:hover{
  transform:translateY(-6px);
  box-shadow:var(--shadow-md);
  border-color:var(--green);
}
.post-card-img{
  height:185px;overflow:hidden;
  background:var(--green-ll);
  flex-shrink:0;position:relative;
}
.post-card-img img{
  width:100%;height:100%;object-fit:cover;
  transition:transform .5s ease;
}
.post-card:hover .post-card-img img{transform:scale(1.06);}
.post-type-badge{
  position:absolute;top:.8rem;left:.8rem;
  font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;
  padding:.35rem .8rem;border-radius:2px;color:#fff;
}
.badge-policy{background:var(--green);}
.badge-research{background:var(--red);}
.badge-report{background:var(--ink-soft);}
.badge-insights{background:#7c4dff;}
.badge-election{background:#e65100;}
.badge-book{background:var(--green-d);}

.post-card-body{padding:1.3rem;flex:1;display:flex;flex-direction:column;}
.post-date{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gray-l);margin-bottom:.5rem;}
.post-title{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1rem;font-weight:900;color:var(--ink);line-height:1.35;
  margin-bottom:.7rem;
}
.post-excerpt{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.8rem;color:var(--gray);line-height:1.6;
  flex:1;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
}
.post-readmore{
  display:inline-flex;align-items:center;gap:5px;
  margin-top:1rem;font-size:10px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--green);
  transition:gap var(--T),color var(--T);
}
.post-card:hover .post-readmore{gap:9px;color:var(--red);}

/* Book card — portrait */
.book-card{
  background:#fff;border:var(--border);
  border-radius:var(--radius);overflow:hidden;
  transition:transform var(--T),box-shadow var(--T),border-color var(--T);
}
.book-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-md);border-color:var(--green);}
.book-cover{
  aspect-ratio:3/4;overflow:hidden;
  background:var(--green-ll);
  border-bottom:var(--border);
}
.book-cover img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease;}
.book-card:hover .book-cover img{transform:scale(1.04);}
.book-info{padding:1.2rem;}
.book-title{font-family:'Playfair Display','Noto Serif Bengali',serif;font-size:.98rem;font-weight:900;color:var(--ink);margin-bottom:.4rem;}
.book-desc{font-family:'Noto Serif Bengali',sans-serif;font-size:.78rem;color:var(--gray);line-height:1.5;}

/* Loading skeleton */
.skeleton{
  background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);
  background-size:200% 100%;
  animation:sk .8s infinite;border-radius:var(--radius-sm);
}
@keyframes sk{0%{background-position:200% 0;}100%{background-position:-200% 0;}}

/* ═══════════════════════════════════════════
   SERVICES SECTION
═══════════════════════════════════════════ */
.services-wrap{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.4rem;margin-top:2.8rem;
}
.svc-card{
  background:#fff;border:var(--border);
  border-radius:var(--radius);
  padding:2rem 1.8rem;
  position:relative;overflow:hidden;
  transition:all var(--T);
  border-top:4px solid var(--green);
}
.svc-card:hover{
  box-shadow:var(--shadow-md);
  transform:translateY(-5px);
  border-top-color:var(--red);
}
.svc-icon{
  width:50px;height:50px;border-radius:var(--radius-sm);
  background:var(--green-l);
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;margin-bottom:1.2rem;
  transition:background var(--T);
}
.svc-card:hover .svc-icon{background:var(--green);}
.svc-title{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.05rem;font-weight:900;color:var(--ink);margin-bottom:.8rem;
}
.svc-list{list-style:none;display:flex;flex-direction:column;gap:.45rem;}
.svc-list li{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.8rem;color:var(--gray);
  padding-left:1.1rem;position:relative;line-height:1.5;
}
.svc-list li::before{content:'→';position:absolute;left:0;color:var(--green);font-weight:900;}
.svc-cta{
  display:inline-flex;align-items:center;gap:6px;
  margin-top:1.2rem;font-size:10px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--green);border-bottom:2px solid var(--green);
  padding-bottom:1px;transition:color var(--T),border-color var(--T),gap var(--T);
}
.svc-cta:hover{color:var(--red);border-color:var(--red);gap:10px;}
.svc-all-btn{
  text-align:center;margin-top:2.5rem;
}
.btn-svc{
  background:var(--green);color:#fff;
  padding:14px 36px;font-size:12px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;
  border-radius:var(--radius-sm);border:2px solid var(--green);
  display:inline-flex;align-items:center;gap:8px;
  transition:all var(--T);
}
.btn-svc:hover{background:var(--green-d);transform:translateY(-2px);box-shadow:0 10px 24px rgba(0,106,78,.25);}

/* ═══════════════════════════════════════════
   ELECTION MONITORING
═══════════════════════════════════════════ */
.election-wrap{
  display:grid;grid-template-columns:1fr 1fr;
  gap:2rem;align-items:start;
}
.election-panel{
  background:var(--ink-soft);
  border-radius:var(--radius);
  padding:2.5rem;color:#fff;
  border:2px solid var(--ink);
}
.live-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(244,42,65,.2);border:1px solid rgba(244,42,65,.4);
  color:#ff8090;font-size:9px;font-weight:900;
  letter-spacing:.16em;text-transform:uppercase;
  padding:.4rem 1rem;border-radius:var(--radius-sm);margin-bottom:1.2rem;
}
.live-badge::before{
  content:'';width:6px;height:6px;border-radius:50%;background:#ff8090;
  animation:pls 1.5s ease infinite;
}
.election-title{
  font-family:'Playfair Display',serif;
  font-size:1.6rem;font-weight:900;color:#fff;line-height:1.2;margin-bottom:1rem;
}
.seat-bar-wrap{margin:1.5rem 0;}
.seat-bar-lbl{font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:.5rem;}
.seat-bar{height:10px;background:rgba(255,255,255,.06);border-radius:5px;overflow:hidden;display:flex;}
.sb-1{background:var(--green);width:70.7%;}
.sb-2{background:var(--red);width:25.7%;}
.sb-3{background:rgba(255,255,255,.15);flex:1;}
.seat-legend{display:flex;gap:1.2rem;margin-top:.7rem;flex-wrap:wrap;}
.sl-item{display:flex;align-items:center;gap:6px;font-size:10px;color:rgba(255,255,255,.5);font-weight:700;}
.sl-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}

.result-rows{display:flex;flex-direction:column;gap:.8rem;}
.res-row{
  display:flex;align-items:center;gap:1.2rem;
  padding:1rem 1.2rem;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.07);
  border-radius:var(--radius-sm);
  border-left:4px solid transparent;
  transition:border-left-color var(--T);
}
.res-row.winner{border-left-color:var(--green);}
.res-row.oppo{border-left-color:var(--red);}
.res-row.other{border-left-color:rgba(255,255,255,.2);}
.res-num{
  font-family:'Playfair Display',serif;font-size:2.4rem;
  font-weight:900;line-height:1;min-width:72px;
}
.res-num.gn{color:#6ee7c0;}
.res-num.rd{color:#ff8090;}
.res-num.wh{color:rgba(255,255,255,.6);}
.res-info .res-party{font-size:.9rem;font-weight:800;color:#fff;margin-bottom:.2rem;}
.res-info .res-status{font-size:.72rem;color:rgba(255,255,255,.4);letter-spacing:.06em;}

/* Monitoring updates */
.monitoring-panel{display:flex;flex-direction:column;gap:0;}
.mon-header{
  background:var(--green);color:#fff;
  padding:1.2rem 1.8rem;
  border-radius:var(--radius) var(--radius) 0 0;
  display:flex;align-items:center;justify-content:space-between;
  border:2px solid var(--green-d);border-bottom:none;
}
.mon-title{font-size:.9rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase;}
.mon-badge{
  background:var(--red);color:#fff;
  font-size:9px;font-weight:900;letter-spacing:.12em;
  padding:.3rem .7rem;border-radius:2px;
  display:flex;align-items:center;gap:5px;
}
.mon-badge::before{content:'●';font-size:6px;animation:pls 1.5s infinite;}
.mon-list{
  border:2px solid var(--green-d);border-top:none;
  border-radius:0 0 var(--radius) var(--radius);
  overflow:hidden;background:#fff;
}
.mon-item{
  padding:1.1rem 1.5rem;border-bottom:var(--border);
  display:flex;gap:1rem;align-items:flex-start;
  transition:background var(--T);
}
.mon-item:last-child{border-bottom:none;}
.mon-item:hover{background:var(--green-ll);}
.mon-dot{
  width:8px;height:8px;border-radius:50%;
  flex-shrink:0;margin-top:.35rem;
}
.mon-dot.g{background:var(--green);}
.mon-dot.r{background:var(--red);}
.mon-dot.y{background:#f59e0b;}
.mon-text{font-size:.84rem;font-weight:600;color:var(--ink);line-height:1.4;}
.mon-meta{font-size:.72rem;color:var(--gray-l);margin-top:.2rem;}

/* ═══════════════════════════════════════════
   TOOLS & METHODOLOGY
═══════════════════════════════════════════ */
.tools-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.4rem;margin-top:2.8rem;
}
.tool-card{
  background:#fff;border:var(--border);
  border-radius:var(--radius);padding:1.8rem;
  transition:all var(--T);
  border-top:3px solid var(--green-l);
}
.tool-card:hover{
  border-top-color:var(--green);
  box-shadow:var(--shadow-md);transform:translateY(-4px);
}
.tool-icon{font-size:2rem;margin-bottom:.8rem;}
.tool-title{font-size:.95rem;font-weight:800;color:var(--ink);margin-bottom:.5rem;}
.tool-desc{font-family:'Noto Serif Bengali',sans-serif;font-size:.8rem;color:var(--gray);line-height:1.6;}
.tool-tag{
  display:inline-block;margin-top:.8rem;
  background:var(--green-l);color:var(--green);
  font-size:9px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;
  padding:.3rem .7rem;border-radius:2px;
}

/* ═══════════════════════════════════════════
   VISION / ABOUT
═══════════════════════════════════════════ */
.vision-wrap{
  display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;
}
.vision-img{
  position:relative;
  border-radius:var(--radius-lg);overflow:hidden;
  border:3px solid var(--green);
  aspect-ratio:4/3;background:var(--green-ll);
}
.vision-img-inner{
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--green) 0%,var(--green-d) 100%);
  padding:2.5rem;text-align:center;
}
.vision-quote-big{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:1.15rem;font-style:italic;color:rgba(255,255,255,.85);
  line-height:1.7;
}
.vision-badge{
  position:absolute;bottom:1.2rem;right:1.2rem;
  background:var(--red);color:#fff;
  font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;
  padding:.5rem 1rem;border-radius:var(--radius-sm);
}
.vision-text .vision-para{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.93rem;color:var(--gray);line-height:1.8;margin-bottom:1.1rem;
}
.check-list{list-style:none;display:flex;flex-direction:column;gap:.6rem;margin-top:.8rem;}
.check-list li{
  display:flex;align-items:center;gap:.7rem;
  font-size:.87rem;font-weight:600;color:var(--ink);
}
.check-list li::before{
  content:'✓';flex-shrink:0;
  width:20px;height:20px;border-radius:50%;
  background:var(--green);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:.62rem;font-weight:900;
}
.vision-stats{
  display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin-top:1.5rem;
}
.vs-item{
  background:var(--green-ll);border-radius:var(--radius-sm);
  padding:.9rem;text-align:center;
  border:1px solid var(--green-l);
}
.vs-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;color:var(--green);}
.vs-lbl{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);margin-top:.2rem;}

/* ═══════════════════════════════════════════
   FAQ
═══════════════════════════════════════════ */
.faq-inner{max-width:860px;margin:0 auto;}
.faq-list{border-top:2px solid var(--green-l);}
.faq-item{border-bottom:1px solid var(--green-l);}
.faq-q{
  width:100%;text-align:left;background:none;border:none;
  padding:1.3rem 0;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  font-family:'DM Sans',sans-serif;
  font-size:.96rem;font-weight:700;color:var(--ink);
  transition:color var(--T);
}
.faq-q:hover{color:var(--green);}
.faq-ico{
  width:28px;height:28px;border-radius:50%;
  border:2px solid var(--green-l);
  background:var(--green-ll);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;font-weight:900;color:var(--green);flex-shrink:0;
  transition:all .3s;
}
.faq-item.open .faq-ico{transform:rotate(45deg);background:var(--green);color:#fff;border-color:var(--green);}
.faq-ans{max-height:0;overflow:hidden;transition:max-height .4s ease,padding-bottom .3s;}
.faq-item.open .faq-ans{max-height:220px;padding-bottom:1.2rem;}
.faq-ans p{font-family:'Noto Serif Bengali',sans-serif;font-size:.87rem;color:var(--gray);line-height:1.75;}

/* ═══════════════════════════════════════════
   CONTACT
═══════════════════════════════════════════ */
.contact-wrap{
  display:grid;grid-template-columns:1fr 1fr;gap:3rem;
}
.contact-info{display:flex;flex-direction:column;gap:1.2rem;}
.contact-item{
  display:flex;align-items:flex-start;gap:1rem;
  padding:1.4rem;background:#fff;
  border:var(--border);border-radius:var(--radius);
  border-left:4px solid var(--green);
  transition:all var(--T);
}
.contact-item:hover{box-shadow:var(--shadow-sm);border-left-color:var(--red);}
.contact-item-icon{
  width:42px;height:42px;border-radius:var(--radius-sm);
  background:var(--green-l);
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;flex-shrink:0;
}
.contact-item-label{font-size:9px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-l);margin-bottom:.3rem;}
.contact-item-val{font-size:.95rem;font-weight:700;color:var(--ink);}
.contact-item-val a{color:var(--green);}
.contact-item-val a:hover{color:var(--red);}

.contact-form{background:#fff;border:var(--border);border-radius:var(--radius);padding:2rem;}
.form-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:900;color:var(--ink);margin-bottom:1.5rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;}
.form-group{margin-bottom:1rem;}
.form-label{font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);margin-bottom:.4rem;display:block;}
.form-input,.form-textarea{
  width:100%;padding:11px 14px;
  border:var(--border);border-radius:var(--radius-sm);
  font-family:'DM Sans',sans-serif;font-size:.88rem;
  background:#fff;color:var(--ink);
  transition:border-color var(--T),box-shadow var(--T);outline:none;
}
.form-input:focus,.form-textarea:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,106,78,.1);}
.form-textarea{resize:vertical;min-height:110px;}
.btn-submit{
  width:100%;background:var(--green);color:#fff;
  padding:13px;font-size:12px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;
  border:none;border-radius:var(--radius-sm);
  transition:all var(--T);
}
.btn-submit:hover{background:var(--green-d);box-shadow:0 8px 20px rgba(0,106,78,.25);transform:translateY(-2px);}

/* ═══════════════════════════════════════════
   CTA BAND
═══════════════════════════════════════════ */
.cta-band{
  background:linear-gradient(135deg,var(--green) 0%,var(--green-d) 100%);
  padding:5rem 0;text-align:center;
  position:relative;overflow:hidden;
  border-top:3px solid var(--green-d);
}
.cta-band::before{
  content:'POLITICAL INSIGHTS BD';
  position:absolute;left:50%;top:50%;
  transform:translate(-50%,-50%);
  font-family:'Playfair Display',serif;font-size:8rem;font-weight:900;
  color:rgba(255,255,255,.04);white-space:nowrap;pointer-events:none;
}
/* BD circle emblem */
.cta-emblem{
  width:60px;height:60px;border-radius:50%;
  background:var(--red);margin:0 auto 1.5rem;
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;position:relative;z-index:1;
  box-shadow:0 0 0 8px rgba(244,42,65,.2);
}
.cta-title{
  font-family:'Playfair Display','Noto Serif Bengali',serif;
  font-size:clamp(1.8rem,3.5vw,3rem);font-weight:900;
  color:#fff;line-height:1.1;margin-bottom:.8rem;
  position:relative;z-index:1;
}
.cta-desc{
  font-family:'Noto Serif Bengali',sans-serif;
  font-size:.98rem;color:rgba(255,255,255,.75);
  margin-bottom:2rem;position:relative;z-index:1;
}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;position:relative;z-index:1;}
.btn-cta-w{
  background:#fff;color:var(--green);
  padding:13px 30px;font-size:11px;font-weight:900;
  letter-spacing:.12em;text-transform:uppercase;
  border-radius:var(--radius-sm);border:2px solid #fff;
  display:inline-flex;align-items:center;gap:7px;
  transition:all var(--T);
}
.btn-cta-w:hover{background:transparent;color:#fff;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2);}
.btn-cta-r{
  background:var(--red);color:#fff;
  padding:13px 30px;font-size:11px;font-weight:900;
  letter-spacing:.12em;text-transform:uppercase;
  border-radius:var(--radius-sm);border:2px solid var(--red);
  display:inline-flex;align-items:center;gap:7px;
  transition:all var(--T);
}
.btn-cta-r:hover{background:var(--red-d);transform:translateY(-2px);box-shadow:0 8px 24px rgba(244,42,65,.3);}

/* ═══════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════ */
footer{background:var(--ink-soft);border-top:3px solid var(--green);}
.ft-top{
  max-width:1360px;width:92%;margin:0 auto;
  display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;
  gap:0;padding:3rem 0;
  border-bottom:1px solid rgba(255,255,255,.07);
}
.ft-col{padding:0 2rem 0 0;}
.ft-col:first-child{padding-right:3rem;}
.ft-logo{height:46px;width:auto;filter:brightness(0) invert(1);margin-bottom:1.1rem;}
