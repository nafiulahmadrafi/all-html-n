/* ─── CARD RENDERER ─── */
function makeCard(post, badgeClass, badgeLabel) {
  const img = post.img || (post._embedded?.['wp:featuredmedia']?.[0]?.source_url) || 'https://images.unsplash.com/photo-1529107386315-e1a2ed48a620?w=400&q=60';
  const title = post.title?.rendered ? post.title.rendered : post.title;
  const excerpt = post.excerpt?.rendered
    ? post.excerpt.rendered.replace(/<[^>]*>/g,'').slice(0,120)+'…'
    : post.excerpt;
  const date = post.date ? new Date(post.date).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'}) : post.date;
  const link = post.link || post.link;
  return `
    <a href="${link}" class="post-card" target="_blank">
      <div class="post-card-img">
        <img src="${img}" alt="${title}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1529107386315-e1a2ed48a620?w=400&q=60'">
        <span class="post-type-badge ${badgeClass}">${badgeLabel}</span>
      </div>
      <div class="post-card-body">
        <div class="post-date">${date}</div>
        <h3 class="post-title">${title}</h3>
        <p class="post-excerpt">${excerpt}</p>
        <span class="post-readmore">Read More →</span>
      </div>
    </a>`;
}

function makeBookCard(book) {
  return `
    <a href="${book.link||'https://politicalinsightsbd.com/all-insights/'}" class="book-card" target="_blank">
      <div class="book-cover">
        <img src="${book.img}" alt="${book.title}" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=400&q=60'">
      </div>
      <div class="book-info">
        <div class="book-title">${book.title}</div>
        <div class="book-desc">${book.desc}</div>
      </div>
    </a>`;
}

/* ─── FETCH WP POSTS BY CATEGORY ─── */
async function fetchCategory(slug, limit) {
  try {
    const catRes = await fetch(`${WP}/categories?slug=${slug}&_fields=id`);
    if (!catRes.ok) throw new Error();
    const cats = await catRes.json();
    if (!cats.length) throw new Error('no cat');
    const catId = cats[0].id;
    const res = await fetch(`${WP}/posts?_embed&per_page=${limit}&categories=${catId}&_fields=id,title,excerpt,date,link,_embedded`);
    if (!res.ok) throw new Error();
    return await res.json();
  } catch(e) { return null; }
}

/* ─── FETCH & RENDER ALL SECTIONS ─── */
