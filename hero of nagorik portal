<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="theme-color" content="#0a4d2e" />
  <title>নাগরিক পোর্টাল — ময়মনসিংহ</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Bengali:wght@700;900&family=Noto+Sans+Bengali:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Noto Sans Bengali', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══════ HERO ═══════ */
    .hero {
      position: relative;
      width: 100%;
      height: 100dvh;
      min-height: 560px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      overflow: hidden;
    }

    /* Image */
    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center center;
      animation: kenburns 22s ease-in-out infinite alternate;
      will-change: transform;
    }
    @keyframes kenburns {
      from { transform: scale(1); }
      to   { transform: scale(1.07) translateX(-1%); }
    }

    /* Shadows */
    .overlay {
      position: absolute; inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.42) 0%,   transparent    18%),
        linear-gradient(0deg,   rgba(0,0,0,.90) 0%,   rgba(0,0,0,.58) 28%, transparent 64%),
        linear-gradient(90deg,  rgba(0,0,0,.24) 0%,   transparent    26%),
        linear-gradient(270deg, rgba(0,0,0,.24) 0%,   transparent    26%);
    }

    /* Top colour bar */
    .topbar {
      position: absolute; top: 0; left: 0; right: 0;
      height: 4px;
      background: linear-gradient(90deg, #0a4d2e, #22c55e 40%, #b91c1c 62%, #7f1d1d);
      z-index: 20;
    }

    /* Badge */
    .badge {
      position: absolute;
      top: clamp(14px, 4vw, 22px);
      left: clamp(14px, 4vw, 22px);
      z-index: 20;
      display: flex; align-items: center; gap: 8px;
      background: rgba(8,55,30,.9);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 40px;
      padding: 6px 14px;
      animation: slideDown .6s .1s both;
    }
    .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 8px #22c55e;
      animation: blink 2s infinite;
      flex-shrink: 0;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.15} }
    .badge-text {
      color: #d1fae5;
      font-size: clamp(.62rem, 2.8vw, .72rem);
      font-weight: 600;
      letter-spacing: .05em;
      white-space: nowrap;
    }

    /* Content block */
    .content {
      position: relative; z-index: 10;
      width: 100%;
      padding: 0 clamp(20px, 6vw, 52px) clamp(38px, 9vh, 58px);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(9px, 2vw, 14px);
      text-align: center;
      animation: slideUp .85s .3s both;
    }

    /* eyebrow */
    .eyebrow {
      display: flex; align-items: center; gap: 8px;
      color: rgba(255,255,255,.48);
      font-size: clamp(.6rem, 2.4vw, .68rem);
      font-weight: 500;
      letter-spacing: .16em;
      text-transform: uppercase;
    }
    .eyebrow::before, .eyebrow::after {
      content: ''; width: 28px; height: 1px;
      background: rgba(255,255,255,.28);
    }

    /* Title — Noto Serif Bengali renders ময়মনসিংহ perfectly */
    .title {
      font-family: 'Noto Serif Bengali', serif;
      font-weight: 900;
      font-size: clamp(1.95rem, 7.5vw, 3.8rem);
      line-height: 1.28;
      color: #fff;
      text-shadow:
        0 1px 0   rgba(0,0,0,.8),
        0 3px 12px rgba(0,0,0,.7),
        0 10px 38px rgba(0,0,0,.5);
    }

    /* EN subtitle */
    .subtitle {
      font-size: clamp(.62rem, 2.5vw, .76rem);
      font-weight: 400;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: rgba(255,255,255,.42);
      margin-top: -3px;
    }

    /* Divider */
    .divider {
      width: 50px; height: 2px;
      background: linear-gradient(90deg, #22c55e, #ef4444);
      border-radius: 2px;
    }

    /* Tagline */
    .tagline {
      font-size: clamp(.78rem, 3vw, .9rem);
      font-weight: 400;
      color: rgba(255,255,255,.62);
      line-height: 1.75;
      max-width: 400px;
    }
    .tagline strong { color: #86efac; font-weight: 700; }

    /* Buttons — side by side always */
    .btns {
      display: flex;
      flex-direction: row;
      gap: clamp(8px, 2.5vw, 12px);
      width: 100%;
      max-width: 400px;
      margin-top: clamp(4px, 1.5vw, 8px);
    }

    .btn {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: clamp(.75rem, 3vw, .9rem) clamp(.6rem, 3vw, 1.4rem);
      border-radius: 9px;
      font-family: 'Noto Sans Bengali', sans-serif;
      font-size: clamp(.82rem, 3.2vw, .95rem);
      font-weight: 700;
      text-decoration: none;
      border: none; cursor: pointer;
      position: relative; overflow: hidden;
      -webkit-appearance: none;
      white-space: nowrap;
      transition: transform .18s, box-shadow .18s;
    }
    .btn::after {
      content: ''; position: absolute; inset: 0;
      background: rgba(255,255,255,0);
      transition: background .2s;
    }
    .btn:hover::after  { background: rgba(255,255,255,.1); }
    .btn:active { transform: scale(.97) !important; }

    .btn-green {
      background: linear-gradient(140deg, #166534, #0a4d2e);
      color: #fff;
      box-shadow: 0 4px 20px rgba(22,101,52,.7), inset 0 1px 0 rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.13);
    }
    .btn-red {
      background: linear-gradient(140deg, #b91c1c, #7f1d1d);
      color: #fff;
      box-shadow: 0 4px 20px rgba(185,28,28,.7), inset 0 1px 0 rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.13);
    }

    /* PIBBD credit */
    .credit {
      position: absolute;
      bottom: clamp(8px, 2.5vw, 14px);
      right: clamp(14px, 4vw, 20px);
      z-index: 10;
      font-size: clamp(.56rem, 1.8vw, .63rem);
      color: rgba(255,255,255,.3);
      letter-spacing: .1em;
    }

    /* Animations */
    @keyframes slideUp   { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
    @keyframes slideDown { from { opacity:0; transform:translateY(-16px); } to { opacity:1; transform:translateY(0); } }

    /* ── Very small phones (iPhone SE etc) ── */
    @media (max-width: 360px) {
      .title    { font-size: 1.78rem; }
      .btns     { max-width: 300px; }
      .btn      { font-size: .8rem; padding: .72rem .5rem; }
      .tagline  { font-size: .74rem; }
    }

    /* ── Landscape phone ── */
    @media (max-height: 480px) and (orientation: landscape) {
      .content  { padding-bottom: 16px; gap: 6px; }
      .title    { font-size: clamp(1.3rem, 5vw, 1.9rem); }
      .tagline, .divider, .eyebrow { display: none; }
      .btns     { margin-top: 4px; }
    }
  </style>
</head>
<body>

<section class="hero">

  <img
    class="hero-img"
    src="https://mymensingh-sadar.bdnagoriksheba.com/wp-content/uploads/2026/02/0a653638-6fa5-452b-93ca-4e7a4f8a11e3_rw_1200.jpg"
    alt="ময়মনসিংহ সদর নাগরিক পোর্টাল"
    loading="eager"
    fetchpriority="high"
  />

  <div class="overlay"></div>
  <div class="topbar"></div>

  <div class="badge">
    <span class="dot"></span>
    <span class="badge-text">নাগরিক পোর্টাল · ময়মনসিংহ সদর</span>
  </div>

  <div class="content">

    <div class="eyebrow">নাগরিক অধিকার ও সুশাসন</div>

    <h1 class="title">ময়মনসিংহ সদর<br>নাগরিক পোর্টাল</h1>

    <p class="subtitle">Mymensingh Sadar · Nagorik Portal</p>

    <div class="divider"></div>

    <p class="tagline">
      নাগরিক অধিকার ও সুশাসন জবাবদিহিতা প্ল্যাটফর্ম<br>
      <strong>পরিচালনায়: PIBBD</strong>
    </p>

    <div class="btns">
      <a href="https://mymensingh-sadar.bdnagoriksheba.com/about/"
         class="btn btn-green" target="_blank" rel="noopener">
        ℹ️ আমাদের সম্পর্কে
      </a>
      <a href="https://mymensingh-sadar.bdnagoriksheba.com/services/"
         class="btn btn-red" target="_blank" rel="noopener">
        📋 সেবা দেখুন
      </a>
    </div>

  </div>

  <span class="credit">© PIBBD · Governance Accountability Platform</span>

</section>

</body>
</html>
