<script>
  function showPanel(id, btn) {
    document.querySelectorAll('.cat-panel').forEach(p => p.classList.remove('visible'));
    document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(id).classList.add('visible');
    btn.classList.add('active');
    window.scrollTo({ top: btn.closest('.category-tabs').offsetTop - 20, behavior: 'smooth' });
  }

  function scrollToForm(cat) {
    const sel = document.getElementById('f-category');
    for (let o of sel.options) {
      if (o.value === cat || o.text === cat) { sel.value = o.value; break; }
    }
    document.getElementById('inquiry-anchor').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function submitForm() {
    const name = document.getElementById('f-name').value.trim();
    const phone = document.getElementById('f-phone').value.trim();
    const cat = document.getElementById('f-category').value;
    const msg = document.getElementById('f-message').value.trim();
    if (!name || !phone || !cat || !msg) {
      alert('অনুগ্রহ করে নাম, মোবাইল নম্বর, সেবার ক্যাটাগরি ও বিস্তারিত চাহিদা পূরণ করুন।');
      return;
    }
    const ok = document.getElementById('inbox-success');
    ok.style.display = 'block';
    ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
    ['f-name','f-phone','f-email','f-org','f-message'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('f-category').value = '';
    document.getElementById('f-elec').value = '';
  }
</script>

