.pm-min-item{display:flex;align-items:center;gap:10px;font-size:13px;color:rgba(255,255,255,.8)}
.pm-min-item::before{content:'';width:6px;height:6px;background:var(--gold);flex-shrink:0;clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%)}
.pm-meta{margin-top:18px;padding-top:14px;border-top:1px solid rgba(255,255,255,.1);display:flex;gap:20px;flex-wrap:wrap}
.pm-meta-item{font-size:10px;font-family:var(--mono);color:rgba(255,255,255,.4)}
.pm-meta-item span{color:var(--gold-light);display:block;font-size:11px;margin-top:1px}
.ministers-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:14px}
.ministers-grid.list-view{grid-template-columns:1fr}
