  document.getElementById('pmSection').innerHTML = `
    <div class="pm-card" onclick="showPersonJSON(-1)">
      <div class="pm-avatar">🏛️</div>
      <div class="pm-info">
        <div class="pm-badge">ক্রম: ০১ · প্রধানমন্ত্রী · PRIME MINISTER</div>
        <div class="pm-name">${pm.name_bn}</div>
        <div class="pm-title-en">${pm.name_en}</div>
        <div class="pm-min-list">${minsHtml}</div>
        <div class="pm-meta">
          <div class="pm-meta-item">নিয়োগের তারিখ<span>${pm.appointment_date}</span></div>
          <div class="pm-meta-item">মোট মন্ত্রণালয়<span>${pm.ministries.length}টি</span></div>
          <div class="pm-meta-item">পদবি<span>${pm.designation_en}</span></div>
          <div class="pm-meta-item" style="margin-left:auto;cursor:pointer;color:rgba(201,168,76,.6);font-size:9px;letter-spacing:1px">📋 JSON দেখুন</div>
        </div>
      </div>
    </div>`;
}

function renderMinisters(filtered) {
  const grid = document.getElementById('ministersGrid');
  const data = filtered || CABINET.ministers;
  if(!data.length){
    grid.innerHTML = '<div class="no-results"><span>🔍</span>কোনো ফলাফল পাওয়া যায়নি</div>';
    document.getElementById('resultCount').textContent = '০ জন মন্ত্রী';
    return;
  }
  grid.innerHTML = data.map((m,i) => {
    const av = AVATARS[i % AVATARS.length];
    const minTags = m.ministries.map(mn => `<span class="min-tag">${mn.name_bn}</span>`).join('');
    const isNew = m.appointment_date !== '2026-02-17';
    return `
    <div class="minister-card" onclick="showPersonJSON(${m.sl-1})" style="animation-delay:${i*0.04}s">
      ${isNew ? `<div style="position:absolute;top:8px;right:8px;background:var(--crimson);color:#fff;font-family:var(--mono);font-size:8px;padding:2px 6px;letter-spacing:1px;z-index:2">NEW</div>` : ''}
      <div class="card-top">
        <div class="card-avatar">
          <span>${av}</span>
          <div class="card-num">${String(m.sl).padStart(2,'0')}</div>
        </div>
        <div class="card-header">
          <div class="card-badge">${m.designation_bn} · ${m.designation_en}</div>
          <div class="card-name">${m.name_bn}</div>
          <div style="font-size:10px;color:var(--muted);font-family:var(--mono);margin-bottom:4px">${m.name_en}</div>
          <div class="card-date">📅 ${m.appointment_date}</div>
        </div>
      </div>
      <div class="card-ministries">
        <div class="min-count-label">মন্ত্রণালয় (${m.ministries.length}টি)</div>
        ${minTags}
      </div>
    </div>`;
  }).join('');
  document.getElementById('resultCount').textContent = `${data.length} জন মন্ত্রী দেখাচ্ছে`;
}

function filterCards() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  let data = CABINET.ministers;
  if(currentFilter === 'multi') data = data.filter(m => m.ministries.length > 1);
  if(currentFilter === 'single') data = data.filter(m => m.ministries.length === 1);
  if(q) data = data.filter(m =>
    m.name_bn.toLowerCase().includes(q) ||
    m.name_en.toLowerCase().includes(q) ||
    m.ministries.some(mn => mn.name_bn.toLowerCase().includes(q) || mn.name_en.toLowerCase().includes(q))
  );
  renderMinisters(data);
}

function filterBy(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentFilter = type;
  document.getElementById('searchInput').value = '';
  renderMinisters(type === 'multi' ? CABINET.ministers.filter(m=>m.ministries.length>1) : type === 'single' ? CABINET.ministers.filter(m=>m.ministries.length===1) : null);
}

function setView(v) {
  currentView = v;
  document.getElementById('ministersGrid').classList.toggle('list-view', v === 'list');
  document.getElementById('gridBtn').classList.toggle('active', v === 'grid');
  document.getElementById('listBtn').classList.toggle('active', v === 'list');
}

function syntaxHighlight(json) {
  json = json.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, match => {
    let cls = 'jn';
    if(/^"/.test(match)) cls = /:$/.test(match) ? 'jk' : 'js';
    else if(/true|false/.test(match)) cls = 'jb';
    else if(/null/.test(match)) cls = 'jp';
    return `<span class="${cls}">${match}</span>`;
  });
}

function showPersonJSON(idx) {
  const person = idx === -1 ? CABINET.prime_minister : CABINET.ministers[idx];
  const jsonStr = JSON.stringify(person, null, 2);
  currentJSON = jsonStr;
  document.getElementById('modalTitle').textContent = `JSON · ${person.name_en} · ${person.designation_en}`;
  document.getElementById('jsonOutput').innerHTML = syntaxHighlight(jsonStr);
  document.getElementById('modalOverlay').classList.add('open');
}

function showFullJSON() {
  const jsonStr = JSON.stringify(CABINET, null, 2);
  currentJSON = jsonStr;
  document.getElementById('modalTitle').textContent = `FULL CABINET JSON · ${CABINET.meta.total_members} MEMBERS · v${CABINET.meta.version}`;
  document.getElementById('jsonOutput').innerHTML = syntaxHighlight(jsonStr);
  document.getElementById('modalOverlay').classList.add('open');
}

function copyJSON() {
  navigator.clipboard.writeText(currentJSON).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.textContent = '✓ COPIED!';
    setTimeout(() => btn.textContent = '📋 COPY JSON', 2000);
  });
}

function closeModal(e) {
  if(e.target === document.getElementById('modalOverlay'))
    document.getElementById('modalOverlay').classList.remove('open');
}

function downloadJSON() {
  const blob = new Blob([JSON.stringify(CABINET, null, 2)], {type:'application/json'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'bangladesh_cabinet_2026.json'; a.click();
}

function downloadCSV() {
  const rows = [['ক্রম','নাম (বাংলা)','নাম (English)','পদবি','নিয়োগের তারিখ','মন্ত্রণালয়','Ministry (EN)']];
  // PM
  CABINET.prime_minister.ministries.forEach((m,i) => {
    rows.push([i===0?'1':'', i===0?CABINET.prime_minister.name_bn:'', i===0?CABINET.prime_minister.name_en:'', i===0?CABINET.prime_minister.designation_bn:'', i===0?CABINET.prime_minister.appointment_date:'', m.name_bn, m.name_en]);
  });
  // Ministers
  CABINET.ministers.forEach(minister => {
    minister.ministries.forEach((m,i) => {
      rows.push([i===0?minister.sl:'', i===0?minister.name_bn:'', i===0?minister.name_en:'', i===0?minister.designation_bn:'', i===0?minister.appointment_date:'', m.name_bn, m.name_en]);
    });
  });
  const csv = rows.map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'bangladesh_cabinet_2026.csv'; a.click();
}

// Count total ministries
function countTotalMinistries() {
  const pmCount = CABINET.prime_minister.ministries.length;
  const minCount = CABINET.ministers.reduce((s,m) => s + m.ministries.length, 0);
  document.getElementById('totalMinistries').textContent = (pmCount + minCount).toString();
}

