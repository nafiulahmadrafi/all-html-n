.pm-info{padding:28px 32px;flex:1}
.pm-badge{display:inline-block;background:var(--gold);color:var(--dark);font-family:var(--mono);font-size:9px;font-weight:700;padding:3px 10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
.pm-name{font-family:var(--display);font-size:30px;font-weight:900;color:var(--gold-light);line-height:1.15;margin-bottom:4px}
.pm-title-en{font-size:13px;color:rgba(255,255,255,.55);margin-bottom:16px;font-family:var(--mono)}
