.hero-title{font-family:var(--display);font-size:clamp(22px,4vw,44px);color:var(--gold-light);letter-spacing:1px;line-height:1.2;margin-bottom:6px;text-shadow:0 2px 12px rgba(0,0,0,.3)}
.hero-subtitle{font-size:12px;color:rgba(255,255,255,.55);letter-spacing:3px;text-transform:uppercase;font-family:var(--mono);margin-bottom:20px}
.hero-stats{display:inline-flex;border:1px solid rgba(201,168,76,.3)}
.hero-stat{padding:12px 24px;border-right:1px solid rgba(201,168,76,.3);text-align:center}
