.card-top{display:flex}
.card-avatar{width:88px;height:88px;flex-shrink:0;background:linear-gradient(135deg,#e8f5f0,#d4ebe2);display:flex;align-items:center;justify-content:center;font-size:34px;border-right:1px solid var(--border);position:relative;overflow:hidden}
.card-num{position:absolute;bottom:4px;right:4px;font-family:var(--mono);font-size:9px;font-weight:700;color:var(--emerald);background:rgba(255,255,255,.9);padding:1px 5px}
.card-header{padding:13px 15px;flex:1}
.card-name{font-size:14px;font-weight:700;color:var(--text);line-height:1.35;margin-bottom:4px}
.card-badge{display:inline-block;background:var(--emerald);color:#fff;font-family:var(--mono);font-size:9px;letter-spacing:1px;padding:2px 7px;margin-bottom:6px}
.card-date{font-family:var(--mono);font-size:10px;color:var(--muted);display:flex;align-items:center;gap:4px}
.card-ministries{padding:10px 14px 13px;border-top:1px solid var(--border);background:rgba(0,106,78,.025)}
.min-count-label{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.min-tag{display:inline-flex;align-items:center;gap:4px;background:rgba(0,106,78,.07);border:1px solid rgba(0,106,78,.15);color:var(--emerald);font-size:11px;padding:4px 8px;margin:2px;line-height:1.35}
.min-tag::before{content:'▸';font-size:8px;color:var(--gold)}
.ministers-grid.list-view .minister-card{display:flex;align-items:stretch}
.ministers-grid.list-view .card-top{flex-shrink:0;border-right:1px solid var(--border)}
.ministers-grid.list-view .card-ministries{flex:1;border-top:none;display:flex;align-items:center;flex-wrap:wrap;align-content:center;padding:10px 14px}
.export-bar{margin:0 40px 22px;background:var(--dark);border:1px solid rgba(201,168,76,.3);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.export-text{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.4)}
.export-text strong{color:var(--gold)}
.export-btns{display:flex;gap:8px}
.export-btn{background:transparent;border:1px solid rgba(201,168,76,.4);color:var(--gold);padding:6px 14px;cursor:pointer;font-family:var(--mono);font-size:10px;letter-spacing:1px;text-transform:uppercase;transition:all .2s}
.export-btn:hover{background:var(--gold);color:var(--dark)}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;backdrop-filter:blur(5px);align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--dark);border:1px solid var(--gold);width:90%;max-width:680px;max-height:82vh;overflow:hidden;display:flex;flex-direction:column;animation:modalIn .3s ease}
@keyframes modalIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid rgba(201,168,76,.3);background:rgba(201,168,76,.05)}
.modal-title{font-family:var(--mono);font-size:11px;color:var(--gold);letter-spacing:2px}
.modal-close{background:none;border:1px solid rgba(201,168,76,.3);color:var(--gold);cursor:pointer;padding:3px 10px;font-size:16px;transition:all .2s}
.modal-close:hover{background:var(--gold);color:var(--dark)}
.modal-body{overflow-y:auto;padding:18px;flex:1}
.json-out{font-family:var(--mono);font-size:12px;line-height:1.9;white-space:pre;overflow-x:auto}
.jk{color:#f0d078}.js{color:#98c98a}.jn{color:#79c0ff}.jb{color:#ff7b72}.jp{color:#c9a84c}
.modal-footer{padding:12px 18px;border-top:1px solid rgba(201,168,76,.3);display:flex;gap:10px}
.copy-btn{background:var(--gold);color:var(--dark);border:none;padding:8px 18px;cursor:pointer;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:1px;transition:opacity .2s}
.copy-btn:hover{opacity:.85}
.no-results{text-align:center;padding:50px 20px;color:var(--muted);font-family:var(--mono);font-size:13px;grid-column:1/-1}
.no-results span{font-size:36px;display:block;margin-bottom:10px}
footer{background:var(--dark);padding:22px 40px;text-align:center;margin-top:40px;border-top:2px solid var(--gold)}
.footer-text{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;line-height:1.8}
.footer-text strong{color:var(--gold)}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--gold)}
@media(max-width:768px){.hero-content,.container{padding-left:16px;padding-right:16px}.controls{padding:10px 16px}.pm-card{flex-direction:column}.pm-avatar{width:100%;min-height:100px}.ministers-grid{grid-template-columns:1fr}.export-bar{margin:0 16px 18px}}
</style>
</head>
