<style>
:root{--emerald:#006a4e;--crimson:#f42a41;--gold:#c9a84c;--gold-light:#f0d078;--bg:#f8f5ef;--bg2:#ffffff;--dark:#0f1b14;--text:#1a2e20;--muted:#7a8c7e;--border:#d9d0be;--shadow:rgba(0,106,78,0.12);--serif:'Noto Serif Bengali',serif;--display:'Playfair Display',serif;--mono:'JetBrains Mono',monospace}
