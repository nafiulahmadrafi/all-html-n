.controls{position:sticky;top:0;z-index:100;background:var(--dark);padding:12px 40px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;border-bottom:2px solid var(--gold);box-shadow:0 4px 20px rgba(0,0,0,.2)}
.search-wrap{flex:1;min-width:180px;max-width:360px;position:relative}
.search-input{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(201,168,76,.3);color:#fff;padding:9px 14px 9px 36px;font-family:var(--serif);font-size:13px;outline:none;transition:border-color .2s}
.search-input::placeholder{color:rgba(255,255,255,.3)}
.search-input:focus{border-color:var(--gold)}
.s-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--gold);font-size:12px}
.filter-btn{background:transparent;border:1px solid rgba(201,168,76,.3);color:rgba(255,255,255,.6);padding:7px 14px;font-family:var(--mono);font-size:10px;cursor:pointer;transition:all .2s;text-transform:uppercase;letter-spacing:1px}
.filter-btn:hover,.filter-btn.active{background:var(--gold);color:var(--dark);border-color:var(--gold)}
.view-toggle{display:flex;gap:4px;margin-left:auto}
.view-btn{background:transparent;border:1px solid rgba(201,168,76,.3);color:rgba(255,255,255,.5);padding:7px 11px;cursor:pointer;transition:all .2s;font-size:13px}
.view-btn.active{background:var(--gold);color:var(--dark);border-color:var(--gold)}
.result-count{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.35);white-space:nowrap}
.container{padding:28px 40px;position:relative;z-index:1}
.section-header{display:flex;align-items:center;gap:14px;margin-bottom:18px}
.section-header .line{flex:1;height:1px;background:linear-gradient(to right,var(--gold),transparent)}
.section-header .line.rev{background:linear-gradient(to left,var(--gold),transparent)}
.section-label{font-family:var(--mono);font-size:10px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;white-space:nowrap;padding:4px 12px;border:1px solid var(--gold);background:rgba(201,168,76,.05)}
