<script>
'use strict';

let currentStep = 1;
const TOTAL_STEPS = 4;

/* ── DISTRICT DATA ── */
const DISTRICTS = {
  dhaka: ['ঢাকা','গাজীপুর','নারায়ণগঞ্জ','টাঙ্গাইল','মানিকগঞ্জ','মুন্সিগঞ্জ','নরসিংদী','ফরিদপুর','গোপালগঞ্জ','মাদারীপুর'],
  chattogram: ['চট্টগ্রাম','কক্সবাজার','কুমিল্লা','ফেনী','নোয়াখালী','লক্ষ্মীপুর','চাঁদপুর','ব্রাহ্মণবাড়িয়া','রাঙামাটি','খাগড়াছড়ি','বান্দরবান'],
  rajshahi: ['রাজশাহী','নাটোর','নওগাঁ','চাঁপাইনবাবগঞ্জ','পাবনা','সিরাজগঞ্জ','বগুড়া','জয়পুরহাট'],
  khulna: ['খুলনা','বাগেরহাট','সাতক্ষীরা','যশোর','নড়াইল','মাগুরা','ঝিনাইদহ','কুষ্টিয়া','মেহেরপুর','চুয়াডাঙ্গা'],
  barisal: ['বরিশাল','পিরোজপুর','ভোলা','ঝালকাঠি','পটুয়াখালী','বরগুনা'],
  sylhet: ['সিলেট','মৌলভীবাজার','হবিগঞ্জ','সুনামগঞ্জ'],
  rangpur: ['রংপুর','দিনাজপুর','কুড়িগ্রাম','গাইবান্ধা','লালমনিরহাট','নীলফামারী','পঞ্চগড়','ঠাকুরগাঁও'],
  mymensingh: ['ময়মনসিংহ','নেত্রকোণা','জামালপুর','শেরপুর']
};

function populateDistricts(division) {
  const sel = document.getElementById('district');
  sel.innerHTML = '<option value="">জেলা বেছে নিন</option>';
  if (!division || !DISTRICTS[division]) return;
  DISTRICTS[division].forEach(d => {
    const opt = document.createElement('option');
    opt.value = d; opt.textContent = d;
    sel.appendChild(opt);
  });
}

/* ── STEP NAVIGATION ── */
function goToStep(step) {
  if (step > currentStep) return; // only go back via click
  currentStep = step;
  updateUI();
}

function nextStep(from) {
  if (!validateStep(from)) return;
  currentStep = from + 1;
  updateUI();
  document.querySelector('.np-register-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function prevStep(from) {
  currentStep = from - 1;
  updateUI();
  document.querySelector('.np-register-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function updateUI() {
  // Panels
  document.querySelectorAll('.np-panel').forEach((p, i) => {
    p.classList.toggle('active', i + 1 === currentStep);
  });
  // Step dots
  document.querySelectorAll('.np-step').forEach((s, i) => {
    const stepNum = i + 1;
    s.classList.remove('active', 'done');
    if (stepNum === currentStep) s.classList.add('active');
    else if (stepNum < currentStep) s.classList.add('done');
  });
  // Dots show checkmark for done
  document.querySelectorAll('.np-step.done .np-step-dot').forEach(d => {
    d.textContent = '✓';
  });
  const nums = ['১','২','৩','৪'];
  document.querySelectorAll('.np-step').forEach((s, i) => {
    if (!s.classList.contains('done')) s.querySelector('.np-step-dot').textContent = nums[i];
  });
}

/* ── VALIDATION ── */
function validateStep(step) {
  const errEl = document.getElementById('err-' + step);
  errEl.textContent = '';

  if (step === 1) {
    const nameBn = document.getElementById('nameBn').value.trim();
    const nameEn = document.getElementById('nameEn').value.trim();
    const email = document.getElementById('email').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const dob = document.getElementById('dob').value;
    const gender = document.getElementById('gender').value;

    if (!nameBn) { errEl.textContent = 'বাংলায় নাম লিখুন'; return false; }
    if (!nameEn) { errEl.textContent = 'ইংরেজিতে নাম লিখুন'; return false; }
    if (!email || !email.includes('@')) { errEl.textContent = 'সঠিক ইমেইল ঠিকানা দিন'; return false; }
    if (!phone || phone.length !== 11) { errEl.textContent = '১১ ডিজিটের মোবাইল নম্বর দিন'; return false; }
    if (!dob) { errEl.textContent = 'জন্ম তারিখ দিন'; return false; }
    if (!gender) { errEl.textContent = 'লিঙ্গ বেছে নিন'; return false; }
    return true;
  }

  if (step === 2) {
    const division = document.getElementById('division').value;
    const district = document.getElementById('district').value;
    const upazila = document.getElementById('upazila').value.trim();
    if (!division) { errEl.textContent = 'বিভাগ বেছে নিন'; return false; }
    if (!district) { errEl.textContent = 'জেলা বেছে নিন'; return false; }
    if (!upazila) { errEl.textContent = 'উপজেলার নাম লিখুন'; return false; }
    return true;
  }

  if (step === 3) {
    const occ = document.getElementById('occupation').value;
    if (!occ) { errEl.textContent = 'পেশা বেছে নিন'; return false; }
    return true;
  }

  return true;
}

/* ── SUBMIT ── */
function submitForm() {
  const errEl = document.getElementById('err-4');
  errEl.textContent = '';

  const pw = document.getElementById('password').value;
  const cpw = document.getElementById('confirmPassword').value;
  const terms = document.getElementById('terms').checked;

  if (pw.length < 8) { errEl.textContent = 'পাসওয়ার্ড কমপক্ষে ৮ অক্ষরের হতে হবে'; return; }
  if (pw !== cpw) { errEl.textContent = 'পাসওয়ার্ড দুটো মিলছে না'; return; }
  if (!terms) { errEl.textContent = 'শর্তাবলীতে সম্মত হতে হবে'; return; }

  // Show success
  const email = document.getElementById('email').value;
  document.getElementById('formBody').style.display = 'none';
  document.getElementById('formFooter').style.display = 'none';
  document.getElementById('successEmail').textContent = email;
  document.getElementById('successState').style.display = 'flex';
  document.querySelector('.np-steps').style.display = 'none';
}

function resetForm() {
  document.getElementById('formBody').style.display = 'block';
  document.getElementById('formFooter').style.display = 'block';
  document.getElementById('successState').style.display = 'none';
  document.querySelector('.np-steps').style.display = 'flex';
  currentStep = 1;
  updateUI();
  // reset form fields
  document.querySelectorAll('input:not([type="radio"]):not([type="checkbox"]), select, textarea').forEach(el => el.value = '');
  document.getElementById('avatarPreview').innerHTML = '🙂';
  document.getElementById('strengthFill').style.width = '0%';
  document.getElementById('strengthText').textContent = '';
}

/* ── PASSWORD STRENGTH ── */
function checkStrength(val) {
  const fill = document.getElementById('strengthFill');
  const text = document.getElementById('strengthText');
  if (!val) { fill.style.width = '0%'; text.textContent = ''; return; }

  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;

  const levels = [
    { w:'20%', c:'#ef4444', t:'দুর্বল' },
    { w:'45%', c:'#f59e0b', t:'মোটামুটি' },
    { w:'70%', c:'#3b82f6', t:'ভালো' },
    { w:'100%', c:'#22c55e', t:'শক্তিশালী ✓' },
  ];
  const l = levels[Math.min(score - 1, 3)] || levels[0];
  fill.style.width = l.w;
  fill.style.background = l.c;
  text.textContent = l.t;
  text.style.color = l.c;
}

/* ── TOGGLE PASSWORD ── */
function togglePw(id, btn) {
  const inp = document.getElementById(id);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  btn.textContent = inp.type === 'password' ? '👁' : '🙈';
}

/* ── AVATAR PREVIEW ── */
function previewAvatar(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      const preview = document.getElementById('avatarPreview');
      preview.innerHTML = `<img src="${e.target.result}" alt="avatar">`;
    };
    reader.readAsDataURL(input.files[0]);
  }
}

/* ── SAME ADDRESS ── */
function toggleSameAddress(cb) {
  document.getElementById('permanentAddr').style.opacity = cb.checked ? '0.4' : '1';
  document.getElementById('permanentAddr').style.pointerEvents = cb.checked ? 'none' : 'auto';
}

/* ── INIT ── */
document.getElementById('dob').max = new Date().toISOString().split('T')[0];
</script>
