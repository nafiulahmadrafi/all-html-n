/* Search/filter pages */
function filterPages(query) {
  const q = query.toLowerCase().trim();
  const cards = document.querySelectorAll('.page-card');
  let visible = 0;

  cards.forEach(card => {
    const match = !q || card.dataset.title.includes(q) || card.dataset.slug.includes(q);
    card.classList.toggle('hidden', !match);
    if (match) visible++;
  });

  document.getElementById('noResults').classList.toggle('show', visible === 0 && q !== '');
}

