/* ══════════════════════════════════════════════
   NOTICE — WordPress posts থেকে auto fetch
   ══════════════════════════════════════════════
   কীভাবে কাজ করে:
   1. WordPress এ "notice" category তে post করুন
   2. অথবা যেকোনো post → এখানে দেখাবে
   3. Category slug: "notice" হলে সেটাকে priority দেওয়া হয়
   ══════════════════════════════════════════════ */

let noticeLoaded = false;
let readNotices = JSON.parse(localStorage.getItem('nb_read_notices') || '[]');

function timeAgo(dateStr) {
  const now = new Date();
  const d = new Date(dateStr);
  const diff = Math.floor((now - d) / 1000);
  if (diff < 60) return 'এইমাত্র';
  if (diff < 3600) return `${Math.floor(diff/60)} মিনিট আগে`;
  if (diff < 86400) return `${Math.floor(diff/3600)} ঘণ্টা আগে`;
  if (diff < 604800) return `${Math.floor(diff/86400)} দিন আগে`;
  return d.toLocaleDateString('bn-BD');
}

function stripHtml(html) {
  const tmp = document.createElement('div');
  tmp.innerHTML = html;
  return tmp.textContent || tmp.innerText || '';
}

async function fetchNotices() {
  try {
    /* Strategy:
       1. First try to get posts from "notice" category slug
       2. If no such category, fall back to latest 10 posts
    */

    // Step 1: find "notice" category id
    let catId = null;
    try {
      const catRes = await fetch(
        `${WP_SITE_URL}/wp-json/wp/v2/categories?slug=notice&_fields=id`,
        { headers: { 'Accept': 'application/json' } }
      );
      if (catRes.ok) {
        const cats = await catRes.json();
        if (cats.length > 0) catId = cats[0].id;
      }
    } catch(e) {}

    // Also try "notish" slug
    if (!catId) {
      try {
        const catRes = await fetch(
          `${WP_SITE_URL}/wp-json/wp/v2/categories?slug=notish&_fields=id`,
          { headers: { 'Accept': 'application/json' } }
        );
        if (catRes.ok) {
          const cats = await catRes.json();
          if (cats.length > 0) catId = cats[0].id;
        }
      } catch(e) {}
    }

    // Step 2: fetch posts
    const catParam = catId ? `&categories=${catId}` : '';
    const res = await fetch(
      `${WP_SITE_URL}/wp-json/wp/v2/posts?per_page=15&status=publish${catParam}&_fields=id,title,link,date,excerpt,categories,_links`,
      { headers: { 'Accept': 'application/json' } }
    );

    if (!res.ok) return null;
    return await res.json();
  } catch(e) {
    return null;
  }
}

function renderNotices(posts) {
  const list = document.getElementById('noticeList');
  const skels = document.getElementById('noticeSkeletons');
  const empty = document.getElementById('noticeEmpty');
  const viewAll = document.getElementById('noticeViewAll');

  skels.style.display = 'none';
  list.innerHTML = '';

  if (!posts || posts.length === 0) {
    renderFallbackNotices();
    return;
  }

  let unreadCount = 0;

  posts.forEach(post => {
    const id = post.id;
    const title = post.title?.rendered || post.title || 'নোটিশ';
    const url = post.link || '#';
    const date = post.date;
    const excerpt = stripHtml(post.excerpt?.rendered || '').trim().slice(0, 100);
    const isRead = readNotices.includes(id);
    const isNew = (new Date() - new Date(date)) < 7 * 24 * 60 * 60 * 1000; // 7 days

    if (!isRead) unreadCount++;

    const item = document.createElement('a');
    item.href = url;
    item.className = 'notice-item';
    item.onclick = () => markRead(id);
    item.innerHTML = `
      <div class="notice-dot-wrap">
        <div class="notice-dot ${isRead ? 'read' : 'unread'}"></div>
      </div>
      <div class="notice-body">
        <div class="notice-title ${!isRead ? 'unread-title' : ''}">${title}</div>
        ${excerpt ? `<div class="notice-excerpt">${excerpt}...</div>` : ''}
        <div class="notice-meta">
          <span class="notice-date">🕐 ${timeAgo(date)}</span>
          <span class="notice-cat">নোটিশ</span>
          ${isNew && !isRead ? '<span class="notice-new-badge">নতুন</span>' : ''}
        </div>
      </div>
    `;
    list.appendChild(item);
  });

  // update badge count
  updateNoticeBadge(unreadCount);
  viewAll.style.display = 'flex';
  empty.style.display = 'none';
}

function renderFallbackNotices() {
  const list = document.getElementById('noticeList');
  const empty = document.getElementById('noticeEmpty');
  list.innerHTML = '';
  empty.style.display = 'block';
  updateNoticeBadge(0);
}

function markRead(id) {
  if (!readNotices.includes(id)) {
    readNotices.push(id);
    localStorage.setItem('nb_read_notices', JSON.stringify(readNotices));
  }
  // recount unread
  const dots = document.querySelectorAll('.notice-dot.unread');
  updateNoticeBadge(dots.length - 1);
}

function updateNoticeBadge(count) {
  const badge = document.getElementById('noticeBadge');
  const newBadge = document.getElementById('noticeNewBadge');
  if (count > 0) {
    badge.textContent = count > 9 ? '৯+' : count;
    badge.style.display = 'flex';
    if (newBadge) newBadge.style.display = 'inline-block';
  } else {
    badge.style.display = 'none';
    if (newBadge) newBadge.style.display = 'none';
  }
}

async function openNotice(e) {
  e.preventDefault();
  const overlay = document.getElementById('noticeOverlay');
  overlay.classList.add('open');

  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  document.getElementById('n-notice').classList.add('active');

  if (!noticeLoaded) {
    noticeLoaded = true;
    const posts = await fetchNotices();
    renderNotices(posts);
  }
}

function closeNotice() {
  document.getElementById('noticeOverlay').classList.remove('open');
  const nNotice = document.getElementById('n-notice');
  if (nNotice) nNotice.classList.remove('active');
}

// Auto-fetch notices on page load silently (for badge count)
(async function autoCheckNotices() {
  try {
    const posts = await fetchNotices();
    if (posts && posts.length > 0) {
      const unread = posts.filter(p => !readNotices.includes(p.id)).length;
      updateNoticeBadge(unread);
    }
  } catch(e) {}
})();

/* Dynamic user name
