<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NagorikBD Header – Universal Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=DM+Sans:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #1565c0;
  --teal: #00838f;
  --text: #0d1b2a;
  --text-soft: #5a7a9a;
  --bg: #f4f8ff;
  --border: rgba(21,101,192,0.09);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Hind Siliguri', sans-serif; }

/* ══ TOP STRIP ══ */
.top-strip {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 54px; display: flex; align-items: center; justify-content: space-between;
  padding: 0 4%;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 2px 20px rgba(21,101,192,0.06);
}
.brand { display:flex; align-items:center; gap:9px; text-decoration:none; }
.brand-icon {
  width:32px; height:32px; background:linear-gradient(135deg,#1565c0,#0097a7);
  border-radius:9px; display:flex; align-items:center; justify-content:center;
  font-size:0.95rem; flex-shrink:0;
}
.brand-name { font-family:'DM Sans',sans-serif; font-size:0.98rem; font-weight:700; color:var(--text); }
.brand-name span { color:var(--teal); }
.top-profile {
  display:flex; align-items:center; gap:9px; cursor:pointer;
  padding:4px 10px 4px 6px; border-radius:50px;
  border:1px solid rgba(21,101,192,0.12); background:rgba(255,255,255,0.6);
  transition:background 0.18s; text-decoration:none;
}
.top-profile:hover { background:rgba(21,101,192,0.06); }
.avatar {
  width:30px; height:30px; border-radius:50%;
  background:linear-gradient(135deg,#1565c0,#00838f);
  display:flex; align-items:center; justify-content:center;
  font-family:'DM Sans',sans-serif; font-size:0.68rem; font-weight:700; color:#fff;
  position:relative; border:2px solid rgba(255,255,255,0.9); flex-shrink:0;
}
.avatar-dot { position:absolute; bottom:-1px; right:-1px; width:8px; height:8px; background:#22c55e; border-radius:50%; border:2px solid #fff; }
.profile-info { display:flex; flex-direction:column; gap:1px; }
.profile-name { font-family:'DM Sans',sans-serif; font-size:0.76rem; font-weight:700; color:var(--text); max-width:120px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.profile-loc { font-family:'DM Sans',sans-serif; font-size:0.62rem; color:var(--text-soft); }

/* ══ BOTTOM NAV ══ */
.bottom-nav {
  position:fixed; bottom:0; left:0; right:0; z-index:200; height:62px;
  display:flex; align-items:center; justify-content:space-around; padding:0 2% 6px;
  background:rgba(255,255,255,0.78);
  backdrop-filter:blur(24px) saturate(200%);
  -webkit-backdrop-filter:blur(24px) saturate(200%);
  border-top:1px solid rgba(255,255,255,0.9);
  box-shadow:0 -4px 28px rgba(21,101,192,0.09);
}
.nav-item {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:3px; padding:0.4rem 0.3rem; border-radius:14px; border:none;
  background:transparent; cursor:pointer; text-decoration:none;
  transition:background 0.18s; position:relative;
}
.nav-item:hover { background:rgba(21,101,192,0.06); }
.nav-item.active { background:rgba(21,101,192,0.09); }
.nav-item.active::before { content:''; position:absolute; top:5px; width:4px; height:4px; background:var(--blue); border-radius:50%; }
.nav-icon { width:24px; height:24px; display:flex; align-items:center; justify-content:center; position:relative; }
.nav-icon svg { width:22px; height:22px; stroke:var(--text-soft); fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; transition:stroke 0.18s; }
.nav-item.active .nav-icon svg, .nav-item:hover .nav-icon svg { stroke:var(--blue); }
.nav-label { font-family:'Hind Siliguri',sans-serif; font-size:0.62rem; font-weight:600; color:var(--text-soft); transition:color 0.18s; }
.nav-item.active .nav-label, .nav-item:hover .nav-label { color:var(--blue); }
.notif-badge { position:absolute; top:-2px; right:-3px; min-width:15px; height:15px; background:#ef4444; border-radius:50%; border:2px solid #fff; font-family:'DM Sans',sans-serif; font-size:0.55rem; font-weight:700; color:#fff; display:flex; align-items:center; justify-content:center; padding:0 2px; }

/* menu button — last */
.menu-nav-btn {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:3px; padding:0.3rem; border-radius:14px; border:none; background:transparent;
  cursor:pointer; transition:background 0.18s;
}
.menu-nav-btn:hover { background:rgba(21,101,192,0.06); }
.menu-nav-btn.active { background:rgba(21,101,192,0.09); }
.menu-pill {
  width:44px; height:36px; background:linear-gradient(135deg,#1565c0,#0097a7);
  border-radius:12px; display:flex; align-items:center; justify-content:center;
  box-shadow:0 3px 14px rgba(21,101,192,0.3); transition:transform 0.2s, box-shadow 0.2s;
}
.menu-nav-btn:hover .menu-pill, .menu-nav-btn.active .menu-pill { transform:scale(1.06); box-shadow:0 5px 20px rgba(21,101,192,0.4); }
.menu-pill svg { stroke:#fff; width:18px; height:18px; fill:none; stroke-width:2; stroke-linecap:round; }
.menu-nav-lbl { font-family:'Hind Siliguri',sans-serif; font-size:0.62rem; font-weight:600; color:var(--blue); }

/* ══ MEGA SHEET ══ */
.mega-overlay { position:fixed; inset:0; z-index:300; pointer-events:none; opacity:0; transition:opacity 0.22s; }
.mega-overlay.open { pointer-events:all; opacity:1; }
.mega-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.3); backdrop-filter:blur(3px); }
.mega-sheet {
  position:absolute; bottom:62px; left:0; right:0;
  background:rgba(255,255,255,0.97); backdrop-filter:blur(24px);
  border-radius:24px 24px 0 0; border-top:1px solid rgba(255,255,255,0.9);
  box-shadow:0 -12px 50px rgba(21,101,192,0.12);
  padding:1.2rem 1rem 2rem; max-height:84vh; overflow-y:auto;
  transform:translateY(30px); transition:transform 0.28s cubic-bezier(.23,1,.32,1);
}
.mega-overlay.open .mega-sheet { transform:translateY(0); }
.handle { width:36px; height:4px; background:rgba(0,0,0,0.1); border-radius:2px; margin:0 auto 1.2rem; }
.sheet-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:0.8rem; padding:0 0.2rem; }
.sheet-title { font-family:'DM Sans',sans-serif; font-size:0.95rem; font-weight:700; color:var(--text); }
.close-btn { width:28px; height:28px; border-radius:50%; background:rgba(0,0,0,0.06); border:none; cursor:pointer; font-size:0.9rem; color:var(--text-soft); display:flex; align-items:center; justify-content:center; transition:background 0.15s; }
.close-btn:hover { background:rgba(21,101,192,0.1); }

/* search box inside menu */
.menu-search {
  display:flex; align-items:center; gap:8px;
  background:var(--bg); border:1.5px solid var(--border); border-radius:12px;
  padding:0.55rem 0.9rem; margin-bottom:1.2rem;
  transition:border-color 0.18s;
}
.menu-search:focus-within { border-color:rgba(21,101,192,0.35); }
.menu-search svg { width:16px; height:16px; stroke:var(--text-soft); fill:none; stroke-width:2; flex-shrink:0; }
.menu-search input {
  flex:1; border:none; background:transparent; outline:none;
  font-family:'Hind Siliguri',sans-serif; font-size:0.85rem; color:var(--text);
}
.menu-search input::placeholder { color:var(--text-soft); }

/* cat label */
.cat-label { font-family:'DM Sans',sans-serif; font-size:0.62rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-soft); display:block; margin-bottom:0.6rem; padding:0 0.2rem; }

/* pages grid — auto-fill */
.pages-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:0.55rem; margin-bottom:1.4rem;
}
.page-card {
  display:flex; flex-direction:column; align-items:center; gap:5px;
  padding:0.75rem 0.4rem; border-radius:14px;
  background:var(--bg); border:1px solid rgba(21,101,192,0.07);
  text-decoration:none; transition:background 0.18s, transform 0.18s;
  cursor:pointer;
}
.page-card:hover { background:rgba(21,101,192,0.08); transform:translateY(-2px); }
.page-card.hidden { display:none; }
.pc-icon { width:38px; height:38px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
.pc-label { font-family:'Hind Siliguri',sans-serif; font-size:0.65rem; font-weight:600; color:var(--text); text-align:center; line-height:1.3; word-break:break-word; }

/* loading skeleton */
.skeleton { background:linear-gradient(90deg,#e8f0fe 25%,#f4f8ff 50%,#e8f0fe 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; border-radius:11px; }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
.skel-card { padding:0.75rem 0.4rem; border-radius:14px; border:1px solid rgba(21,101,192,0.07); display:flex; flex-direction:column; align-items:center; gap:6px; }
.skel-ic { width:38px; height:38px; border-radius:11px; }
.skel-txt { width:48px; height:10px; border-radius:4px; }

/* no results */
.no-results { text-align:center; padding:1.5rem; color:var(--text-soft); font-size:0.85rem; display:none; }
.no-results.show { display:block; }

/* gov services grid */
.menu-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.55rem; margin-bottom:1.4rem; }
.menu-item { display:flex; flex-direction:column; align-items:center; gap:5px; padding:0.8rem 0.4rem; border-radius:14px; background:var(--bg); border:1px solid rgba(21,101,192,0.07); text-decoration:none; transition:background 0.18s, transform 0.18s; }
.menu-item:hover { background:rgba(21,101,192,0.08); transform:translateY(-2px); }
.mi-ic { width:38px; height:38px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; }
.mi-lbl { font-family:'Hind Siliguri',sans-serif; font-size:0.65rem; font-weight:600; color:var(--text); text-align:center; line-height:1.3; }
.c1{background:rgba(21,101,192,0.1);} .c2{background:rgba(0,131,143,0.1);} .c3{background:rgba(34,197,94,0.1);} .c4{background:rgba(234,88,12,0.1);} .c5{background:rgba(124,58,237,0.1);} .c6{background:rgba(239,68,68,0.1);} .c7{background:rgba(200,150,12,0.1);} .c8{background:rgba(14,165,233,0.1);}

/* quick links */
.quick-row { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:1.4rem; }
.q-link { font-family:'Hind Siliguri',sans-serif; font-size:0.75rem; font-weight:600; color:var(--blue); background:rgba(21,101,192,0.07); border:1px solid rgba(21,101,192,0.13); border-radius:50px; padding:0.35rem 0.85rem; text-decoration:none; transition:background 0.15s; }
.q-link:hover { background:rgba(21,101,192,0.14); }

/* page count badge */
.count-badge { font-family:'DM Sans',sans-serif; font-size:0.65rem; font-weight:700; color:var(--blue); background:rgba(21,101,192,0.1); border-radius:50px; padding:2px 8px; margin-left:6px; }

/* ══ NOTICE OVERLAY ══ */
.notice-overlay { position:fixed; inset:0; z-index:300; pointer-events:none; opacity:0; transition:opacity 0.22s; }
.notice-overlay.open { pointer-events:all; opacity:1; }
.notice-backdrop { position:absolute; inset:0; background:rgba(0,0,0,0.3); backdrop-filter:blur(3px); }
.notice-sheet {
  position:absolute; bottom:62px; left:0; right:0;
  background:rgba(255,255,255,0.98); backdrop-filter:blur(24px);
  border-radius:24px 24px 0 0; border-top:1px solid rgba(255,255,255,0.9);
  box-shadow:0 -12px 50px rgba(21,101,192,0.12);
  padding:1.2rem 1rem 2rem; max-height:84vh; overflow-y:auto;
  transform:translateY(30px); transition:transform 0.28s cubic-bezier(.23,1,.32,1);
}
.notice-overlay.open .notice-sheet { transform:translateY(0); }
.notice-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.2rem; padding:0 0.2rem; }
.notice-title-wrap { display:flex; align-items:center; gap:8px; }
.notice-title { font-family:'DM Sans',sans-serif; font-size:0.95rem; font-weight:700; color:var(--text); }
.notice-new-badge { font-size:0.6rem; font-weight:700; background:#ef4444; color:#fff; border-radius:50px; padding:2px 8px; font-family:'DM Sans',sans-serif; display:none; }
.notice-list { display:flex; flex-direction:column; gap:0.7rem; margin-bottom:1rem; }
.notice-item {
  display:flex; gap:12px; align-items:flex-start;
  padding:1rem 1.1rem; border-radius:16px;
  background:var(--bg); border:1px solid var(--border);
  text-decoration:none; transition:background 0.18s, transform 0.18s;
}
.notice-item:hover { background:rgba(21,101,192,0.06); transform:translateX(3px); }
.notice-item.unread { border-left:3px solid var(--blue); background:rgba(21,101,192,0.04); }
.n-dot { width:8px; height:8px; border-radius:50%; background:var(--blue); flex-shrink:0; margin-top:5px; }
.n-body { flex:1; min-width:0; }
.n-title { font-family:'Hind Siliguri',sans-serif; font-size:0.88rem; font-weight:700; color:var(--text); line-height:1.35; margin-bottom:4px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.n-meta { display:flex; align-items:center; gap:7px; flex-wrap:wrap; }
.n-date { font-family:'DM Sans',sans-serif; font-size:0.65rem; color:var(--text-soft); }
.n-cat { font-family:'DM Sans',sans-serif; font-size:0.6rem; font-weight:700; color:var(--blue); background:rgba(21,101,192,0.1); border-radius:50px; padding:2px 7px; }
.notice-skel { display:flex; gap:12px; align-items:flex-start; padding:1rem 1.1rem; border-radius:16px; background:var(--bg); border:1px solid var(--border); margin-bottom:0.7rem; }
.ns-d { width:8px; height:8px; border-radius:50%; flex-shrink:0; margin-top:5px; }
.ns-b { flex:1; display:flex; flex-direction:column; gap:6px; }
.ns-l { height:11px; border-radius:4px; background:linear-gradient(90deg,#e8f0fe 25%,#f4f8ff 50%,#e8f0fe 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; }
.ns-l.w80{width:80%;} .ns-l.w50{width:50%;}
.notice-view-all { display:block; text-align:center; padding:0.7rem; font-family:'Hind Siliguri',sans-serif; font-size:0.85rem; font-weight:700; color:var(--blue); background:rgba(21,101,192,0.07); border:1px solid rgba(21,101,192,0.15); border-radius:12px; text-decoration:none; transition:background 0.18s; }
.notice-view-all:hover { background:rgba(21,101,192,0.13); }
.notice-empty { text-align:center; padding:2rem; color:var(--text-soft); display:none; }
.notice-empty .nei { font-size:2.2rem; margin-bottom:0.5rem; }
.notice-empty p { font-size:0.85rem; line-height:1.6; }
</style>
</head>
<body>

<!-- ══ TOP STRIP ══ -->
<div class="top-strip">
  <a href="#" class="brand">
    <div class="brand-icon">🏛</div>
    <span class="brand-name">Nagorik<span>BD</span></span>
  </a>
  <a href="#" class="top-profile">
    <div class="avatar">
      <span id="avatarInitials">?</span>
      <div class="avatar-dot"></div>
    </div>
    <div class="profile-info">
      <span class="profile-name" id="topUserName">লগইন করুন</span>
      <span class="profile-loc">ময়মনসিংহ জেলা</span>
    </div>
  </a>
</div>

<!-- ══ BOTTOM NAV ══ -->
<nav class="bottom-nav">
  <a href="#" class="nav-item active" id="n-home" onclick="setNav('n-home')">
    <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
    <span class="nav-label">হোম</span>
  </a>
  <a href="#" class="nav-item" id="n-feed" onclick="setNav('n-feed')">
    <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M4 11a9 9 0 019 9"/><path d="M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1.5" fill="#5a7a9a" stroke="none"/></svg></div>
    <span class="nav-label">ফিড</span>
  </a>
  <a href="#" class="nav-item" id="n-notice" onclick="openNotice(event)">
    <div class="nav-icon">
      <span class="notif-badge" id="noticeBadge" style="display:none">0</span>
      <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
    </div>
    <span class="nav-label">নোটিশ</span>
  </a>
  <!-- MENU — LAST -->
  <button class="menu-nav-btn" id="n-mega" onclick="toggleMega()">
    <div class="menu-pill">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </div>
    <span class="menu-nav-lbl">মেনু</span>
  </button>
</nav>

<!-- ══ NOTICE OVERLAY ══ -->
<div class="notice-overlay" id="noticeOverlay">
  <div class="notice-backdrop" onclick="closeNotice()"></div>
  <div class="notice-sheet">
    <div class="handle"></div>
    <div class="notice-head">
      <div class="notice-title-wrap">
        <span class="notice-title">📢 নোটিশ বোর্ড</span>
        <span class="notice-new-badge" id="noticeNewBadge">নতুন</span>
      </div>
      <button class="close-btn" onclick="closeNotice()">✕</button>
    </div>

    <!-- Skeletons shown while loading -->
    <div id="noticeSkeletons">
      <div class="notice-skel"><div class="ns-d skeleton"></div><div class="ns-b"><div class="ns-l w80"></div><div class="ns-l w50"></div></div></div>
      <div class="notice-skel"><div class="ns-d skeleton"></div><div class="ns-b"><div class="ns-l w80"></div><div class="ns-l w50"></div></div></div>
      <div class="notice-skel"><div class="ns-d skeleton"></div><div class="ns-b"><div class="ns-l w80"></div><div class="ns-l w50"></div></div></div>
    </div>

    <!-- Actual notice list -->
    <div class="notice-list" id="noticeList"></div>

    <!-- Empty state -->
    <div class="notice-empty" id="noticeEmpty">
      <div class="nei">🔔</div>
      <p>এখনো কোনো নোটিশ নেই।<br>নতুন পোস্ট করলে এখানে দেখাবে।</p>
    </div>

    <!-- View all link -->
    <a href="/notice/" class="notice-view-all" id="noticeViewAll" style="display:none">
      সব নোটিশ দেখুন →
    </a>
  </div>
</div>

<!-- ══ MEGA SHEET ══ -->
<div class="mega-overlay" id="megaOverlay">
  <div class="mega-backdrop" onclick="closeMega()"></div>
  <div class="mega-sheet">
    <div class="handle"></div>
    <div class="sheet-head">
      <span class="sheet-title">
        সকল পাতা
        <span class="count-badge" id="pageCount">লোড হচ্ছে...</span>
      </span>
      <button class="close-btn" onclick="closeMega()">✕</button>
    </div>

    <!-- Search -->
    <div class="menu-search">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="pageSearch" placeholder="পাতা খুঁজুন..." oninput="filterPages(this.value)">
    </div>

    <!-- All Pages — auto loaded -->
    <span class="cat-label">📄 সকল পাতা</span>
    <div class="pages-grid" id="pagesGrid">
      <!-- skeleton loaders -->
      <div class="skel-card"><div class="skel-ic skeleton"></div><div class="skel-txt skeleton"></div></div>
      <div class="skel-card"><div class="skel-ic skeleton"></div><div class="skel-txt skeleton"></div></div>
      <div class="skel-card"><div class="skel-ic skeleton"></div><div class="skel-txt skeleton"></div></div>
      <div class="skel-card"><div class="skel-ic skeleton"></div><div class="skel-txt skeleton"></div></div>
    </div>
    <div class="no-results" id="noResults">কোনো পাতা পাওয়া যায়নি 🔍</div>

    <!-- Gov Services -->
    <span class="cat-label">🏛 সরকারি সেবা</span>
    <div class="menu-grid">
      <a href="#" class="menu-item"><div class="mi-ic c1">🪪</div><span class="mi-lbl">NID সেবা</span></a>
