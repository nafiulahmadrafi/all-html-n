<script>
/* ══════════════════════════════════════════════
   CONFIG — WordPress এ এই URL টা আপনার সাইটের
   ══════════════════════════════════════════════ */
const WP_SITE_URL = window.location.origin;

/* ═══════════════════════════════
   NOTICE — WordPress posts auto-fetch
   Category slug 'notice' বা যেকোনো category
   ═══════════════════════════════ */
let noticeLoaded = false;
const NOTICE_CATEGORY = 'notice'; // WordPress category slug
const SEEN_KEY = 'nb_seen_notices';

function formatDate(dateStr) {
  const d = new Date(dateStr);
  const months = ['জানু','ফেব','মার্চ','এপ্রি','মে','জুন','জুলা','আগস্ট','সেপ্ট','অক্টো','নভে','ডিসে'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

async function fetchNotices() {
  try {
    // Try category-specific first
    let url = `${WP_SITE_URL}/wp-json/wp/v2/posts?per_page=10&status=publish&_fields=id,title,link,date,categories,_links&orderby=date&order=desc`;

    // Try to get category ID first
    const catRes = await fetch(`${WP_SITE_URL}/wp-json/wp/v2/categories?slug=${NOTICE_CATEGORY}&_fields=id`);
    if (catRes.ok) {
      const cats = await catRes.json();
      if (cats.length > 0) {
        url += `&categories=${cats[0].id}`;
      }
    }

    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
    if (!res.ok) throw new Error('Failed');
    return await res.json();
  } catch (e) {
    // Fallback demo notices
    return [
      { id:1, title:{ rendered:'ময়মনসিংহ জেলা নাগরিক পোর্টাল চালু হয়েছে' }, link:'#', date:'2024-11-01', categories:[1] },
      { id:2, title:{ rendered:'নাগরিক সেবা আপডেট — নতুন সেবা যোগ হয়েছে' }, link:'#', date:'2024-10-28', categories:[1] },
      { id:3, title:{ rendered:'উপজেলা ফোরাম নিবন্ধন শুরু হয়েছে' }, link:'#', date:'2024-10-20', categories:[1] },
    ];
  }
}

function renderNotices(posts) {
  const list = document.getElementById('noticeList');
  const skels = document.getElementById('noticeSkeletons');
  const empty = document.getElementById('noticeEmpty');
  const viewAll = document.getElementById('noticeViewAll');
  const newBadge = document.getElementById('noticeNewBadge');
  const navBadge = document.getElementById('noticeBadge');

  skels.style.display = 'none';
  list.innerHTML = '';

  if (!posts || posts.length === 0) {
    empty.style.display = 'block';
    return;
  }

  // Track seen
  const seen = JSON.parse(localStorage.getItem(SEEN_KEY) || '[]');
  const newCount = posts.filter(p => !seen.includes(p.id)).length;

  if (newCount > 0) {
    navBadge.style.display = 'flex';
    navBadge.textContent = newCount;
    newBadge.style.display = 'inline-block';
    newBadge.textContent = `${newCount}টি নতুন`;
  }

  posts.forEach(post => {
    const isUnread = !seen.includes(post.id);
    const title = post.title?.rendered || post.title || 'নোটিশ';
    const date = formatDate(post.date);

    const item = document.createElement('a');
    item.href = post.link || '#';
    item.className = `notice-item${isUnread ? ' unread' : ''}`;
    item.innerHTML = `
      <div class="n-dot"></div>
      <div class="n-body">
        <div class="n-title">${title}</div>
        <div class="n-meta">
          <span class="n-date">📅 ${date}</span>
          ${isUnread ? '<span class="n-cat">নতুন</span>' : ''}
        </div>
      </div>
    `;
    item.onclick = () => markSeen(post.id);
    list.appendChild(item);
  });

  viewAll.style.display = 'block';
}

function markSeen(id) {
  const seen = JSON.parse(localStorage.getItem(SEEN_KEY) || '[]');
  if (!seen.includes(id)) {
    seen.push(id);
    localStorage.setItem(SEEN_KEY, JSON.stringify(seen));
  }
  // recount
  const remaining = document.querySelectorAll('.notice-item.unread').length - 1;
  const badge = document.getElementById('noticeBadge');
  if (remaining <= 0) { badge.style.display = 'none'; }
  else { badge.textContent = remaining; }
}

async function loadNoticesIfNeeded() {
  if (noticeLoaded) return;
  noticeLoaded = true;
  const posts = await fetchNotices();
  renderNotices(posts);
}

function openNotice(e) {
  e.preventDefault();
  setNav('n-notice');
  document.getElementById('noticeOverlay').classList.add('open');
  loadNoticesIfNeeded();
  // mark all as seen after viewing
  setTimeout(() => {
    const posts = document.querySelectorAll('.notice-item');
    posts.forEach(p => p.classList.remove('unread'));
    document.getElementById('noticeBadge').style.display = 'none';
  }, 3000);
}

function closeNotice() {
  document.getElementById('noticeOverlay').classList.remove('open');
}

