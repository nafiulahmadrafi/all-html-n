   const loggedInUser = '<?php echo esc_js(wp_get_current_user()->display_name); ?>';
*/
const loggedInUser = 'Ahmad Rafi';

(function initUser() {
  const nameEl = document.getElementById('topUserName');
  const initialsEl = document.getElementById('avatarInitials');
  if (loggedInUser?.trim()) {
    nameEl.textContent = loggedInUser;
    const p = loggedInUser.trim().split(' ');
    initialsEl.textContent = p.length >= 2
      ? p[0][0].toUpperCase() + p[1][0].toUpperCase()
      : p[0].slice(0,2).toUpperCase();
  } else {
    nameEl.textContent = 'লগইন করুন';
    initialsEl.textContent = '?';
  }
})();
