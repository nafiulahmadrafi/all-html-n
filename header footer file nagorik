function getPageIcon(slug, title) {
  const key = Object.keys(PAGE_ICONS).find(k =>
    slug.includes(k) || title.toLowerCase().includes(k)
  );
  return PAGE_ICONS[key] || PAGE_ICONS['default'];
}

/* Fetch all WordPress pages via REST API */
async function fetchAllPages() {
  try {
    let page = 1;
    let collected = [];

    while (true) {
      const res = await fetch(
        `${WP_SITE_URL}/wp-json/wp/v2/pages?per_page=100&page=${page}&status=publish&_fields=id,title,link,slug`,
        { headers: { 'Accept': 'application/json' } }
      );

      if (!res.ok) break;

      const total = parseInt(res.headers.get('X-WP-TotalPages') || '1');
      const data = await res.json();
      collected = [...collected, ...data];

      if (page >= total) break;
      page++;
    }

    return collected;
  } catch (e) {
    console.warn('WP REST API failed, using fallback pages');
    return null;
  }
}

/* Render pages into grid */
function renderPages(pages) {
  const grid = document.getElementById('pagesGrid');
  grid.innerHTML = '';

  if (!pages || pages.length === 0) {
    renderFallbackPages();
    return;
  }

  allPages = pages;
  document.getElementById('pageCount').textContent = `${pages.length}টি পাতা`;

  pages.forEach(p => {
    const slug = p.slug || '';
    const title = p.title?.rendered || p.title || 'পাতা';
    const url = p.link || '#';
    const { icon, bg } = getPageIcon(slug, title);

    const card = document.createElement('a');
    card.href = url;
    card.className = 'page-card';
    card.dataset.slug = slug;
    card.dataset.title = title.toLowerCase();
    card.innerHTML = `
      <div class="pc-icon" style="background:${bg}">${icon}</div>
      <span class="pc-label">${title}</span>
    `;
    grid.appendChild(card);
  });
}

