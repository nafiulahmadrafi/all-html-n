<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>স্বেচ্ছাসেবক নিবন্ধন — নাগরিক ফোরাম বাংলাদেশ</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Tiro+Bangla:ital@0;1&display=swap" rel="stylesheet">
<!-- jsPDF for PDF generation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Hind Siliguri', sans-serif;
  background: linear-gradient(160deg, #e8f5e9 0%, #ffffff 40%, #fff5f5 70%, #fce4e4 100%);
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 30px 16px 70px;
  position: relative;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 55% at 8% 12%, rgba(0,106,78,0.08) 0%, transparent 65%),
    radial-gradient(ellipse 65% 55% at 92% 88%, rgba(244,42,65,0.07) 0%, transparent 65%),
    radial-gradient(ellipse 50% 40% at 50% 50%, rgba(255,255,255,0.55) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.container {
  width: 100%;
  max-width: 740px;
  position: relative;
  z-index: 1;
}

/* ── Hero ── */
.hero-header {
  text-align: center;
  margin-bottom: 22px;
  animation: fadeDown 0.55s ease;
}
@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.flag-strip {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 13px;
}
.flag-green1 { background: #006a4e; width: 55px; height: 5px; border-radius: 3px 0 0 3px; }
.flag-circle { background: #f42a41; width: 26px; height: 26px; border-radius: 50%; margin: 0 8px; box-shadow: 0 2px 10px rgba(244,42,65,0.35); }
.flag-green2 { background: #006a4e; width: 55px; height: 5px; border-radius: 0 3px 3px 0; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(120deg, rgba(0,106,78,0.1), rgba(244,42,65,0.08));
  border: 1px solid rgba(0,106,78,0.18);
  color: #006a4e;
  font-size: 11px;
  font-weight: 700;
  padding: 5px 14px;
  border-radius: 20px;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.hero-icon { font-size: 48px; line-height: 1; margin-bottom: 10px; }

.hero-title {
  font-family: 'Tiro Bangla', serif;
  font-size: 26px;
  font-weight: 700;
  color: #1a3320;
  line-height: 1.35;
}
.hero-title span {
  background: linear-gradient(120deg, #006a4e 20%, #f42a41 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: 13px;
  color: #4a6741;
  margin-top: 8px;
  line-height: 1.7;
}

/* ── Progress steps ── */
.steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 18px 0 22px;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  position: relative;
}
.step-dot {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: #e8f5e9;
  border: 2px solid #b8ddc8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  color: #9ab8a8;
  transition: all 0.3s;
  z-index: 1;
}
.step.active .step-dot {
  background: #006a4e;
  border-color: #006a4e;
  color: #fff;
  box-shadow: 0 3px 10px rgba(0,106,78,0.3);
}
.step.done .step-dot {
  background: #e8f5e9;
  border-color: #006a4e;
  color: #006a4e;
}
.step-label {
  font-size: 10px;
  font-weight: 600;
  color: #9ab8a8;
  white-space: nowrap;
  letter-spacing: 0.3px;
}
.step.active .step-label { color: #006a4e; }
.step.done .step-label { color: #5a9a7a; }
.step-line {
  width: 50px; height: 2px;
  background: #c8e6c9;
  margin-bottom: 20px;
  transition: background 0.3s;
}
.step-line.done { background: #006a4e; }

@media (max-width: 480px) { .step-line { width: 28px; } .step-label { font-size: 9px; } }

/* ── Form card ── */
.form-card {
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0,106,78,0.13);
  border-radius: 20px;
  padding: 32px 30px;
  box-shadow:
    0 4px 24px rgba(0,106,78,0.08),
    0 1px 4px rgba(0,0,0,0.04),
    inset 0 1px 0 rgba(255,255,255,0.9);
  animation: fadeUp 0.65s ease 0.1s both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Step panels ── */
.step-panel { display: none; }
.step-panel.active { display: block; animation: panelIn 0.35s ease; }
@keyframes panelIn {
  from { opacity: 0; transform: translateX(12px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── Section labels ── */
.section-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  color: #006a4e;
  margin-bottom: 12px;
  margin-top: 22px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-label:first-of-type { margin-top: 0; }
.section-label::before {
  content: '';
  width: 3px; height: 13px;
  background: linear-gradient(180deg, #006a4e 0%, #f42a41 100%);
  border-radius: 2px;
  flex-shrink: 0;
}

.section-divider {
  border: none;
  border-top: 1px solid rgba(0,106,78,0.1);
  margin: 6px 0 0;
}

/* ── Grid layouts ── */
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.grid-1 { display: grid; grid-template-columns: 1fr; gap: 12px; }

@media (max-width: 600px) {
  .grid-3 { grid-template-columns: 1fr; }
  .grid-2 { grid-template-columns: 1fr; }
  .form-card { padding: 20px 14px; }
  .hero-title { font-size: 21px; }
}

/* ── Field ── */
.field-wrap { display: flex; flex-direction: column; gap: 5px; }
.field-label {
  font-size: 11.5px;
  color: #2d5f3f;
  font-weight: 600;
  letter-spacing: 0.2px;
}
.field-label .req { color: #e53935; margin-left: 2px; }

input, select, textarea {
  width: 100%;
  background: rgba(255,255,255,0.85);
  border: 1.5px solid #b8ddc8;
  border-radius: 10px;
  color: #1a2e1a;
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 14px;
  padding: 10px 13px;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
}
input:focus, select:focus, textarea:focus {
  border-color: #006a4e;
  background: rgba(255,255,255,0.98);
  box-shadow: 0 0 0 3px rgba(0,106,78,0.1);
}
input.error, select.error, textarea.error {
  border-color: #e53935;
  box-shadow: 0 0 0 3px rgba(229,57,53,0.08);
}
input::placeholder, textarea::placeholder { color: #9abfab; }
select option { background: #fff; color: #1a2e1a; }
select:disabled { opacity: 0.42; cursor: not-allowed; }

.select-wrap { position: relative; }
.select-wrap select { padding-right: 32px; cursor: pointer; }
.select-wrap::after {
  content: '▾';
  position: absolute;
  right: 11px; top: 50%;
  transform: translateY(-50%);
  color: #006a4e;
  pointer-events: none;
  font-size: 13px;
}

textarea { resize: vertical; min-height: 90px; line-height: 1.6; }

/* ── Skills grid ── */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 2px;
}
@media (max-width: 500px) { .skills-grid { grid-template-columns: repeat(2, 1fr); } }

.skill-chip {
  display: flex;
  align-items: center;
  gap: 7px;
  background: rgba(255,255,255,0.7);
  border: 1.5px solid #c8e6c9;
  border-radius: 9px;
  padding: 9px 11px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 12.5px;
  color: #2d5f3f;
  font-weight: 500;
  user-select: none;
}
.skill-chip:hover { border-color: #006a4e; background: rgba(0,106,78,0.05); }
.skill-chip.selected {
  border-color: #006a4e;
  background: rgba(0,106,78,0.1);
  color: #006a4e;
  font-weight: 600;
}
.skill-chip input[type="checkbox"] { display: none; }
.skill-check {
  width: 16px; height: 16px;
  border: 1.5px solid #b8ddc8;
  border-radius: 4px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  transition: all 0.2s;
  font-size: 10px;
}
.skill-chip.selected .skill-check {
  background: #006a4e;
  border-color: #006a4e;
  color: #fff;
}
.skill-chip.selected .skill-check::after { content: '✓'; }

/* ── Availability radio ── */
.avail-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-top: 2px;
}
@media (max-width: 500px) { .avail-grid { grid-template-columns: repeat(2, 1fr); } }

.avail-chip {
  border: 1.5px solid #c8e6c9;
  border-radius: 9px;
  padding: 9px 8px;
  text-align: center;
  cursor: pointer;
  font-size: 12px;
  color: #2d5f3f;
  font-weight: 500;
  background: rgba(255,255,255,0.7);
  transition: all 0.2s;
  user-select: none;
}
.avail-chip:hover { border-color: #006a4e; }
.avail-chip.selected {
  border-color: #006a4e;
  background: rgba(0,106,78,0.1);
  color: #006a4e;
  font-weight: 700;
}
.avail-chip input { display: none; }

/* ── Motivation textarea hint ── */
.char-count { font-size: 11px; color: #6aaa88; text-align: right; margin-top: 3px; }

/* ── Navigation buttons ── */
.btn-row {
  display: flex;
  gap: 12px;
  margin-top: 28px;
}

.btn-back {
  flex: 0 0 auto;
  background: rgba(255,255,255,0.8);
  border: 1.5px solid #b8ddc8;
  border-radius: 12px;
  color: #2d5f3f;
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 14px;
  font-weight: 600;
  padding: 13px 22px;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 7px;
}
.btn-back:hover { border-color: #006a4e; background: rgba(0,106,78,0.05); }

.btn-next, .btn-submit, .btn-pdf {
  flex: 1;
  border: none;
  border-radius: 12px;
  color: #fff;
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 15.5px;
  font-weight: 700;
  padding: 13px 20px;
  cursor: pointer;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  letter-spacing: 0.2px;
}

.btn-next {
  background: linear-gradient(120deg, #006a4e 0%, #00a36c 100%);
  box-shadow: 0 4px 16px rgba(0,106,78,0.25);
}
.btn-next:hover { transform: translateY(-2px); box-shadow: 0 7px 22px rgba(0,106,78,0.32); }

.btn-submit {
  background: linear-gradient(120deg, #006a4e 0%, #00a36c 45%, #c62828 100%);
  background-size: 200% 100%;
  background-position: 0%;
  box-shadow: 0 4px 16px rgba(0,106,78,0.25);
}
.btn-submit:hover { background-position: 100%; transform: translateY(-2px); box-shadow: 0 7px 22px rgba(0,106,78,0.3); }
.btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.btn-pdf {
  background: linear-gradient(120deg, #b71c1c 0%, #e53935 100%);
  box-shadow: 0 4px 16px rgba(183,28,28,0.22);
}
.btn-pdf:hover { transform: translateY(-2px); box-shadow: 0 7px 22px rgba(183,28,28,0.28); }

/* ── Spinner ── */
.spinner {
  width: 18px; height: 18px;
  border: 2.5px solid rgba(255,255,255,0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: none;
}
.btn-submit.loading .spinner { display: block; }
.btn-submit.loading .btn-txt { display: none; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Review card ── */
.review-section {
  background: rgba(240,250,244,0.6);
  border: 1px solid #c8e6c9;
  border-radius: 12px;
  padding: 16px 18px;
  margin-bottom: 14px;
}
.review-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #006a4e;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.review-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px 16px;
}
@media (max-width: 480px) { .review-grid { grid-template-columns: 1fr; } }
.review-item { font-size: 13px; color: #1a2e1a; }
.review-item span { color: #5a9a7a; font-weight: 600; font-size: 11px; display: block; }

/* ── Modal ── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.32);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal-overlay.show { opacity: 1; pointer-events: all; }
.modal-box {
  background: rgba(255,255,255,0.97);
  border: 1.5px solid rgba(0,106,78,0.2);
  border-radius: 22px;
  padding: 36px 32px;
  text-align: center;
  max-width: 420px;
  width: 100%;
  transform: scale(0.88);
  transition: transform 0.3s;
  box-shadow: 0 16px 50px rgba(0,106,78,0.18);
}
.modal-overlay.show .modal-box { transform: scale(1); }
.modal-icon { font-size: 56px; margin-bottom: 12px; }
.modal-title { font-size: 20px; font-weight: 700; color: #006a4e; font-family: 'Tiro Bangla', serif; margin-bottom: 8px; }
.modal-text { font-size: 13px; color: #4a6741; line-height: 1.75; }
.modal-text strong { color: #006a4e; }
.modal-ref { font-size: 12px; color: #6aaa88; margin-top: 10px; font-weight: 600; }
.modal-actions { display: flex; gap: 10px; margin-top: 20px; justify-content: center; }
.modal-btn-green {
  background: linear-gradient(120deg, #006a4e, #00a36c);
  color: #fff; border: none; border-radius: 10px;
  padding: 10px 24px; font-size: 14px; font-weight: 700;
  cursor: pointer; font-family: 'Hind Siliguri', sans-serif;
  transition: transform 0.2s; box-shadow: 0 3px 12px rgba(0,106,78,0.22);
}
.modal-btn-green:hover { transform: scale(1.04); }
.modal-btn-red {
  background: linear-gradient(120deg, #b71c1c, #e53935);
  color: #fff; border: none; border-radius: 10px;
  padding: 10px 24px; font-size: 14px; font-weight: 700;
  cursor: pointer; font-family: 'Hind Siliguri', sans-serif;
  transition: transform 0.2s; box-shadow: 0 3px 12px rgba(183,28,28,0.2);
}
.modal-btn-red:hover { transform: scale(1.04); }

/* ═══ UNIVERSAL FOOTER ═══ */
.pib-footer { margin-top: 48px; position: relative; z-index: 10; font-family: 'Hind Siliguri', sans-serif; }
.pib-footer-wave { width: 100%; line-height: 0; overflow: hidden; }
.pib-footer-wave svg { display: block; width: 100%; height: 48px; }
.pib-footer-body {
  background: linear-gradient(160deg, #0a1628 0%, #0d2137 55%, #0f1f10 100%);
  padding: 38px 20px 0;
  position: relative;
  overflow: hidden;
}
.pib-footer-body::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 20% 30%, rgba(0,106,78,0.12) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 70%, rgba(244,42,65,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 50% 10%, rgba(212,175,55,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.pib-footer-inner { max-width: 760px; margin: 0 auto; position: relative; z-index: 1; }
.pib-footer-brand {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 26px;
  padding-bottom: 20px;
  border-bottom: 1px solid rgba(212,175,55,0.18);
}
.pib-footer-logo {
  width: 56px; height: 56px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(212,175,55,0.45);
  box-shadow: 0 4px 16px rgba(0,0,0,0.4), 0 0 20px rgba(212,175,55,0.12);
  flex-shrink: 0;
}
.pib-footer-orgname { font-family: 'Tiro Bangla', serif; font-size: 17px; font-weight: 700; color: #f5d76e; line-height: 1.2; }
.pib-footer-tagline { font-size: 10.5px; color: rgba(255,255,255,0.45); margin-top: 3px; letter-spacing: 1px; text-transform: uppercase; }
.pib-footer-badge {
  background: linear-gradient(120deg, rgba(212,175,55,0.14), rgba(212,175,55,0.07));
  border: 1px solid rgba(212,175,55,0.28);
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 10px;
  font-weight: 700;
  color: #f5d76e;
  letter-spacing: 0.7px;
  text-transform: uppercase;
  white-space: nowrap;
  margin-left: auto;
}
.pib-footer-nav {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
  gap: 18px 24px;
  margin-bottom: 24px;
}
.pib-nav-col-title {
  font-size: 10.5px; font-weight: 700; color: #f5d76e;
  letter-spacing: 1.2px; text-transform: uppercase;
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 6px;
}
.pib-nav-col-title::after { content: ''; flex: 1; height: 1px; background: rgba(212,175,55,0.18); }
.pib-nav-links { list-style: none; display: flex; flex-direction: column; gap: 6px; }
.pib-nav-links li a {
  font-size: 12.5px;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  display: flex; align-items: center; gap: 6px;
  transition: color 0.2s, padding-left 0.2s;
}
.pib-nav-links li a:hover { color: #f5d76e; padding-left: 3px; }
.pib-footer-contact {
  display: flex; flex-wrap: wrap; gap: 8px 20px;
  padding: 14px 16px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(212,175,55,0.1);
  border-radius: 12px;
  margin-bottom: 20px;
}
.pib-contact-item { display: flex; align-items: center; gap: 7px; font-size: 12px; color: rgba(255,255,255,0.5); }
.pib-contact-item a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
.pib-contact-item a:hover { color: #f5d76e; }
.pib-footer-social { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
.pib-social-btn {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 8px;
  padding: 7px 13px;
  font-size: 11.5px; font-weight: 600;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  transition: all 0.22s;
  font-family: 'Hind Siliguri', sans-serif;
  cursor: pointer;
}
.pib-social-btn:hover {
  background: rgba(212,175,55,0.1);
  border-color: rgba(212,175,55,0.28);
  color: #f5d76e;
  transform: translateY(-2px);
}
.pib-footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 14px 0 18px;
  display: flex; flex-wrap: wrap; gap: 8px;
  align-items: center; justify-content: space-between;
}
.pib-copyright { font-size: 11.5px; color: rgba(255,255,255,0.32); line-height: 1.7; }
.pib-copyright strong { color: rgba(212,175,55,0.65); }
.pib-footer-legal { display: flex; gap: 14px; }
.pib-footer-legal a { font-size: 10.5px; color: rgba(255,255,255,0.28); text-decoration: none; transition: color 0.2s; }
.pib-footer-legal a:hover { color: #f5d76e; }
@media (max-width: 580px) {
  .pib-footer-brand { flex-wrap: wrap; }
  .pib-footer-badge { display: none; }
