window.addEventListener('DOMContentLoaded', function() {
  // Divisions
  var divSel = document.getElementById('division');
  Object.keys(BD).forEach(function(d) {
    var o = document.createElement('option'); o.value = d; o.textContent = d; divSel.appendChild(o);
  });

  // Skills chips
  var sg = document.getElementById('skillsGrid');
  SKILLS.forEach(function(s, i) {
    var chip = document.createElement('label');
    chip.className = 'skill-chip';
    chip.innerHTML = '<input type="checkbox" value="' + s.label + '">' +
      '<span class="skill-check"></span>' + s.icon + ' ' + s.label;
    chip.addEventListener('click', function() {
      setTimeout(function() {
        var cb = chip.querySelector('input');
        if (cb.checked) {
          chip.classList.add('selected');
          if (!selectedSkills.includes(s.label)) selectedSkills.push(s.label);
        } else {
          chip.classList.remove('selected');
          selectedSkills = selectedSkills.filter(function(x){ return x !== s.label; });
        }
      }, 0);
    });
    sg.appendChild(chip);
  });

  // Availability chips
  var ag = document.getElementById('availGrid');
  AVAILABILITY.forEach(function(a) {
    var chip = document.createElement('div');
    chip.className = 'avail-chip';
    chip.textContent = a;
    chip.addEventListener('click', function() {
      document.querySelectorAll('.avail-chip').forEach(function(c){ c.classList.remove('selected'); });
      chip.classList.add('selected');
      selectedAvail = a;
    });
    ag.appendChild(chip);
  });
});

