// ── Step navigation ──
function goStep(n) {
  if (n > currentStep && !validateStep(currentStep)) return;

  // Update panels
  document.querySelectorAll('.step-panel').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('panel' + n).classList.add('active');

  // Update step indicators
  for (var i = 1; i <= 4; i++) {
    var el = document.getElementById('stepEl' + i);
    el.classList.remove('active','done');
    if (i < n) el.classList.add('done');
    else if (i === n) el.classList.add('active');
  }
  // Update lines
  for (var j = 1; j <= 3; j++) {
    var line = document.getElementById('line' + j);
    if (line) {
      if (j < n) line.classList.add('done');
      else line.classList.remove('done');
    }
  }

  currentStep = n;
  if (n === 4) buildReview();
  window.scrollTo({top: 0, behavior: 'smooth'});
}

// ── Validation ──
function validateStep(step) {
  var ok = true;
  function req(id) {
    var el = document.getElementById(id);
    if (!el.value.trim()) { el.classList.add('error'); ok = false; } else el.classList.remove('error');
  }
  if (step === 1) { req('division'); req('zila'); req('upazila'); }
  if (step === 2) { req('name'); req('phone'); req('age'); req('profession'); }
  if (!ok) alert('অনুগ্রহ করে * চিহ্নিত সকল তথ্য পূরণ করুন।');
  return ok;
}

// ── Build review ──
function buildReview() {
  document.getElementById('rev_div').textContent   = document.getElementById('division').value || '—';
  document.getElementById('rev_zila').textContent  = document.getElementById('zila').value || '—';
  document.getElementById('rev_upa').textContent   = document.getElementById('upazila').value || '—';
  document.getElementById('rev_name').textContent  = document.getElementById('name').value || '—';
  document.getElementById('rev_phone').textContent = document.getElementById('phone').value || '—';
  document.getElementById('rev_email').textContent = document.getElementById('email').value || '—';
  document.getElementById('rev_age').textContent   = document.getElementById('age').value ? document.getElementById('age').value + ' বছর' : '—';
  var inst = document.getElementById('institution').value;
  var cd   = document.getElementById('classDept').value;
  document.getElementById('rev_inst').textContent  = (inst ? inst + (cd ? ' ('+cd+')' : '') : '—');
  document.getElementById('rev_prof').textContent  = document.getElementById('profession').value || '—';
  var sk = selectedSkills.slice();
  var oth = document.getElementById('otherSkill').value.trim();
  if (oth) sk.push(oth);
  document.getElementById('rev_skills').textContent = sk.length ? sk.join(', ') : '—';
  document.getElementById('rev_avail').textContent  = selectedAvail || '—';
}

// ── Collect data ──
function collectData() {
  var sk = selectedSkills.slice();
  var oth = document.getElementById('otherSkill').value.trim();
  if (oth) sk.push(oth);
  return {
    division:    document.getElementById('division').value,
    zila:        document.getElementById('zila').value,
    upazila:     document.getElementById('upazila').value,
    name:        document.getElementById('name').value.trim(),
    phone:       document.getElementById('phone').value.trim(),
    email:       document.getElementById('email').value.trim(),
    age:         document.getElementById('age').value,
    institution: document.getElementById('institution').value.trim(),
    classDept:   document.getElementById('classDept').value.trim(),
    profession:  document.getElementById('profession').value,
    social:      document.getElementById('social').value.trim(),
    skills:      sk,
    availability:selectedAvail,
    motivation:  document.getElementById('motivation').value.trim()
  };
}

// ── PDF Generation ──
function generatePDF() {
  var d = collectData();
  var refNo = lastRefNo || ('VOL-' + Date.now().toString(36).toUpperCase());
  buildPDF(d, refNo);
}

function downloadPDFFromModal() {
  var d = collectData();
