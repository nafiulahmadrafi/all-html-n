}

function buildPDF(d, refNo) {
  var jsPDF = window.jspdf.jsPDF;
  var doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  var W = 210, margin = 18, y = 0;

  // Header bar
  doc.setFillColor(0, 106, 78);
  doc.rect(0, 0, W, 32, 'F');
  doc.setFillColor(244, 42, 65);
  doc.circle(W/2, 16, 8, 'F');

  // Title
  doc.setTextColor(255, 255, 255);
  doc.setFontSize(14);
  doc.setFont('helvetica','bold');
  doc.text('Nagorik Forum Bangladesh', W/2, 11, {align:'center'});
  doc.setFontSize(10);
  doc.setFont('helvetica','normal');
  doc.text('Volunteer Registration Certificate', W/2, 27, {align:'center'});

  y = 44;

  // Ref & date
  doc.setTextColor(100,100,100);
  doc.setFontSize(9);
  doc.text('Ref: ' + refNo, margin, y);
  doc.text('Date: ' + new Date().toLocaleDateString('en-BD'), W - margin, y, {align:'right'});
  y += 10;

  // Helper
  function sectionHeader(title) {
    doc.setFillColor(232, 245, 233);
    doc.roundedRect(margin, y, W - margin*2, 8, 2, 2, 'F');
    doc.setTextColor(0, 106, 78);
    doc.setFontSize(10);
    doc.setFont('helvetica','bold');
    doc.text(title, margin + 4, y + 5.5);
    y += 12;
  }

  function row(label, value) {
    doc.setTextColor(80, 80, 80);
    doc.setFontSize(9);
    doc.setFont('helvetica','bold');
    doc.text(label + ':', margin + 4, y);
    doc.setFont('helvetica','normal');
    doc.setTextColor(30, 30, 30);
    doc.text(String(value || '—'), margin + 50, y);
    y += 7;
  }

  sectionHeader('LOCATION');
  row('Division', d.division);
  row('District (Zila)', d.zila);
  row('Upazila', d.upazila);
  y += 3;

  sectionHeader('PERSONAL INFORMATION');
  row('Full Name', d.name);
  row('Mobile', d.phone);
  row('Email', d.email || '—');
  row('Age', d.age ? d.age + ' years' : '—');
  row('Institution', d.institution || '—');
  row('Class / Dept', d.classDept || '—');
  row('Profession', d.profession);
  row('Social Media', d.social || '—');
  y += 3;

  sectionHeader('SKILLS & AVAILABILITY');
  row('Skills', d.skills.length ? d.skills.join(', ') : '—');
  row('Weekly Time', d.availability || '—');
  y += 3;

  if (d.motivation) {
    sectionHeader('MOTIVATION');
    doc.setTextColor(50,50,50);
    doc.setFontSize(9);
    doc.setFont('helvetica','normal');
    var lines = doc.splitTextToSize(d.motivation, W - margin*2 - 8);
    lines.forEach(function(line) { doc.text(line, margin + 4, y); y += 6; });
    y += 3;
  }

  // Footer
  y = Math.max(y + 10, 260);
  doc.setFillColor(0, 106, 78);
  doc.rect(0, y, W, 1.5, 'F');
  y += 8;
  doc.setTextColor(0, 106, 78);
  doc.setFontSize(8);
  doc.setFont('helvetica','bold');
  doc.text('Nagorik Forum Bangladesh', margin, y);
  doc.setFont('helvetica','normal');
  doc.setTextColor(150,150,150);
  doc.text('join.nagorikforumbd@gmail.com', W - margin, y, {align:'right'});

  doc.save('Volunteer_' + (d.name.replace(/\s+/g,'_') || 'Registration') + '_' + refNo + '.pdf');
}

