<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>নান্দাইল উপজেলা পোর্টাল</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Noto+Serif+Bengali:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --royal-deep:    #1a3fa0;
    --royal-navy:    #2255c8;
    --royal-blue:    #3b7ef8;
    --royal-mid:     #5b97ff;
    --royal-bright:  #2255c8;
    --royal-light:   #1a3fa0;
    --gold:          #d97706;
    --gold-light:    #fbbf24;
    --white:         #1e293b;
    --off-white:     #f0f5ff;
    --glass:         rgba(59,126,248,0.06);
    --glass-border:  rgba(59,126,248,0.15);
    --shadow:        0 8px 40px rgba(59,126,248,0.12);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Hind Siliguri', sans-serif;
    background: #f4f7fe;
    color: #1e293b;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ═══════════════════════════════════════
     GLOBAL BACKGROUND MESH
  ═══════════════════════════════════════ */
  .page-bg {
    position: fixed; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 20%, rgba(59,126,248,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 90% 80%, rgba(34,85,200,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 100% 50% at 50% 0%, rgba(111,163,255,0.1) 0%, transparent 70%),
      linear-gradient(160deg, #f4f7fe 0%, #eef3ff 50%, #f8faff 100%);
  }
  .page-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%233b7ef8' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.6;
  }

  .wrapper { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  /* ═══════════════════════════════════════
     SECTION HEADER
  ═══════════════════════════════════════ */
  .section-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, rgba(217,119,6,0.1), rgba(217,119,6,0.04));
    border: 1px solid rgba(217,119,6,0.25);
    border-radius: 50px;
    padding: 6px 18px;
    font-size: 0.78rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .section-badge .dot {
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(1.4); }
  }

  /* ═══════════════════════════════════════
     SECTION 1 — SEARCH DIRECTORY
  ═══════════════════════════════════════ */
  .search-section {
    padding: 80px 0 60px;
    animation: fadeSlideUp 0.8s ease both;
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font-family: 'Noto Serif Bengali', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    background: linear-gradient(135deg, #0d2461 0%, var(--royal-blue) 60%, #2255c8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .section-subtitle {
    color: rgba(30,41,59,0.5);
    font-size: 0.95rem;
    margin-bottom: 36px;
  }

  /* Search Card */
  .search-card {
    background: #ffffff;
    border: 1px solid rgba(59,126,248,0.12);
    border-radius: 24px;
    padding: 36px 40px;
    box-shadow: 0 4px 32px rgba(59,126,248,0.1), inset 0 1px 0 rgba(255,255,255,0.9);
    margin-bottom: 40px;
    animation: fadeSlideUp 0.9s 0.1s ease both;
    position: relative;
    overflow: hidden;
  }
  .search-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--royal-blue), #5b97ff, var(--royal-blue));
    border-radius: 24px 24px 0 0;
  }

  .search-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 14px;
    align-items: end;
  }
  @media(max-width: 768px) {
    .search-grid { grid-template-columns: 1fr; }
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--royal-blue);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .form-group select,
  .form-group input {
    width: 100%;
    background: #f4f7fe;
    border: 1px solid rgba(59,126,248,0.2);
    border-radius: 12px;
    padding: 13px 16px;
    color: #1e293b;
    font-family: 'Hind Siliguri', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: all 0.3s;
    appearance: none;
    cursor: pointer;
  }
  .form-group select:focus,
  .form-group input:focus {
    border-color: var(--royal-blue);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(59,126,248,0.12);
  }
  .form-group select option { background: #fff; color: #1e293b; }

  .btn-search {
    background: linear-gradient(135deg, var(--royal-bright) 0%, var(--royal-mid) 100%);
    border: none;
    border-radius: 12px;
    padding: 13px 30px;
    color: #fff;
    font-family: 'Hind Siliguri', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    white-space: nowrap;
    box-shadow: 0 4px 24px rgba(59,126,248,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    transition: all 0.3s;
    position: relative; overflow: hidden;
  }
  .btn-search::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .btn-search:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(59,126,248,0.55); }
  .btn-search:hover::after { opacity: 1; }
  .btn-search:active { transform: translateY(0); }

  /* Quick Icons */
  .quick-links-title {
    font-size: 0.8rem;
    color: rgba(30,41,59,0.45);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .quick-links {
    display: flex; flex-wrap: wrap; gap: 12px;
    animation: fadeSlideUp 1s 0.2s ease both;
  }
  .quick-link {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    background: #ffffff;
    border: 1px solid rgba(59,126,248,0.12);
    border-radius: 16px;
    padding: 18px 22px;
    cursor: pointer;
    transition: all 0.3s;
    min-width: 90px;
    text-align: center;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(59,126,248,0.06);
  }
  .quick-link::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(59,126,248,0.06), rgba(26,63,160,0.04));
    opacity: 0; transition: opacity 0.3s;
  }
  .quick-link:hover { border-color: rgba(59,126,248,0.35); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(59,126,248,0.15); }
  .quick-link:hover::before { opacity: 1; }
  .quick-link .icon { font-size: 1.8rem; line-height: 1; }
  .quick-link .label {
    font-size: 0.75rem;
    color: rgba(30,41,59,0.7);
    font-weight: 600;
    line-height: 1.3;
  }

  /* ═══════════════════════════════════════
     SECTION 2 — NOTICE BOARD
  ═══════════════════════════════════════ */
  .notice-section {
    padding: 60px 0 80px;
    animation: fadeSlideUp 0.8s 0.15s ease both;
  }

  .notice-header {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap; gap: 16px;
  }

  .notice-tabs {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .tab-btn {
    background: #ffffff;
    border: 1px solid rgba(59,126,248,0.15);
    border-radius: 50px;
    padding: 7px 18px;
    font-family: 'Hind Siliguri', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(30,41,59,0.6);
    cursor: pointer;
    transition: all 0.25s;
    display: flex; align-items: center; gap: 6px;
    box-shadow: 0 1px 4px rgba(59,126,248,0.06);
  }
  .tab-btn.active,
  .tab-btn:hover {
    background: linear-gradient(135deg, var(--royal-blue), var(--royal-bright));
    border-color: transparent;
    color: #fff;
    box-shadow: 0 4px 16px rgba(59,126,248,0.3);
  }

  .btn-all {
    background: transparent;
    border: 1px solid rgba(217,119,6,0.4);
    border-radius: 8px;
    padding: 9px 20px;
    font-family: 'Hind Siliguri', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    cursor: pointer;
    transition: all 0.3s;
    display: flex; align-items: center; gap: 6px;
    text-decoration: none;
  }
  .btn-all:hover {
    background: rgba(217,119,6,0.08);
    border-color: var(--gold);
    box-shadow: 0 4px 16px rgba(217,119,6,0.15);
  }

  /* Notice Grid */
  .notice-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  .notice-card {
    background: #ffffff;
    border: 1px solid rgba(59,126,248,0.1);
    border-radius: 18px;
    padding: 24px 26px;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    animation: fadeSlideUp 0.7s ease both;
    box-shadow: 0 2px 16px rgba(59,126,248,0.06);
  }
  .notice-card:nth-child(1) { animation-delay: 0.1s; }
  .notice-card:nth-child(2) { animation-delay: 0.15s; }
  .notice-card:nth-child(3) { animation-delay: 0.2s; }
  .notice-card:nth-child(4) { animation-delay: 0.25s; }
  .notice-card:nth-child(5) { animation-delay: 0.3s; }
  .notice-card:nth-child(6) { animation-delay: 0.35s; }

  .notice-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(59,126,248,0.04), rgba(26,63,160,0.02));
    opacity: 0; transition: opacity 0.3s;
  }
  .notice-card:hover { border-color: rgba(59,126,248,0.25); transform: translateY(-4px); box-shadow: 0 16px 40px rgba(59,126,248,0.12), 0 0 0 1px rgba(59,126,248,0.1); }
  .notice-card:hover::before { opacity: 1; }

  /* Accent bar on left */
  .notice-card::after {
    content: '';
    position: absolute; top: 20px; left: 0; bottom: 20px; width: 3px;
    border-radius: 0 3px 3px 0;
    transition: height 0.3s;
  }
  .notice-card.type-tender::after  { background: linear-gradient(180deg, #3b7ef8, #6fa3ff); }
  .notice-card.type-tcb::after     { background: linear-gradient(180deg, #22c77a, #6eefc0); }
  .notice-card.type-budget::after  { background: linear-gradient(180deg, #f5c842, #ffe47a); }
  .notice-card.type-notice::after  { background: linear-gradient(180deg, #f5604a, #ff9a84); }
  .notice-card.type-education::after { background: linear-gradient(180deg, #a855f7, #d8b4fe); }
  .notice-card.type-govt::after    { background: linear-gradient(180deg, #0ea5e9, #7dd3fc); }

  .notice-top {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 12px; margin-bottom: 12px;
  }
  .notice-badge {
    display: inline-flex; align-items: center; gap: 5px;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .badge-tender    { background: rgba(59,126,248,0.15); color: #6fa3ff; border: 1px solid rgba(59,126,248,0.25); }
  .badge-tcb       { background: rgba(34,199,122,0.12); color: #6eefc0; border: 1px solid rgba(34,199,122,0.25); }
  .badge-budget    { background: rgba(245,200,66,0.12); color: var(--gold); border: 1px solid rgba(245,200,66,0.25); }
  .badge-notice    { background: rgba(245,96,74,0.12);  color: #ff9a84;  border: 1px solid rgba(245,96,74,0.25); }
  .badge-education { background: rgba(168,85,247,0.12); color: #d8b4fe;  border: 1px solid rgba(168,85,247,0.25); }
  .badge-govt      { background: rgba(14,165,233,0.12); color: #7dd3fc;  border: 1px solid rgba(14,165,233,0.25); }

  .notice-new-tag {
    background: var(--gold);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .notice-title {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    line-height: 1.45;
    margin-bottom: 8px;
  }
  .notice-desc {
    font-size: 0.85rem;
    color: rgba(30,41,59,0.55);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .notice-footer {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid rgba(59,126,248,0.08);
    padding-top: 12px;
    gap: 8px;
  }
  .notice-meta {
    display: flex; flex-direction: column; gap: 2px;
  }
  .notice-source {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--royal-blue);
  }
  .notice-date {
    font-size: 0.73rem;
    color: rgba(30,41,59,0.4);
  }
  .notice-arrow {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: rgba(59,126,248,0.08);
    border: 1px solid rgba(59,126,248,0.15);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
    color: var(--royal-blue);
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .notice-card:hover .notice-arrow {
    background: var(--royal-blue);
    border-color: var(--royal-blue);
    color: #fff;
    box-shadow: 0 4px 12px rgba(59,126,248,0.3);
  }

  /* Divider */
  .royal-divider {
    display: flex; align-items: center; gap: 16px;
    margin: 0 0 50px;
    opacity: 0.2;
  }
  .royal-divider::before, .royal-divider::after {
    content: ''; flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59,126,248,0.6), transparent);
  }
  .royal-divider span { font-size: 1rem; }

  /* Responsive */
  @media(max-width:600px) {
    .search-card { padding: 22px 18px; }
    .notice-grid { grid-template-columns: 1fr; }
    .notice-header { flex-direction: column; align-items: flex-start; }
    .quick-link { min-width: 75px; padding: 14px 14px; }
    .quick-link .icon { font-size: 1.5rem; }
  }
</style>
</head>
<body>

<div class="page-bg"></div>

<div class="wrapper">

  <!-- ══════════════════════════════════
       SECTION 1: SEARCH DIRECTORY
  ══════════════════════════════════ -->
  <section class="search-section">
    <div class="section-badge"><span class="dot"></span> নান্দাইল উপজেলা পোর্টাল</div>
    <h2 class="section-title">কোন প্রতিষ্ঠান বা সেবা খুঁজছেন?</h2>
    <p class="section-subtitle">বিভাগ, এলাকা ও প্রতিষ্ঠান নির্বাচন করে সহজেই খুঁজে নিন</p>

    <div class="search-card">
      <div class="search-grid">
        <div class="form-group">
          <label>বিভাগ / Category</label>
          <select>
            <option>সব বিভাগ</option>
            <option>শিক্ষা প্রতিষ্ঠান</option>
            <option>স্বাস্থ্যসেবা</option>
            <option>সরকারি দফতর</option>
            <option>ইউনিয়ন পরিষদ</option>
            <option>পৌরসভা</option>
            <option>ব্যাংক ও আর্থিক সেবা</option>
            <option>কৃষি সেবা</option>
          </select>
        </div>
        <div class="form-group">
          <label>এলাকা / Area</label>
          <select>
            <option>সব এলাকা</option>
            <option>পৌরসভা</option>
            <option>চরবেলতা ইউনিয়ন</option>
            <option>আচিন্তপুর ইউনিয়ন</option>
            <option>মুসুল্লি ইউনিয়ন</option>
            <option>রাজগাতি ইউনিয়ন</option>
            <option>কান্দিউড়া ইউনিয়ন</option>
            <option>শেরপুর ইউনিয়ন</option>
            <option>সিংরা ইউনিয়ন</option>
          </select>
        </div>
        <div class="form-group">
          <label>প্রতিষ্ঠানের ধরন</label>
          <select>
            <option>সব প্রতিষ্ঠান</option>
            <option>সরকারি স্কুল</option>
            <option>বেসরকারি স্কুল</option>
            <option>কলেজ / মাদ্রাসা</option>
            <option>উপজেলা পরিষদ</option>
            <option>ইউনিয়ন পরিষদ</option>
            <option>সরকারি হাসপাতাল</option>
            <option>কমিউনিটি ক্লিনিক</option>
          </select>
        </div>
        <button class="btn-search">🔍 এখনই খুঁজুন</button>
      </div>
    </div>

    <div class="quick-links-title">দ্রুত অ্যাক্সেস</div>
    <div class="quick-links">
      <a class="quick-link" href="#">
        <span class="icon">🏫</span>
        <span class="label">স্কুল / কলেজ</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🕌</span>
        <span class="label">মাদ্রাসা</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🏛️</span>
        <span class="label">উপজেলা পরিষদ</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🏘️</span>
        <span class="label">ইউনিয়ন পরিষদ</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🏙️</span>
        <span class="label">পৌরসভা</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🏥</span>
        <span class="label">হাসপাতাল</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">💊</span>
        <span class="label">কমিউনিটি ক্লিনিক</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🌾</span>
        <span class="label">কৃষি অফিস</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">🏦</span>
        <span class="label">ব্যাংক / বীমা</span>
      </a>
      <a class="quick-link" href="#">
        <span class="icon">👮</span>
        <span class="label">পুলিশ / থানা</span>
      </a>
    </div>
  </section>

  <div class="royal-divider"><span>✦</span></div>

  <!-- ══════════════════════════════════
       SECTION 2: NOTICE BOARD
  ══════════════════════════════════ -->
  <section class="notice-section">
