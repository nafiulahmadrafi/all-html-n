<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>\u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09aa\u09c2\u09b0\u09cd\u09a3 \u09ab\u09b0\u09cd\u09ae\u09b8\u09ae\u09c2\u09b9 \u2014 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09cb\u09b0\u09cd\u099f\u09be\u09b2</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green-deep: #1a5c3a;
  --green-mid:  #2d7d52;
  --green-pale: #e8f5ee;
  --green-mist: #f4faf7;
  --gold:       #c8a84b;
  --white:      #ffffff;
  --bg:         #f7faf8;
  --text-dark:  #0f2318;
  --text-mid:   #2e4d3a;
  --text-muted: #6b8576;
  --border:     #d5e8dc;
  --border-lt:  #eaf3ed;
  --red:        #c62828;
  --blue:       #1565c0;
  --orange:     #e65100;
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html { font-size: 16px; }
body {
  font-family: 'Hind Siliguri', sans-serif;
  background: var(--bg);
  color: var(--text-dark);
  min-height: 100vh;
}

/* \u2500\u2500 SEARCH BAR (sticky) \u2500\u2500 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  padding: 12px 16px 10px;
  box-shadow: 0 2px 8px rgba(26,92,58,0.08);
}
.search-inner {
  position: relative;
  margin-bottom: 10px;
}
.search-inner input {
  width: 100%;
  padding: 11px 16px 11px 42px;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 14px;
  font-family: 'Hind Siliguri', sans-serif;
  background: var(--green-mist);
  color: var(--text-dark);
  outline: none;
  transition: border 0.2s, background 0.2s;
}
.search-inner input:focus { border-color: var(--green-mid); background: #fff; }
.search-icon {
  position: absolute;
  left: 13px; top: 50%;
  transform: translateY(-50%);
  font-size: 17px;
  pointer-events: none;
}

/* Filter scroll row */
.filter-row {
  display: flex;
  gap: 7px;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 2px;
}
.filter-row::-webkit-scrollbar { display: none; }
.f-btn {
  flex-shrink: 0;
  padding: 7px 14px;
  border-radius: 20px;
  border: 1.5px solid var(--border);
  background: var(--white);
  font-size: 12.5px;
  font-weight: 600;
  font-family: 'Hind Siliguri', sans-serif;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.f-btn.active, .f-btn:active {
  background: var(--green-pale);
  border-color: var(--green-mid);
  color: var(--green-deep);
}

/* Result count */
.result-row {
  padding: 8px 16px 4px;
  font-size: 12.5px;
  color: var(--text-muted);
}
.result-row strong { color: var(--green-deep); }

/* \u2500\u2500 MAIN \u2500\u2500 */
.main { padding: 8px 12px 48px; max-width: 900px; margin: 0 auto; }

/* Section heading */
.sec-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 24px 0 10px;
}
.sec-icon {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.sec-head h2 {
  font-family: 'Noto Serif Bengali', serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--text-dark);
  flex: 1;
}
.sec-count {
  font-size: 11px;
  font-weight: 700;
  background: var(--green-pale);
  color: var(--green-deep);
  padding: 3px 9px;
  border-radius: 20px;
  white-space: nowrap;
}

/* \u2500\u2500 DESKTOP TABLE \u2500\u2500 */
.tbl-wrap {
  background: var(--white);
  border-radius: 14px;
  border: 1px solid var(--border);
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(26,92,58,0.06);
}
table {
  width: 100%;
  border-collapse: collapse;
}
thead { background: var(--green-deep); }
thead th {
  padding: 11px 14px;
  font-size: 11.5px;
  font-weight: 700;
  color: rgba(255,255,255,0.88);
  text-align: left;
  white-space: nowrap;
  letter-spacing: 0.3px;
}
tbody tr {
  border-bottom: 1px solid var(--border-lt);
  transition: background 0.12s;
}
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: var(--green-mist); }
td {
  padding: 12px 14px;
  font-size: 13px;
  color: var(--text-mid);
  vertical-align: middle;
}
.td-num { color: var(--text-muted); font-size: 11.5px; font-weight: 700; width: 30px; }
.form-name { font-weight: 600; color: var(--text-dark); font-size: 13.5px; line-height: 1.4; }
.form-name small { display: block; font-size: 11.5px; color: var(--text-muted); font-weight: 400; margin-top: 2px; }
.form-office { font-size: 12px; color: var(--text-muted); }

/* Category badges */
.cat { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:600; padding:3px 9px; border-radius:20px; white-space:nowrap; }
.c-id   { background:#e3f2fd; color:#1565c0; }
.c-land { background:#e8f5e9; color:#2e7d32; }
.c-tr   { background:#fff3e0; color:#e65100; }
.c-hlt  { background:#fce4ec; color:#c62828; }
.c-edu  { background:#f3e5f5; color:#6a1b9a; }
.c-biz  { background:#fff8e1; color:#f57f17; }
.c-tax  { background:#fbe9e7; color:#bf360c; }
.c-soc  { background:#e0f2f1; color:#00695c; }

/* Format badge */
.fmt { font-size:10px; font-weight:700; padding:3px 7px; border-radius:6px; letter-spacing:0.4px; white-space:nowrap; }
.f-pdf    { background:#ffebee; color:var(--red); }
.f-web    { background:#e8f5e9; color:#2e7d32; }
.f-both   { background:#fff3e0; color:var(--orange); }

/* Download buttons */
.dl {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 14px;
  border-radius: 9px;
  font-size: 12.5px;
  font-weight: 700;
  font-family: 'Hind Siliguri', sans-serif;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.15s, transform 0.15s;
}
.dl:active { opacity: 0.8; transform: scale(0.97); }
.dl-pdf  { background: var(--green-deep); color: #fff; }
.dl-web  { background: var(--blue); color: #fff; }
.dl-both { background: var(--gold); color: #2a1800; }

/* \u2500\u2500 MOBILE CARDS (hidden on desktop) \u2500\u2500 */
.card-list { display: none; }
.form-card {
  background: var(--white);
  border-radius: 14px;
  border: 1px solid var(--border);
  padding: 15px 16px;
  margin-bottom: 10px;
  box-shadow: 0 1px 5px rgba(26,92,58,0.06);
}
.card-top {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 10px;
}
.card-num {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  min-width: 24px;
  margin-top: 2px;
}
.card-name {
  flex: 1;
  font-size: 14px;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1.4;
}
.card-name small {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 400;
  margin-top: 3px;
}
.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
  margin-bottom: 12px;
}
.card-office {
  font-size: 11.5px;
  color: var(--text-muted);
  width: 100%;
  padding-left: 34px;
  margin-top: -4px;
  margin-bottom: 4px;
}
.card-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 700;
  font-family: 'Hind Siliguri', sans-serif;
  text-decoration: none;
  transition: opacity 0.15s;
}
.card-btn:active { opacity: 0.8; }
.cb-pdf  { background: var(--green-deep); color: #fff; }
.cb-web  { background: var(--blue); color: #fff; }
.cb-both { background: var(--gold); color: #2a1800; }

/* Empty state */
.empty {
  display: none;
  text-align: center;
  padding: 52px 20px;
}
.empty.show { display: block; }
.empty .e-ico { font-size: 44px; margin-bottom: 12px; }
.empty p { font-size: 15px; color: var(--text-muted); }

/* Info note */
.info-note {
  background: #fffde7;
  border: 1px solid #ffe082;
  border-radius: 12px;
  padding: 13px 15px;
  font-size: 12.5px;
  color: #6d4c00;
  line-height: 1.7;
  margin-bottom: 4px;
  display: flex;
  gap: 9px;
}
.info-note .ni { flex-shrink: 0; font-size: 16px; }

/* Bottom links */
.bottom-links {
  margin-top: 32px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 14px;
  