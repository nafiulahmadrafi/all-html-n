<script>
  function filterSection(type, btn) {
    document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');

    const sections = {
      health: 'section-health',
      pets: 'section-pets',
      edu: 'section-edu',
      license: 'section-license',
      infra: 'section-infra',
      disaster: 'section-disaster',
    };

    if (type === 'all') {
      document.querySelectorAll('.service-section').forEach(s => s.classList.remove('hidden'));
    } else {
      document.querySelectorAll('.service-section').forEach(s => s.classList.add('hidden'));
      const target = document.getElementById(sections[type]);
      if (target) target.classList.remove('hidden');
    }
    window.scrollTo({ top: 240, behavior: 'smooth' });
  }
</script>
