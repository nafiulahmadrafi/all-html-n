<title>Footer — Political Insights BD</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Bengali:wght@400;500;600;700&family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --green:     #006a4e;
    --green-mid: #008a65;
    --green-lt:  #e8f5f0;
    --green-ltr: #c8e8dc;
    --red:       #f42a41;
    --red-lt:    #fff0f2;
    --white:     #ffffff;
    --text:      #0d1f17;
    --text-mid:  #3a5445;
    --muted:     #7a9488;
    --border:    #daeee6;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: #f5f8f6; }

  /* ══ FOOTER ══ */
  .pibd-footer {
    background: #ffffff;
    border-top: 3px solid var(--green);
    width: 100%;
  }

  /* flag stripe top */
  .footer-flag {
    height: 4px;
    background: linear-gradient(90deg, var(--green) 50%, var(--red) 50%);
  }

  /* ── contact bar ── */
  .footer-contact-bar {
    background: var(--green);
    padding: .85rem 6vw;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  .contact-bar-left {
    font-family: 'Noto Serif Bengali', serif;
    font-size: .82rem; color: rgba(255,255,255,.85);
  }
  .contact-bar-right { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .contact-link {
    display: inline-flex; align-items: center; gap: .4rem;
    color: #fff; text-decoration: none; font-size: .8rem; font-weight: 600;
    padding: .3rem .85rem; border-radius: 20px;
    border: 1.5px solid rgba(255,255,255,.3);
    transition: background .2s, border-color .2s;
  }
  .contact-link:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.6); }
  .contact-link svg { width: 13px; height: 13px; }

  /* ── main body ── */
  .footer-body {
    padding: 3.5rem 6vw 2.5rem;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  /* brand col */
  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-size: 1.15rem; font-weight: 800; letter-spacing: .02em;
    color: var(--green); text-decoration: none;
    display: inline-block; margin-bottom: 1rem;
  }
  .footer-logo span { color: var(--red); }

  .footer-tagline {
    font-family: 'Noto Serif Bengali', serif;
    font-size: .82rem; color: var(--text-mid); line-height: 1.75;
    margin-bottom: 1.4rem; max-width: 260px;
  }

  /* social row */
  .footer-social { display: flex; gap: .55rem; flex-wrap: wrap; margin-top: .2rem; }
  .social-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    text-decoration: none; border: 1.5px solid var(--border);
    background: #fff; color: var(--text-mid);
    transition: all .22s cubic-bezier(.165,.84,.44,1);
  }
  .social-icon svg { width: 17px; height: 17px; }
  .social-icon:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,.1); }
  .social-icon.facebook:hover  { background: #1877f2; border-color: #1877f2; color: #fff; }
  .social-icon.youtube:hover   { background: #ff0000; border-color: #ff0000; color: #fff; }
  .social-icon.twitter:hover   { background: #000;    border-color: #000;    color: #fff; }
  .social-icon.linkedin:hover  { background: #0a66c2; border-color: #0a66c2; color: #fff; }
  .social-icon.whatsapp:hover  { background: #25d366; border-color: #25d366; color: #fff; }
  .social-icon.telegram:hover  { background: #229ed9; border-color: #229ed9; color: #fff; }
  .social-icon.email:hover     { background: var(--green); border-color: var(--green); color: #fff; }

  /* link cols */
  .footer-col h4 {
    font-family: 'Syne', sans-serif;
    font-size: .78rem; font-weight: 800; letter-spacing: .1em;
    text-transform: uppercase; color: var(--green);
    margin-bottom: 1.1rem;
    padding-bottom: .6rem;
    border-bottom: 2px solid var(--green-ltr);
  }

  .footer-links { list-style: none; display: flex; flex-direction: column; gap: .55rem; }
  .footer-links li a {
    text-decoration: none; font-size: .85rem; color: var(--text-mid);
    display: flex; align-items: center; gap: .45rem;
    transition: color .18s, gap .18s;
  }
  .footer-links li a:hover { color: var(--green); gap: .65rem; }
  .footer-links li a .link-arrow { font-size: .7rem; opacity: .5; transition: opacity .18s; }
  .footer-links li a:hover .link-arrow { opacity: 1; }

  /* sub-label inside col */
  .footer-sub-label {
    font-size: .68rem; font-weight: 800; letter-spacing: .12em;
    text-transform: uppercase; color: var(--muted);
    margin: .9rem 0 .4rem;
  }

  /* external badge */
  .ext-badge {
    display: inline-block;
    background: var(--red-lt); color: var(--red);
    font-size: .58rem; font-weight: 800; padding: .1rem .45rem;
    border-radius: 4px; margin-left: .3rem; vertical-align: middle;
    letter-spacing: .04em;
  }

  /* ── divider ── */
  .footer-divider {
    border: none; border-top: 1px solid var(--border);
    margin: 0 6vw;
  }

  /* ── bottom bar ── */
  .footer-bottom {
    padding: 1.2rem 6vw;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  .footer-copy { font-size: .76rem; color: var(--muted); }
  .footer-copy strong { color: var(--green); font-weight: 700; }
  .footer-bottom-links { display: flex; gap: 1.4rem; flex-wrap: wrap; }
  .footer-bottom-links a {
    font-size: .75rem; color: var(--muted);
    text-decoration: none; transition: color .18s;
  }
  .footer-bottom-links a:hover { color: var(--green); }
  .footer-made {
    font-size: .72rem; color: var(--muted);
    display: flex; align-items: center; gap: .3rem;
  }
  .footer-made .heart { color: var(--red); }

  /* ── responsive ── */
  @media (max-width: 900px) {
    .footer-body { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-body { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 5vw 2rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: .6rem; }
    .footer-contact-bar { flex-direction: column; align-items: flex-start; }
  }
</style>
