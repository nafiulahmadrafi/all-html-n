<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>২০২৬ নির্বাচনে তৃণমূল কৌশল | Political Insights BD</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Noto+Sans+Bengali:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
@font-face{font-family:'SolaimanLipi';src:url('https://fonts.maateen.me/solaiman-lipi/SolaimanLipi.woff2') format('woff2');font-weight:400;font-display:swap}
@font-face{font-family:'SolaimanLipi';src:url('https://fonts.maateen.me/solaiman-lipi/SolaimanLipi_Bold.woff2') format('woff2');font-weight:700 800 900;font-display:swap}
:root{
  --bg:#f5f3ee;--bg-alt:#faf8f4;--bg-pure:#ffffff;--surface:#eeeae2;--border:#e2ddd4;--border-s:#d5cfc5;
  --ink:#1a1710;--ink-2:#3a3428;--muted:#7a7060;--muted-l:#a09880;
  --gold:#b8922a;--gold-b:#d4a83a;--gold-pale:#fdf3d0;--gold-bg:#faf4e6;
  --royal:#0d1b3e;--royal-m:#1a3a7c;--royal-b:#2e5fad;
  --sh-sm:0 2px 12px rgba(26,23,16,.08);--sh-md:0 8px 32px rgba(26,23,16,.10);--sh-lg:0 20px 60px rgba(26,23,16,.13);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--surface)}::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* HEADER */
#main-header{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(245,243,238,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:all .3s}
.header-inner{max-width:1320px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:72px}
.logo-wrap{display:flex;align-items:center;gap:13px;text-decoration:none}
.logo-main{font-family:'Cinzel',serif;font-size:1.08rem;font-weight:700;background:linear-gradient(135deg,var(--gold),#c49a20);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:.04em}
.logo-sub{font-size:.6rem;color:var(--muted-l);letter-spacing:2.5px;text-transform:uppercase;margin-top:3px}
nav{display:flex;align-items:center;gap:2px}
nav a{color:var(--ink-2);font-size:.83rem;font-weight:500;padding:7px 14px;border-radius:8px;text-decoration:none;transition:all .22s}
nav a:hover,.nav-active{color:var(--gold)!important;background:var(--gold-bg)!important}
.nav-cta{background:linear-gradient(135deg,var(--royal),#0a1428)!important;color:#fff!important;font-weight:700!important;padding:8px 22px!important;border-radius:100px!important;box-shadow:0 4px 16px rgba(13,27,62,.2)!important;margin-left:6px}
.nav-cta:hover{transform:translateY(-1px);color:#fff!important}
.ham{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.ham span{width:24px;height:2px;background:var(--gold);border-radius:2px;transition:.3s}
#mobile-menu{display:none;position:fixed;top:72px;left:0;right:0;background:rgba(245,243,238,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);z-index:999;padding:20px 28px;flex-direction:column;gap:4px;box-shadow:var(--sh-md)}
#mobile-menu.open{display:flex}
#mobile-menu a{color:var(--ink-2);font-size:.9rem;padding:10px 14px;border-radius:8px;text-decoration:none}
#mobile-menu a:hover{background:var(--gold-bg);color:var(--gold)}
#mobile-menu .mob-cta{background:var(--royal);color:#fff!important;border-radius:10px;margin-top:8px;text-align:center}

/* READ PROGRESS */
#progress-bar{position:fixed;top:72px;left:0;width:0%;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-b));z-index:999;transition:width .1s}

/* BREADCRUMB */
.breadcrumb{background:var(--bg-pure);border-bottom:1px solid var(--border);padding:14px 28px}
.breadcrumb-inner{max-width:1320px;margin:0 auto;display:flex;align-items:center;gap:8px;font-size:.78rem;color:var(--muted)}
.breadcrumb a{color:var(--muted);text-decoration:none;transition:.2s}
.breadcrumb a:hover{color:var(--gold)}
.breadcrumb-cur{color:var(--ink);font-weight:600;max-width:300px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}

/* HERO */
.post-hero{background:linear-gradient(148deg,#0d1b3e 0%,#122250 38%,#0f1c40 65%,#091228 100%);padding:120px 28px 72px;position:relative;overflow:hidden}
.post-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 55% 65% at 68% 38%,rgba(212,168,58,.08),transparent 55%)}
.post-hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:60px 60px}
.post-hero-inner{max-width:860px;margin:0 auto;position:relative;z-index:2}
.post-cat-badge{display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:4px 12px;border-radius:100px;margin-bottom:16px;background:#dcfce7;color:#166534}
.post-title{font-size:clamp(1.8rem,4vw,3rem);line-height:1.2;color:#fff;font-weight:800;letter-spacing:-.02em;margin-bottom:20px;animation:fade-up .8s ease both}
@keyframes fade-up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.post-meta-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.post-author{display:flex;align-items:center;gap:10px}
.post-author-img{width:40px;height:40px;border-radius:50%;background:rgba(212,168,58,.12);border:1.5px solid rgba(212,168,58,.3);display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.post-author-name{font-size:.85rem;font-weight:700;color:#fff}
.post-author-role{font-size:.7rem;color:rgba(255,255,255,.45)}
.post-meta-sep{width:4px;height:4px;background:rgba(255,255,255,.2);border-radius:50%}
.post-meta-item{font-size:.78rem;color:rgba(255,255,255,.5);display:flex;align-items:center;gap:5px}
.post-meta-item span{color:rgba(255,255,255,.7);font-weight:500}

/* SHARE FLOAT (desktop) */
.share-float{position:sticky;top:120px;display:flex;flex-direction:column;align-items:center;gap:10px;padding-top:8px}
.share-label{font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted-l);margin-bottom:4px}
.share-btn{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700;text-decoration:none;cursor:pointer;border:1.5px solid var(--border);background:var(--bg-pure);color:var(--muted);transition:all .22s;box-shadow:var(--sh-sm)}
.share-btn:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
.share-btn.fb:hover{background:#1877f2;border-color:#1877f2;color:#fff}
.share-btn.tw:hover{background:#000;border-color:#000;color:#fff}
.share-btn.wa:hover{background:#25d366;border-color:#25d366;color:#fff}
.share-btn.li:hover{background:#0a66c2;border-color:#0a66c2;color:#fff}
.share-btn.cp:hover{background:var(--gold);border-color:var(--gold);color:#fff}
.share-divider{width:1px;height:20px;background:var(--border);margin:2px 0}

/* MAIN LAYOUT */
.post-layout{max-width:1320px;margin:0 auto;padding:52px 28px 80px;display:grid;grid-template-columns:52px 1fr 320px;gap:36px;align-items:start}

/* ARTICLE */
article{background:var(--bg-pure);border:1px solid var(--border);border-radius:20px;overflow:hidden;box-shadow:var(--sh-sm)}
.article-img{height:380px;background:linear-gradient(135deg,#1e6640,#28a05e);display:flex;align-items:center;justify-content:center;font-size:6rem;position:relative}
.article-img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(to top,var(--bg-pure),transparent)}

/* INLINE SHARE (mobile) */
.share-inline{display:none;background:var(--bg-alt);border-bottom:1px solid var(--border);padding:14px 28px;flex-wrap:wrap;gap:8px;align-items:center}
.share-inline-label{font-size:.72rem;color:var(--muted);font-weight:600;margin-right:4px}
.share-inline .share-btn{width:36px;height:36px;border-radius:8px;font-size:.78rem}

.article-body{padding:36px 40px}
.article-intro{font-size:1.05rem;color:var(--ink-2);line-height:2;font-weight:500;margin-bottom:28px;padding-left:20px;border-left:3px solid var(--gold)}
.article-body h2{font-size:1.25rem;font-weight:800;color:var(--royal);margin:32px 0 14px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.article-body h3{font-size:1.05rem;font-weight:700;color:var(--ink-2);margin:24px 0 10px}
.article-body p{font-size:.93rem;color:var(--muted);line-height:2.05;margin-bottom:18px}
.article-body strong{color:var(--ink);font-weight:700}
.article-body ul,.article-body ol{margin:0 0 20px 0;padding-left:22px}
.article-body li{font-size:.9rem;color:var(--muted);line-height:1.95;margin-bottom:8px}
.article-body blockquote{background:var(--gold-bg);border-left:4px solid var(--gold);border-radius:0 10px 10px 0;padding:18px 22px;margin:24px 0;font-style:italic;font-size:.95rem;color:var(--ink-2);line-height:1.85}
.article-body blockquote cite{display:block;margin-top:8px;font-size:.75rem;font-style:normal;color:var(--muted);font-weight:700}
.callout{background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:18px 20px;margin:24px 0;display:flex;gap:13px}
.callout-ico{font-size:1.3rem;flex-shrink:0;margin-top:2px}
.callout-text{font-size:.87rem;color:#1e3a5f;line-height:1.85}
.callout-text strong{color:#0d1b3e}

/* TAGS & SHARE BOTTOM */
.article-footer{padding:24px 40px 32px;border-top:1px solid var(--border)}
.article-tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;align-items:center}
.article-tags-label{font-size:.72rem;font-weight:700;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-right:4px}
.article-tag{padding:5px 13px;background:var(--bg);border:1.5px solid var(--border);border-radius:100px;font-size:.75rem;color:var(--muted);transition:.2s;cursor:pointer}
.article-tag:hover{border-color:var(--gold);color:var(--gold)}
.share-bottom{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.share-bottom-label{font-size:.78rem;color:var(--muted);font-weight:600}
.share-bottom-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:.78rem;font-weight:700;text-decoration:none;transition:.2s;cursor:pointer;border:1.5px solid transparent}
.sbb-fb{background:#e7f0fd;color:#1877f2;border-color:#bfdbfe}
.sbb-fb:hover{background:#1877f2;color:#fff}
.sbb-tw{background:#e7e7e7;color:#333;border-color:#d1d5db}
.sbb-tw:hover{background:#000;color:#fff;border-color:#000}
.sbb-wa{background:#e8fdf0;color:#128c7e;border-color:#bbf7d0}
.sbb-wa:hover{background:#25d366;color:#fff;border-color:#25d366}
.sbb-cp{background:var(--gold-bg);color:var(--gold);border-color:rgba(184,146,42,.3)}
.sbb-cp:hover{background:var(--gold);color:#fff}

/* AUTHOR BOX */
.author-box{margin-top:0;background:var(--bg-alt);border:1px solid var(--border);border-radius:16px;padding:28px;display:flex;gap:20px;align-items:flex-start;box-shadow:var(--sh-sm)}
.author-avatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--royal),#1a3a7c);border:2px solid rgba(212,168,58,.25);display:flex;align-items:center;justify-content:center;font-size:1.8rem;flex-shrink:0}
.author-name{font-size:1rem;font-weight:800;color:var(--royal);margin-bottom:3px}
.author-role{font-size:.72rem;color:var(--gold);font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px}
.author-bio{font-size:.82rem;color:var(--muted);line-height:1.82}
.author-socials{display:flex;gap:8px;margin-top:12px}
.author-social{width:30px;height:30px;border-radius:7px;background:var(--bg-pure);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.75rem;color:var(--muted);text-decoration:none;transition:.2s}
.author-social:hover{background:var(--gold-bg);border-color:rgba(184,146,42,.3);color:var(--gold)}

/* COMMENTS */
.comments-section{margin-top:0;background:var(--bg-pure);border:1px solid var(--border);border-radius:20px;overflow:hidden;box-shadow:var(--sh-sm)}
.comments-header{padding:22px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.comments-title{font-size:1rem;font-weight:800;color:var(--royal)}
.comments-count{font-size:.75rem;background:var(--gold-bg);border:1px solid rgba(184,146,42,.22);color:var(--gold);font-weight:700;padding:2px 10px;border-radius:100px}
.comment-form{padding:24px 28px;border-bottom:1px solid var(--border);background:var(--bg-alt)}
.comment-form-title{font-size:.8rem;font-weight:700;color:var(--royal);margin-bottom:16px;letter-spacing:.5px}
.cf-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.cf-input{width:100%;background:var(--bg-pure);border:1.5px solid var(--border);border-radius:10px;padding:10px 14px;font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;font-size:.85rem;color:var(--ink);outline:none;transition:.25s}
.cf-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,146,42,.1)}
.cf-textarea{width:100%;background:var(--bg-pure);border:1.5px solid var(--border);border-radius:10px;padding:11px 14px;font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;font-size:.85rem;color:var(--ink);outline:none;transition:.25s;height:100px;resize:vertical;margin-bottom:12px;display:block}
.cf-textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,146,42,.1)}
.cf-submit{background:linear-gradient(135deg,var(--royal),#162d6a);color:#fff;padding:10px 28px;border-radius:100px;font-weight:800;font-size:.85rem;border:none;cursor:pointer;transition:.25s}
.cf-submit:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(13,27,62,.25)}

.comment-list{padding:0 28px}
.comment{padding:20px 0;border-bottom:1px solid var(--border);display:flex;gap:14px}
.comment:last-child{border-bottom:none}
.comment-avatar{width:40px;height:40px;border-radius:50%;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.comment-body{flex:1}
.comment-head{display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap}
.comment-name{font-size:.85rem;font-weight:700;color:var(--ink)}
.comment-badge{font-size:.6rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 8px;border-radius:100px}
.comment-date{font-size:.7rem;color:var(--muted-l)}
.comment-text{font-size:.83rem;color:var(--muted);line-height:1.82}
.comment-actions{display:flex;gap:12px;margin-top:10px}
.comment-action{font-size:.72rem;color:var(--muted-l);cursor:pointer;display:flex;align-items:center;gap:4px;transition:.2s}
.comment-action:hover{color:var(--gold)}
.comment-reply{padding:14px 0 14px 54px}
.comment-reply .comment{padding:14px 16px;background:var(--bg-alt);border:1px solid var(--border);border-radius:12px;border-bottom:none;margin-bottom:8px}

/* SIDEBAR */
.sidebar{display:flex;flex-direction:column;gap:22px;position:sticky;top:90px}
.sidebar-widget{background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;padding:22px;box-shadow:var(--sh-sm)}
.widget-title{font-size:.68rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.toc-item{display:flex;gap:10px;padding:7px 10px;border-radius:8px;cursor:pointer;transition:.2s;text-decoration:none}
.toc-item:hover{background:var(--bg-alt)}
.toc-num{font-size:.68rem;font-weight:800;color:var(--gold);width:18px;flex-shrink:0;font-family:'Cinzel',serif;margin-top:2px}
.toc-text{font-size:.78rem;color:var(--ink-2);line-height:1.5}
.toc-item.active .toc-text{color:var(--gold);font-weight:600}

.related-item{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);text-decoration:none;transition:.2s}
.related-item:last-child{border-bottom:none}
.related-item:hover .related-title{color:var(--gold)}
.related-thumb{width:64px;height:52px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.5rem}
.related-title{font-size:.79rem;font-weight:600;color:var(--ink);line-height:1.5;transition:.2s}
.related-meta{font-size:.68rem;color:var(--muted-l);margin-top:3px}

/* CTA WIDGET */
.cta-widget{background:linear-gradient(135deg,var(--royal),#142254);border-radius:16px;padding:22px;position:relative;overflow:hidden;text-align:center}
.cta-widget::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 20%,rgba(212,168,58,.1),transparent)}
.cta-widget::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.cta-widget-title{font-size:.93rem;font-weight:800;color:#fff;margin-bottom:8px;position:relative;z-index:1}
.cta-widget-sub{font-size:.76rem;color:rgba(255,255,255,.5);line-height:1.7;margin-bottom:16px;position:relative;z-index:1}
.cta-widget-btn{display:inline-block;background:linear-gradient(135deg,var(--gold-b),#a07020);color:#0a0a14;padding:10px 22px;border-radius:100px;font-weight:800;font-size:.82rem;text-decoration:none;position:relative;z-index:1;transition:.25s}
.cta-widget-btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(184,146,42,.35)}

/* RELATED SECTION */
.related-section{max-width:1320px;margin:0 auto;padding:0 28px 80px}
.related-section-title{font-size:1.4rem;font-weight:800;color:var(--royal);margin-bottom:24px;display:flex;align-items:center;gap:10px}
.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.rel-card{background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:all .28s;text-decoration:none;display:block;box-shadow:var(--sh-sm)}
.rel-card:hover{transform:translateY(-4px);border-color:rgba(184,146,42,.25);box-shadow:var(--sh-lg)}
.rel-thumb{height:140px;display:flex;align-items:center;justify-content:center;font-size:2.8rem}
.rel-body{padding:18px 20px}
.rel-cat{font-size:.62rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:2px 9px;border-radius:100px;display:inline-block;margin-bottom:8px}
.rel-title{font-size:.9rem;font-weight:700;color:var(--royal);line-height:1.5;margin-bottom:8px}
.rel-meta{font-size:.7rem;color:var(--muted-l);display:flex;gap:8px}

/* FOOTER */
footer{background:var(--royal);color:rgba(255,255,255,.75);padding:64px 0 28px;border-top:4px solid var(--gold)}
.footer-inner{max-width:1320px;margin:0 auto;padding:0 28px}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
.footer-brand{display:flex;flex-direction:column;gap:16px}
.footer-logo{display:flex;align-items:center;gap:12px;text-decoration:none}
.footer-logo-text .main{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;background:linear-gradient(135deg,var(--gold-b),#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.footer-logo-text .sub{font-size:.6rem;color:rgba(255,255,255,.3);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.footer-desc{font-size:.79rem;color:rgba(255,255,255,.45);line-height:1.85;max-width:300px}
.footer-socials{display:flex;gap:10px;margin-top:4px}
.social-btn{width:36px;height:36px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.45);font-size:.85rem;text-decoration:none;transition:.25s}
.social-btn:hover{background:rgba(212,168,58,.15);color:var(--gold-b);border-color:rgba(212,168,58,.3)}
.footer-col h4{font-size:.7rem;font-weight:700;color:var(--gold-b);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:16px}
.footer-links{display:flex;flex-direction:column;gap:9px}
.footer-links a{font-size:.79rem;color:rgba(255,255,255,.38);text-decoration:none;transition:.22s;display:flex;align-items:center;gap:6px}
.footer-links a::before{content:'›';color:rgba(212,168,42,.4);font-size:1rem}
.footer-links a:hover{color:var(--gold-b);transform:translateX(3px)}
.footer-divider{height:1px;background:rgba(255,255,255,.08);margin-bottom:24px}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
