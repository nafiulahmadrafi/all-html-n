<script>
// HEADER SCROLL
window.addEventListener('scroll',()=>{
  const h=document.getElementById('main-header');
  h.style.background=window.scrollY>60?'rgba(245,243,238,.97)':'rgba(245,243,238,.92)';
  h.style.boxShadow=window.scrollY>60?'0 4px 24px rgba(26,23,16,.1)':'none';
  // Progress bar
  const doc=document.documentElement;
  const progress=(doc.scrollTop||document.body.scrollTop)/(doc.scrollHeight-doc.clientHeight)*100;
  document.getElementById('progress-bar').style.width=progress+'%';
  // TOC active
  document.querySelectorAll('h2[id]').forEach(s=>{
    const toc=document.querySelector(`.toc-item[href="#${s.id}"]`);
    if(toc){
      const rect=s.getBoundingClientRect();
      if(rect.top<=120 && rect.top>-200) toc.classList.add('active');
      else toc.classList.remove('active');
    }
  });
});

function toggleMenu(){document.getElementById('mobile-menu').classList.toggle('open')}

function sharePost(platform){
  const url=encodeURIComponent(window.location.href);
  const title=encodeURIComponent('২০২৬ নির্বাচনে তৃণমূল কৌশল কেন সবচেয়ে গুরুত্বপূর্ণ | PIBBD');
  const urls={
    fb:`https://www.facebook.com/sharer/sharer.php?u=${url}`,
    tw:`https://twitter.com/intent/tweet?url=${url}&text=${title}`,
    wa:`https://wa.me/?text=${title}%20${url}`,
    li:`https://www.linkedin.com/shareArticle?mini=true&url=${url}&title=${title}`
  };
  if(urls[platform]) window.open(urls[platform],'_blank','width=600,height=400');
}

function copyLink(){
  navigator.clipboard.writeText(window.location.href).then(()=>{
    const t=document.getElementById('copy-toast');
    t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'),2500);
  });
}

let commentData=[
  {name:'সাইফুল ইসলাম',emoji:'👨',badge:'পাঠক',badgeStyle:'background:#dcfce7;color:#166534',date:'১৬ মার্চ, ২০২৬',text:'অত্যন্ত তথ্যবহুল লেখা।',likes:5,reply:{name:'ড. আরিফ হোসেন',emoji:'👨‍💼',badge:'লেখক',badgeStyle:'background:var(--gold-bg);color:var(--gold)',date:'১৬ মার্চ, ২০২৬',text:'আপনার মন্তব্যের জন্য ধন্যবাদ।',likes:3}},
  {name:'রাহেলা বেগম',emoji:'👩',badge:'নতুন পাঠক',badgeStyle:'background:#eef2ff;color:#3730a3',date:'১৭ মার্চ, ২০২৬',text:'নারী ভোটারদের বিষয়টা আরও বিস্তারিত হলে ভালো হতো।',likes:8}
];

function likeComment(btn){
  const countEl=btn.querySelector('span');
  let n=parseInt(countEl.textContent.replace(/[()]/g,''));
  btn.style.color='var(--gold)';
  countEl.textContent=`(${n+1})`;
}

function showReplyForm(btn){
  // Remove any existing reply forms
  document.querySelectorAll('.inline-reply-form').forEach(f=>f.remove());
  const comment=btn.closest('.comment');
  const form=document.createElement('div');
  form.className='inline-reply-form';
  form.style.cssText='margin-top:12px;display:flex;gap:10px';
  form.innerHTML=`<input type="text" class="cf-input" style="flex:1" placeholder="জবাব লিখুন..." id="inlineReply">
    <button class="cf-submit" onclick="postReply(this)" style="padding:10px 16px;border-radius:8px;white-space:nowrap">পাঠান</button>`;
  comment.querySelector('.comment-body').appendChild(form);
  form.querySelector('input').focus();
}

function postReply(btn){
  const val=btn.previousElementSibling.value.trim();
  if(!val) return;
  btn.closest('.inline-reply-form').remove();
  // just show toast for demo
  const t=document.getElementById('copy-toast');
  t.textContent='✓ জবাব পাঠানো হয়েছে!';
  t.classList.add('show');
  setTimeout(()=>{t.classList.remove('show');t.textContent='✓ লিংক কপি হয়েছে!'},2500);
}

function submitComment(){
  const name=document.getElementById('commentName').value.trim();
  const text=document.getElementById('commentText').value.trim();
  if(!name||!text){alert('নাম ও মন্তব্য আবশ্যক।');return}
  const list=document.getElementById('commentList');
  const div=document.createElement('div');
  div.className='comment';
  div.style.animation='fade-up .4s ease both';
  div.innerHTML=`<div class="comment-avatar">👤</div>
    <div class="comment-body">
      <div class="comment-head">
        <div class="comment-name">${name}</div>
        <div class="comment-badge" style="background:#dcfce7;color:#166534">নতুন</div>
        <div class="comment-date">এইমাত্র</div>
      </div>
      <p class="comment-text">${text}</p>
      <div class="comment-actions"><span class="comment-action" onclick="likeComment(this)">👍 পছন্দ <span>(0)</span></span></div>
    </div>`;
  list.appendChild(div);
  document.getElementById('commentName').value='';
  document.getElementById('commentText').value='';
  document.getElementById('commentEmail').value='';
  // Update count
  const cnt=document.getElementById('commentCount');
  const n=list.querySelectorAll('.comment:not(.comment-reply .comment)').length;
  const bn=x=>String(x).replace(/\d/g,d=>'০১২৩৪৫৬৭৮৯'[d]);
  cnt.textContent=`${bn(n)} টি মন্তব্য`;
  div.scrollIntoView({behavior:'smooth',block:'center'});
}
</script>
