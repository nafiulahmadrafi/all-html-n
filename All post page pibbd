const POSTS_PER_PAGE = 6;
let currentCat = 'all';
let currentSearch = '';
let currentPage = 1;
let currentSort = 'latest';
let filteredPosts = [...allPosts];

function getFilteredAndSorted(){
  let posts = allPosts.filter(p=>{
    const matchCat = currentCat==='all' || p.cat===currentCat;
    const q = currentSearch.toLowerCase();
    const matchSearch = !q || p.title.includes(q) || p.author.toLowerCase().includes(q) || p.cat.includes(q) || p.excerpt.includes(q);
    return matchCat && matchSearch;
  });
  if(currentSort==='popular') posts.sort((a,b)=>b.views-a.views);
  else if(currentSort==='oldest') posts.sort((a,b)=>new Date(a.date_val)-new Date(b.date_val));
  else posts.sort((a,b)=>new Date(b.date_val)-new Date(a.date_val));
  return posts;
}

function renderPosts(){
  filteredPosts = getFilteredAndSorted();
  const total = filteredPosts.length;
  const totalPages = Math.ceil(total/POSTS_PER_PAGE);
  if(currentPage>totalPages) currentPage=1;
  const start=(currentPage-1)*POSTS_PER_PAGE, end=start+POSTS_PER_PAGE;
  const pagePosts=filteredPosts.slice(start,end);

  const grid=document.getElementById('blogGrid');
  const noRes=document.getElementById('noResults');
  const countEl=document.getElementById('resultCount');

  // Bangla numerals
  const bn=n=>String(n).replace(/\d/g,d=>'০১২৩৪৫৬৭৮৯'[d]);
  countEl.textContent=bn(total);

  if(total===0){grid.innerHTML='';noRes.classList.add('show')}
  else{noRes.classList.remove('show');
    grid.innerHTML=pagePosts.map(p=>`
      <a href="single-post.html" class="blog-card">
        <div class="blog-card-thumb" style="background:${p.bg}">${p.emoji}</div>
        <div class="blog-card-body">
          <div class="blog-card-top">
            <div class="blog-cat" style="${p.catStyle}">${p.cat}</div>
            <div class="blog-card-title">${p.title}</div>
            <div class="blog-card-excerpt">${p.excerpt}</div>
          </div>
          <div class="blog-card-meta">
            <div class="blog-author-img">${p.authorEmoji}</div>
            <div>
              <div class="blog-author-name">${p.author}</div>
              <div class="blog-date">${p.date}</div>
            </div>
            <div class="blog-read-time">⏱ ${p.readTime}</div>
          </div>
        </div>
      </a>`).join('');
  }
  renderPagination(totalPages);
}

function renderPagination(totalPages){
  const pg=document.getElementById('pagination');
  if(totalPages<=1){pg.innerHTML='';return}
  const bn=n=>String(n).replace(/\d/g,d=>'০১২৩৪৫৬৭৮৯'[d]);
  let html='';
  html+=`<span class="pg-btn${currentPage===1?' disabled':''}" onclick="gotoPage(${currentPage-1})">← আগে</span>`;
  for(let i=1;i<=totalPages;i++){
    if(totalPages>7&&i>2&&i<totalPages-1&&Math.abs(i-currentPage)>1){
      if(i===3||i===totalPages-2) html+=`<span class="pg-dots">…</span>`;
    } else {
      html+=`<span class="pg-btn${i===currentPage?' active':''}" onclick="gotoPage(${i})">${bn(i)}</span>`;
    }
  }
  html+=`<span class="pg-btn${currentPage===totalPages?' disabled':''}" onclick="gotoPage(${currentPage+1})">পরে →</span>`;
  pg.innerHTML=html;
}

function gotoPage(p){
  const total=Math.ceil(filteredPosts.length/POSTS_PER_PAGE);
  if(p<1||p>total) return;
  currentPage=p;
  renderPosts();
  document.querySelector('.filter-bar').scrollIntoView({behavior:'smooth',block:'start'});
}

function filterByCategory(el){
  document.querySelectorAll('.cat-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  currentCat=el.dataset.cat;
  currentPage=1;
  renderPosts();
}

function filterByName(cat){
  currentCat=cat;
  currentPage=1;
  document.querySelectorAll('.cat-pill').forEach(p=>{
    p.classList.toggle('active',p.dataset.cat===cat);
  });
  renderPosts();
}

function filterPosts(){
  currentSearch=document.getElementById('searchInput').value;
  currentPage=1;
  renderPosts();
}

function sortPosts(val){currentSort=val;currentPage=1;renderPosts()}

window.addEventListener('scroll',()=>{
  const h=document.getElementById('main-header');
  h.style.background=window.scrollY>60?'rgba(245,243,238,.97)':'rgba(245,243,238,.92)';
  h.style.boxShadow=window.scrollY>60?'0 4px 24px rgba(26,23,16,.1)':'none';
});
function toggleMenu(){document.getElementById('mobile-menu').classList.toggle('open')}

renderPosts();
</script>
