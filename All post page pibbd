<header id="main-header">
  <div class="header-inner">
    <a href="pibbd-homepage-light.html" class="logo-wrap">
      <div style="width:48px;height:48px;background:linear-gradient(135deg,var(--royal),#142254);border:1.5px solid rgba(212,168,58,.3);border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-weight:700;font-size:1.1rem;color:var(--gold-b)">P</div>
      <div class="logo-text-wrap">
