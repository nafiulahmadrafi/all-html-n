<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-grid"></div>
  <div class="page-hero-inner">
    <div class="page-badge">✦ ব্লগ ও বিশ্লেষণ</div>
    <h1 class="page-title">রাজনৈতিক জ্ঞান ও<br><span style="background:linear-gradient(135deg,var(--gold-b),#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">গভীর বিশ্লেষণ</span></h1>
