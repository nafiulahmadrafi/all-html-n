<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ব্লগ ও বিশ্লেষণ | Political Insights BD</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Noto+Sans+Bengali:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
@font-face{font-family:'SolaimanLipi';src:url('https://fonts.maateen.me/solaiman-lipi/SolaimanLipi.woff2') format('woff2');font-weight:400;font-display:swap}
@font-face{font-family:'SolaimanLipi';src:url('https://fonts.maateen.me/solaiman-lipi/SolaimanLipi_Bold.woff2') format('woff2');font-weight:700 800 900;font-display:swap}
:root{
  --bg:#f5f3ee;--bg-alt:#faf8f4;--bg-pure:#ffffff;--surface:#eeeae2;--border:#e2ddd4;--border-s:#d5cfc5;
  --ink:#1a1710;--ink-2:#3a3428;--muted:#7a7060;--muted-l:#a09880;
  --gold:#b8922a;--gold-b:#d4a83a;--gold-pale:#fdf3d0;--gold-bg:#faf4e6;
  --royal:#0d1b3e;--royal-m:#1a3a7c;--royal-b:#2e5fad;
  --sh-sm:0 2px 12px rgba(26,23,16,.08);--sh-md:0 8px 32px rgba(26,23,16,.10);--sh-lg:0 20px 60px rgba(26,23,16,.13);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--surface)}::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* HEADER */
#main-header{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(245,243,238,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:all .3s}
.header-inner{max-width:1320px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:72px}
.logo-wrap{display:flex;align-items:center;gap:13px;text-decoration:none}
.logo-main{font-family:'Cinzel',serif;font-size:1.08rem;font-weight:700;background:linear-gradient(135deg,var(--gold),#c49a20);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:.04em}
.logo-sub{font-size:.6rem;color:var(--muted-l);letter-spacing:2.5px;text-transform:uppercase;margin-top:3px}
nav{display:flex;align-items:center;gap:2px}
nav a{color:var(--ink-2);font-size:.83rem;font-weight:500;padding:7px 14px;border-radius:8px;text-decoration:none;transition:all .22s}
nav a:hover,.nav-active{color:var(--gold)!important;background:var(--gold-bg)!important}
.nav-cta{background:linear-gradient(135deg,var(--royal),#0a1428)!important;color:#fff!important;font-weight:700!important;padding:8px 22px!important;border-radius:100px!important;box-shadow:0 4px 16px rgba(13,27,62,.2)!important;margin-left:6px}
.nav-cta:hover{transform:translateY(-1px);color:#fff!important}
.ham{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.ham span{width:24px;height:2px;background:var(--gold);border-radius:2px;transition:.3s}
#mobile-menu{display:none;position:fixed;top:72px;left:0;right:0;background:rgba(245,243,238,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);z-index:999;padding:20px 28px;flex-direction:column;gap:4px;box-shadow:var(--sh-md)}
#mobile-menu.open{display:flex}
#mobile-menu a{color:var(--ink-2);font-size:.9rem;padding:10px 14px;border-radius:8px;text-decoration:none}
#mobile-menu a:hover{background:var(--gold-bg);color:var(--gold)}
#mobile-menu .mob-cta{background:var(--royal);color:#fff!important;border-radius:10px;margin-top:8px;text-align:center}

/* PAGE HERO */
.page-hero{background:linear-gradient(148deg,#0d1b3e 0%,#122250 38%,#0f1c40 65%,#091228 100%);padding:140px 28px 80px;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 55% 65% at 68% 38%,rgba(212,168,58,.08),transparent 55%)}
.page-hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:60px 60px}
.page-hero-inner{max-width:1320px;margin:0 auto;position:relative;z-index:2;text-align:center}
.page-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(212,168,58,.12);border:1px solid rgba(212,168,58,.35);color:#f5d878;padding:7px 20px;border-radius:100px;font-size:10.5px;letter-spacing:3px;text-transform:uppercase;font-weight:700;margin-bottom:22px;animation:fade-up .7s ease both}
.page-title{font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.1;color:#fff;font-weight:800;letter-spacing:-.02em;margin-bottom:16px;animation:fade-up .8s .1s ease both}
.page-sub{font-size:1rem;color:rgba(255,255,255,.55);max-width:580px;margin:0 auto;line-height:1.9;animation:fade-up .8s .2s ease both}
@keyframes fade-up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* BREADCRUMB */
.breadcrumb{background:var(--bg-pure);border-bottom:1px solid var(--border);padding:14px 28px}
.breadcrumb-inner{max-width:1320px;margin:0 auto;display:flex;align-items:center;gap:8px;font-size:.78rem;color:var(--muted)}
.breadcrumb a{color:var(--muted);text-decoration:none;transition:.2s}
.breadcrumb a:hover{color:var(--gold)}
.breadcrumb-cur{color:var(--ink);font-weight:600}

/* BLOG MAIN */
.blog-main{max-width:1320px;margin:0 auto;padding:52px 28px 80px;display:grid;grid-template-columns:1fr 320px;gap:44px;align-items:start}

/* SEARCH & FILTER BAR */
.filter-bar{background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;padding:22px 24px;margin-bottom:28px;box-shadow:var(--sh-sm)}
.search-wrap{position:relative;margin-bottom:16px}
.search-input{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;padding:11px 16px 11px 44px;font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;font-size:.87rem;color:var(--ink);outline:none;transition:.25s}
.search-input:focus{border-color:var(--gold);background:#fff;box-shadow:0 0 0 3px rgba(184,146,42,.1)}
.search-ico{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted-l);font-size:.95rem;pointer-events:none}
.filter-label{font-size:.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.cat-pills{display:flex;flex-wrap:wrap;gap:8px}
.cat-pill{padding:6px 14px;border-radius:100px;font-size:.78rem;font-weight:600;border:1.5px solid var(--border);background:var(--bg);color:var(--muted);cursor:pointer;transition:all .2s;white-space:nowrap}
.cat-pill:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-bg)}
.cat-pill.active{background:var(--royal);border-color:var(--royal);color:#fff}

/* RESULTS INFO */
.results-info{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px}
.results-count{font-size:.8rem;color:var(--muted)}
.results-count strong{color:var(--ink)}
.sort-select{background:var(--bg-pure);border:1.5px solid var(--border);border-radius:8px;padding:7px 12px;font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;font-size:.78rem;color:var(--ink);outline:none;cursor:pointer}

/* BLOG CARDS */
.blog-grid{display:flex;flex-direction:column;gap:20px}
.blog-card{background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;overflow:hidden;display:grid;grid-template-columns:200px 1fr;transition:all .28s;text-decoration:none;box-shadow:var(--sh-sm)}
.blog-card:hover{transform:translateY(-3px);border-color:rgba(184,146,42,.25);box-shadow:var(--sh-lg)}
.blog-card-thumb{min-height:160px;display:flex;align-items:center;justify-content:center;font-size:3rem;flex-shrink:0}
.blog-card-body{padding:22px 24px;display:flex;flex-direction:column;justify-content:space-between}
.blog-card-top{flex:1}
.blog-cat{display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:3px 10px;border-radius:100px;margin-bottom:8px}
.blog-card-title{font-size:1rem;font-weight:700;color:var(--royal);line-height:1.5;margin-bottom:8px}
.blog-card-excerpt{font-size:.8rem;color:var(--muted);line-height:1.78;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.blog-card-meta{display:flex;align-items:center;gap:12px;margin-top:14px;padding-top:12px;border-top:1px solid var(--border)}
.blog-author-img{width:28px;height:28px;border-radius:50%;background:var(--gold-bg);border:1px solid rgba(184,146,42,.25);display:flex;align-items:center;justify-content:center;font-size:.8rem}
.blog-author-name{font-size:.73rem;font-weight:600;color:var(--ink-2)}
.blog-date{font-size:.7rem;color:var(--muted-l)}
.blog-read-time{font-size:.7rem;color:var(--muted-l);margin-left:auto;background:var(--bg);border:1px solid var(--border);border-radius:100px;padding:2px 9px}

/* NO RESULTS */
.no-results{text-align:center;padding:60px 20px;background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;display:none}
.no-results.show{display:block}
.no-results-ico{font-size:3rem;margin-bottom:12px}
.no-results-text{font-size:.93rem;color:var(--muted)}

/* PAGINATION */
.pagination{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:36px;flex-wrap:wrap}
.pg-btn{min-width:38px;height:38px;display:inline-flex;align-items:center;justify-content:center;border-radius:9px;font-size:.83rem;font-weight:600;cursor:pointer;transition:all .2s;border:1.5px solid var(--border);background:var(--bg-pure);color:var(--muted);text-decoration:none;padding:0 10px}
.pg-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-bg)}
.pg-btn.active{background:var(--royal);border-color:var(--royal);color:#fff}
.pg-btn.disabled{opacity:.35;cursor:default;pointer-events:none}
.pg-dots{color:var(--muted-l);font-size:.85rem;padding:0 4px}

/* SIDEBAR */
.sidebar{display:flex;flex-direction:column;gap:22px;position:sticky;top:90px}
.sidebar-widget{background:var(--bg-pure);border:1px solid var(--border);border-radius:16px;padding:22px;box-shadow:var(--sh-sm)}
.widget-title{font-size:.68rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.trending-item{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);text-decoration:none;transition:.2s}
.trending-item:last-child{border-bottom:none;padding-bottom:0}
.trending-item:hover .trending-title{color:var(--gold)}
.trending-num{width:24px;height:24px;flex-shrink:0;background:var(--gold-bg);border:1px solid rgba(184,146,42,.22);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;color:var(--gold);font-family:'Cinzel',serif}
.trending-title{font-size:.79rem;font-weight:600;color:var(--ink);line-height:1.55;transition:.2s}
.trending-meta{font-size:.68rem;color:var(--muted-l);margin-top:3px}

.cat-list{display:flex;flex-direction:column;gap:8px}
.cat-row{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-radius:8px;cursor:pointer;transition:.2s;text-decoration:none}
.cat-row:hover{background:var(--bg)}
.cat-row-name{font-size:.82rem;color:var(--ink-2);font-weight:500}
.cat-row-count{font-size:.7rem;font-weight:700;color:var(--gold);background:var(--gold-bg);border:1px solid rgba(184,146,42,.2);border-radius:100px;padding:1px 9px}

.tag-cloud{display:flex;flex-wrap:wrap;gap:7px}
.tag{padding:5px 12px;background:var(--bg);border:1.5px solid var(--border);border-radius:100px;font-size:.72rem;font-weight:500;color:var(--muted);cursor:pointer;transition:.2s}
.tag:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-bg)}

/* NEWSLETTER */
.newsletter-widget{background:linear-gradient(135deg,var(--royal),#142254);border-radius:16px;padding:22px;position:relative;overflow:hidden}
.newsletter-widget::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 80% 20%,rgba(212,168,58,.1),transparent)}
.newsletter-widget::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.nw-title{font-size:.9rem;font-weight:800;color:#fff;margin-bottom:8px;position:relative;z-index:1}
.nw-sub{font-size:.76rem;color:rgba(255,255,255,.55);line-height:1.7;margin-bottom:14px;position:relative;z-index:1}
.nw-input{width:100%;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);border-radius:8px;padding:9px 13px;font-family:'SolaimanLipi','Noto Sans Bengali',sans-serif;font-size:.82rem;color:#fff;outline:none;margin-bottom:10px;position:relative;z-index:1}
.nw-input::placeholder{color:rgba(255,255,255,.35)}
.nw-input:focus{border-color:rgba(212,168,58,.5)}
.nw-btn{width:100%;background:linear-gradient(135deg,var(--gold-b),#a07020);color:#0a0a14;padding:9px;border-radius:8px;font-weight:800;font-size:.82rem;border:none;cursor:pointer;position:relative;z-index:1;transition:.25s}
.nw-btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(184,146,42,.35)}

/* FOOTER */
footer{background:var(--royal);color:rgba(255,255,255,.75);padding:64px 0 28px;border-top:4px solid var(--gold)}
.footer-inner{max-width:1320px;margin:0 auto;padding:0 28px}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
.footer-brand{display:flex;flex-direction:column;gap:16px}
.footer-logo{display:flex;align-items:center;gap:12px;text-decoration:none}
.footer-logo-text .main{font-family:'Cinzel',serif;font-size:1rem;font-weight:700;background:linear-gradient(135deg,var(--gold-b),#f0d060);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.footer-logo-text .sub{font-size:.6rem;color:rgba(255,255,255,.3);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.footer-desc{font-size:.79rem;color:rgba(255,255,255,.45);line-height:1.85;max-width:300px}
.footer-socials{display:flex;gap:10px;margin-top:4px}
.social-btn{width:36px;height:36px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.45);font-size:.85rem;text-decoration:none;transition:.25s}
.social-btn:hover{background:rgba(212,168,58,.15);color:var(--gold-b);border-color:rgba(212,168,58,.3)}
.footer-col h4{font-size:.7rem;font-weight:700;color:var(--gold-b);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:16px}
.footer-links{display:flex;flex-direction:column;gap:9px}
.footer-links a{font-size:.79rem;color:rgba(255,255,255,.38);text-decoration:none;transition:.22s;display:flex;align-items:center;gap:6px}
.footer-links a::before{content:'›';color:rgba(212,168,42,.4);font-size:1rem}
.footer-links a:hover{color:var(--gold-b);transform:translateX(3px)}
.footer-divider{height:1px;background:rgba(255,255,255,.08);margin-bottom:24px}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.footer-copy{font-size:.74rem;color:rgba(255,255,255,.28)}
.footer-copy span{color:var(--gold-b);opacity:.8}
.footer-bottom-links{display:flex;gap:20px}
.footer-bottom-links a{font-size:.72rem;color:rgba(255,255,255,.22);text-decoration:none;transition:.22s}
.footer-bottom-links a:hover{color:var(--gold-b)}

@media(max-width:1100px){.blog-main{grid-template-columns:1fr}.sidebar{position:static;display:grid;grid-template-columns:1fr 1fr;gap:18px}}
@media(max-width:768px){
  nav,.ham-hide{display:none}.ham{display:flex}
  .blog-main{padding:32px 18px 60px}
  .blog-card{grid-template-columns:1fr}.blog-card-thumb{height:120px}
  .sidebar{grid-template-columns:1fr}
  .footer-top{grid-template-columns:1fr 1fr;gap:24px}
}
</style>
</head>
<body>

