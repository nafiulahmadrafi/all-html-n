  </div>
</section>

<div class="breadcrumb">
  <div class="breadcrumb-inner">
    <a href="pibbd-homepage-light.html">হোম</a>
    <span style="color:var(--muted-l)">›</span>
    <span class="breadcrumb-cur">ব্লগ</span>
  </div>
</div>

<!-- BLOG MAIN -->
<div class="blog-main">
  <!-- LEFT: POSTS -->
  <div>
    <!-- FILTER BAR -->
    <div class="filter-bar">
      <div class="search-wrap">
        <span class="search-ico">🔍</span>
        <input type="text" class="search-input" id="searchInput" placeholder="ব্লগ খুঁজুন... (শিরোনাম, বিষয় বা লেখক)" oninput="filterPosts()">
      </div>
      <div class="filter-label">ক্যাটাগরি অনুযায়ী ফিল্টার করুন</div>
      <div class="cat-pills">
        <div class="cat-pill active" data-cat="all" onclick="filterByCategory(this)">সকল</div>
        <div class="cat-pill" data-cat="তৃণমূল" onclick="filterByCategory(this)">তৃণমূল</div>
        <div class="cat-pill" data-cat="বিশ্লেষণ" onclick="filterByCategory(this)">বিশ্লেষণ</div>
        <div class="cat-pill" data-cat="ঝুঁকি" onclick="filterByCategory(this)">ঝুঁকি</div>
        <div class="cat-pill" data-cat="নির্বাচন" onclick="filterByCategory(this)">নির্বাচন</div>
        <div class="cat-pill" data-cat="কৌশল" onclick="filterByCategory(this)">কৌশল</div>
        <div class="cat-pill" data-cat="গবেষণা" onclick="filterByCategory(this)">গবেষণা</div>
        <div class="cat-pill" data-cat="ডিজিটাল" onclick="filterByCategory(this)">ডিজিটাল</div>
      </div>
    </div>

