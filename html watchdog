DEPARTMENT SPENDING:
- Infrastructure & Roads: Approved ₦1.2B, Spent ₦780M — ON TRACK
- Education: Approved ₦800M, Spent ₦490M — ON TRACK  
- Healthcare: Approved ₦720M, Spent ₦738M — OVERRUN by 2.8%
- Water & Sanitation: Approved ₦200M, Spent ₦308M — OVERRUN by 55% (CRITICAL)
- Agriculture: Approved ₦380M, Spent ₦88M — UNDERUTILIZED 50%
- Social Services: Approved ₦500M, Spent ₦210M — UNDERUTILIZED 46%

TENDER STATUS (24 active):
- 7 tenders exceeding 90-day legal maximum
- 3 duplicate tenders detected
- 11 completed on time
- Notable overdues: TND-2024-001 (127 days), TND-2024-004 (164 days), TND-2024-006 (102 days)

CORRUPTION FLAGS:
1. CRITICAL: Water & Sanitation budget overrun ₦110M without authorization
2. CRITICAL: Duplicate tender award for borehole drilling — double mobilization paid (TND-089 & TND-112, ₦238M)
3. CRITICAL: Ghost project — Market Renovation, ₦60M paid, 12% done, contractor missing 38 days
4. CRITICAL: Tender splitting (4 awards) to avoid ₦50M competitive bidding threshold — all to related entities (AceFurniture family)
5. HIGH: End-of-quarter rush spending in March — ₦418M (74% above average), 6 contracts in last 3 days
6. HIGH: Single contractor NovaBuild Ltd holds 34% of all contracts, director on procurement committee
7. MEDIUM: 5 contracts missing performance bonds totalling ₦780M

FIELD WORK:
- 18 active sites, 6 delayed, 2 stalled/abandoned
- Market Renovation: stalled 38 days, 12% progress
- Bridge X-4: stalled 31 days, 45% progress
- Zone 4 Boreholes: 28% progress, supervisor last seen 18 days ago
`;

async function runAIAnalysis() {
  const btn = document.getElementById('analyzeBtn');
  const output = document.getElementById('aiOutput');
  btn.disabled = true;
  btn.textContent = '⏳ ANALYZING...';
  output.innerHTML = '<div class="ai-loading">Scanning all data for corruption patterns <div class="ai-loading-dots"><span></span><span></span><span></span></div></div>';

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{
          role: "user",
          content: `You are a senior government anti-corruption auditor and forensic financial analyst. Analyze the following government budget and tender data and provide a structured corruption risk assessment. Be specific, factual, and actionable. Use plain text with clear sections.

${DATA_CONTEXT}

Provide:
1. EXECUTIVE SUMMARY (2-3 sentences on overall risk level)
2. TOP 3 MOST URGENT ISSUES (with estimated financial exposure)
3. SUSPICIOUS PATTERNS (cross-referencing multiple data points)
4. RECOMMENDED IMMEDIATE ACTIONS (numbered list)
5. OVERALL CORRUPTION RISK SCORE: X/100

Be direct and specific. Format clearly with section headers.`
        }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(b => b.text || "").join("") || "No response received.";
    output.style.fontStyle = 'normal';
    output.style.color = 'var(--text)';

    // Typed output
    let i = 0;
    output.textContent = '';
    const interval = setInterval(() => {
      if (i < text.length) {
        output.textContent += text[i++];
        output.scrollTop = output.scrollHeight;
      } else {
        clearInterval(interval);
      }
    }, 10);

  } catch (e) {
    output.innerHTML = `<span style="color:var(--danger)">Error: ${e.message}. Please check your connection.</span>`;
  }

  btn.disabled = false;
  btn.textContent = '🔄 RE-RUN ANALYSIS';
}

async function runCustomQuery() {
  const query = document.getElementById('customQuery').value.trim();
  if (!query) { document.getElementById('customQuery').focus(); return; }

  const output = document.getElementById('aiOutput');
  output.innerHTML = '<div class="ai-loading">Processing query <div class="ai-loading-dots"><span></span><span></span><span></span></div></div>';

  // Scroll to AI panel
  document.querySelectorAll('.tab')[4].click();

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{
          role: "user",
          content: `You are a government anti-corruption monitoring AI. Here is the full dataset:

${DATA_CONTEXT}

User query: ${query}

Answer concisely and specifically based only on the data provided. If the query involves corruption risks, be direct about what the data shows.`
        }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(b => b.text || "").join("") || "No response.";
    output.style.fontStyle = 'normal';
    output.style.color = 'var(--text)';
    let i = 0;
    output.textContent = '';
    const interval = setInterval(() => {
      if (i < text.length) { output.textContent += text[i++]; output.scrollTop = output.scrollHeight; }
      else clearInterval(interval);
    }, 8);
  } catch(e) {
    output.innerHTML = `<span style="color:var(--danger)">Error: ${e.message}</span>`;
  }
}

function addTender() {
  const name = document.getElementById('newTenderName').value.trim();
  const value = document.getElementById('newTenderValue').value.trim();
  const contractor = document.getElementById('newTenderContractor').value.trim();
  const days = parseInt(document.getElementById('newTenderDays').value) || 0;
  const result = document.getElementById('addResult');

  if (!name || !contractor) { result.textContent = '⚠ Please fill in tender name and contractor.'; result.style.color = 'var(--warn)'; return; }

  const flags = [];
  if (days > 90) flags.push('🚨 EXCEEDS MAX 90-DAY LIMIT');
  if (days > 60) flags.push('⚠ APPROACHING MAX TIME');
  if (parseInt(value?.replace(/,/g,'')) > 2000000000) flags.push('⚠ HIGH VALUE — ENHANCED SCRUTINY REQUIRED');

  const tbody = document.getElementById('tenderTableBody');
  const newId = 'TND-2025-' + String(tbody.children.length + 1).padStart(3,'0');
  const statusBadge = days > 90 ? '<span class="badge danger">OVERDUE</span>' : days > 60 ? '<span class="badge warn">AT RISK</span>' : '<span class="badge ok">ACTIVE</span>';
  const row = `<tr><td>${newId}</td><td>${name}</td><td>${contractor}</td><td>${value || 'TBD'}</td><td style="color:${days>90?'var(--danger)':days>60?'var(--warn)':'var(--ok)'}">${days}</td><td>90</td><td>${statusBadge}</td></tr>`;
  tbody.insertAdjacentHTML('afterbegin', row);

  result.style.color = flags.length ? 'var(--warn)' : 'var(--ok)';
  result.textContent = flags.length ? '⚠ FLAGS: ' + flags.join(' | ') : '✓ Added successfully. No immediate flags detected.';

  document.getElementById('newTenderName').value = '';
  document.getElementById('newTenderValue').value = '';
  document.getElementById('newTenderContractor').value = '';
  document.getElementById('newTenderDays').value = '';
}

// Allow Enter on custom query to submit
document.getElementById('customQuery').addEventListener('keydown', e => {
  if (e.key === 'Enter' && e.ctrlKey) runCustomQuery();
});
</script>
