<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Political Insights BD — Part 1: Header, Hero & Impact</title>
<meta name="description" content="Bangladesh's leading political analysis, policy research, and strategic consulting platform.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;700;800&family=Noto+Serif+Bengali:wght@400;600;700&family=Hind+Siliguri:wght@300;400;500;600;700&family=Tiro+Bangla:ital@0;1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════ */
:root {
  --green:#006A4E;--green-d:#004f3a;--green-l:#e6f2ee;--green-ll:#f0f8f5;
  --red:#F42A41;--red-d:#c41f31;--red-l:#fff0f1;
  --white:#ffffff;--off-white:#f9fafb;--ink:#0d1117;--ink-soft:#1a2332;
  --gray:#5a6474;--gray-l:#8a95a3;
  --border:1px solid #dee2e8;--border-d:2px solid var(--ink);
  --shadow-sm:0 2px 8px rgba(0,0,0,.07);--shadow-md:0 8px 32px rgba(0,0,0,.10);
  --radius-sm:4px;--radius:8px;--radius-lg:14px;
  --header-h:84px;--header-s:62px;
  --T:0.3s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--ink);overflow-x:hidden;padding-top:var(--header-h);}
img{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}
button{cursor:pointer;font-family:inherit;}

/* ═══ HEADER ═══ */
#hdr{position:fixed;top:0;left:0;right:0;height:var(--header-h);z-index:9999;background:transparent;transition:background var(--T),height var(--T),box-shadow var(--T),border-bottom var(--T);border-bottom:1px solid transparent;}
#hdr.scrolled{background:rgba(255,255,255,.97);backdrop-filter:blur(18px) saturate(180%);-webkit-backdrop-filter:blur(18px) saturate(180%);height:var(--header-s);border-bottom:var(--border);box-shadow:0 2px 20px rgba(0,106,78,.08);}
.hdr-inner{max-width:1360px;width:92%;margin:0 auto;height:100%;display:flex;align-items:center;justify-content:space-between;gap:2rem;}
.hdr-logo img{height:54px;width:auto;transition:height var(--T),filter var(--T);filter:brightness(0) invert(1);}
#hdr.scrolled .hdr-logo img{height:42px;filter:none;}
.hdr-nav{display:flex;align-items:center;gap:1.6rem;}
.hdr-nav a{font-size:11.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.92);position:relative;padding-bottom:3px;white-space:nowrap;transition:color var(--T);}
#hdr.scrolled .hdr-nav a{color:var(--ink);}
.hdr-nav a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--green);transition:width .25s ease;}
.hdr-nav a:hover::after{width:100%;}
.hdr-nav a:hover{color:var(--green)!important;}
.hdr-cta{background:var(--red);color:#fff!important;padding:9px 20px;font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;border-radius:var(--radius-sm);border:none;transition:background var(--T),transform .15s;white-space:nowrap;}
.hdr-cta::after{display:none!important;}
.hdr-cta:hover{background:var(--red-d);transform:translateY(-2px);}
.ham-btn{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:6px;}
.ham-btn span{display:block;width:26px;height:2px;background:#fff;border-radius:2px;transition:background var(--T),transform .3s;}
#hdr.scrolled .ham-btn span{background:var(--ink);}
.ham-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.ham-btn.open span:nth-child(2){opacity:0;}
.ham-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mob-wa-btn{display:none;align-items:center;gap:6px;background:#25D366;color:#fff;border:none;border-radius:var(--radius-sm);padding:7px 10px;font-size:10px;font-weight:800;white-space:nowrap;text-decoration:none;transition:background var(--T),transform .15s;flex-shrink:0;}
.mob-wa-btn:hover{background:#1da851;transform:translateY(-1px);}
.mob-wa-icon{width:18px;height:18px;flex-shrink:0;}
.mob-nav{display:none;position:fixed;top:var(--header-s);left:0;right:0;background:#fff;border-bottom:2px solid var(--green);box-shadow:var(--shadow-md);flex-direction:column;padding:1rem 5%;z-index:9998;animation:slideDown .25s ease;}
.mob-nav.open{display:flex;}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:none;}}
.mob-nav a{font-size:.9rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink);padding:.8rem 0;border-bottom:var(--border);display:flex;align-items:center;gap:.6rem;}
.mob-nav a:last-child{border:none;}
.mob-nav a:hover{color:var(--green);}

/* ═══ HERO ═══ */
#hdr:not(.scrolled) .hdr-nav a{color:var(--ink)!important;}
#hdr:not(.scrolled) .hdr-logo img{filter:none!important;}
#hdr:not(.scrolled) .ham-btn span{background:var(--ink)!important;}
#hero{background:var(--white);min-height:calc(100vh - var(--header-h));display:flex;flex-direction:column;position:relative;overflow:hidden;border-bottom:3px solid var(--green);}
/* Multi-layer gradient background */
#hero::before{content:'';position:absolute;inset:0;background:
  radial-gradient(ellipse 60% 70% at 85% 30%,rgba(0,106,78,.09) 0%,transparent 70%),
  radial-gradient(ellipse 45% 55% at 10% 80%,rgba(244,42,65,.06) 0%,transparent 65%),
  radial-gradient(circle 400px at 70% 60%,rgba(0,106,78,.04) 0%,transparent 100%),
  radial-gradient(circle 300px at 20% 30%,rgba(244,42,65,.03) 0%,transparent 100%);
  pointer-events:none;z-index:0;}
/* PIBD watermark */
#hero::after{content:'PIBD';position:absolute;right:-2rem;bottom:-1rem;font-family:'Playfair Display',serif;font-size:clamp(8rem,18vw,18rem);font-weight:900;color:rgba(0,106,78,.04);line-height:1;pointer-events:none;z-index:0;letter-spacing:-.04em;}

/* ═══ HERO BACKGROUND GRAPHICS ═══ */
.hero-bg-graphics{position:absolute;inset:0;pointer-events:none;z-index:0;overflow:hidden;}

/* Large rotating circle — BD flag inspired */
.hero-bg-circle-1{position:absolute;top:8%;right:5%;width:420px;height:420px;border-radius:50%;border:1.5px solid rgba(0,106,78,.06);animation:heroRotate 60s linear infinite;}
.hero-bg-circle-2{position:absolute;top:12%;right:9%;width:340px;height:340px;border-radius:50%;border:1.5px dashed rgba(0,106,78,.05);animation:heroRotate 45s linear infinite reverse;}
.hero-bg-circle-3{position:absolute;bottom:10%;left:3%;width:280px;height:280px;border-radius:50%;border:1.5px solid rgba(244,42,65,.05);animation:heroRotate 50s linear infinite;}

/* Red circle — flag reference */
.hero-bg-red-circle{position:absolute;top:18%;right:14%;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(244,42,65,.06) 0%,rgba(244,42,65,.02) 50%,transparent 70%);animation:heroPulse 8s ease-in-out infinite;}

/* Floating dots */
.hero-dot{position:absolute;border-radius:50%;animation:heroFloat 6s ease-in-out infinite;}
.hero-dot-1{width:8px;height:8px;background:rgba(0,106,78,.12);top:20%;left:12%;animation-delay:0s;animation-duration:7s;}
.hero-dot-2{width:6px;height:6px;background:rgba(244,42,65,.15);top:35%;right:20%;animation-delay:1s;animation-duration:5s;}
.hero-dot-3{width:10px;height:10px;background:rgba(0,106,78,.08);bottom:25%;left:8%;animation-delay:2s;animation-duration:8s;}
.hero-dot-4{width:5px;height:5px;background:rgba(244,42,65,.1);top:60%;right:8%;animation-delay:0.5s;animation-duration:6s;}
.hero-dot-5{width:7px;height:7px;background:rgba(0,106,78,.1);top:15%;left:45%;animation-delay:3s;animation-duration:9s;}
.hero-dot-6{width:4px;height:4px;background:rgba(244,42,65,.12);bottom:35%;right:35%;animation-delay:1.5s;animation-duration:7s;}
.hero-dot-7{width:9px;height:9px;background:rgba(0,106,78,.06);bottom:15%;left:40%;animation-delay:4s;animation-duration:6.5s;}

/* Geometric grid lines */
.hero-grid-lines{position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(0,106,78,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,106,78,.025) 1px,transparent 1px);
  background-size:80px 80px;
  mask-image:radial-gradient(ellipse 70% 60% at 75% 40%,black 0%,transparent 70%);
  -webkit-mask-image:radial-gradient(ellipse 70% 60% at 75% 40%,black 0%,transparent 70%);}

/* Corner decorative triangles */
.hero-corner-tl{position:absolute;top:0;left:0;width:0;height:0;border-left:120px solid rgba(0,106,78,.04);border-bottom:120px solid transparent;}
.hero-corner-br{position:absolute;bottom:0;right:0;width:0;height:0;border-right:160px solid rgba(244,42,65,.03);border-top:160px solid transparent;}

/* Diagonal accent line */
.hero-diag-line{position:absolute;top:0;right:38%;width:1px;height:100%;background:linear-gradient(180deg,transparent 0%,rgba(0,106,78,.06) 30%,rgba(0,106,78,.06) 70%,transparent 100%);transform:rotate(15deg);transform-origin:top center;}

/* Cross/Plus marks */
.hero-cross{position:absolute;width:16px;height:16px;opacity:.12;}
.hero-cross::before,.hero-cross::after{content:'';position:absolute;background:var(--green);}
.hero-cross::before{width:16px;height:1.5px;top:50%;left:0;transform:translateY(-50%);}
.hero-cross::after{width:1.5px;height:16px;left:50%;top:0;transform:translateX(-50%);}
.hero-cross-1{top:25%;left:25%;}
.hero-cross-2{top:70%;left:55%;opacity:.08;}
.hero-cross-3{top:45%;right:12%;opacity:.1;width:12px;height:12px;}
.hero-cross-3::before{width:12px;}
.hero-cross-3::after{height:12px;}

/* Small diamond shapes */
.hero-diamond{position:absolute;width:10px;height:10px;border:1.5px solid rgba(0,106,78,.1);transform:rotate(45deg);animation:heroFloat 7s ease-in-out infinite;}
.hero-diamond-1{top:30%;right:28%;animation-delay:2s;}
.hero-diamond-2{bottom:20%;left:18%;animation-delay:0s;border-color:rgba(244,42,65,.1);}
.hero-diamond-3{top:55%;left:35%;animation-delay:3.5s;width:7px;height:7px;}

/* Animations */
@keyframes heroRotate{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
@keyframes heroPulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.15);opacity:.6;}}
@keyframes heroFloat{0%,100%{transform:translateY(0) translateX(0);}25%{transform:translateY(-12px) translateX(5px);}50%{transform:translateY(-6px) translateX(-4px);}75%{transform:translateY(-15px) translateX(3px);}}
.hero-flag-stripe{position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--green) 60%,var(--red) 60%);z-index:1;}
.hero-grid{max-width:1360px;width:92%;margin:0 auto;flex:1;display:grid;grid-template-columns:1.15fr 1fr;gap:0;align-items:center;padding:4.5rem 0 4rem;position:relative;z-index:1;}
.hero-left{padding-right:4.5rem;border-right:1.5px solid var(--green-l);}
.hero-eyebrow{display:flex;align-items:center;gap:.7rem;margin-bottom:1.6rem;flex-wrap:wrap;}
.hero-eyebrow-bn{font-family:'Noto Serif Bengali',serif;font-size:13px;font-weight:700;color:var(--green);letter-spacing:.02em;}
.hero-eyebrow-divider{width:4px;height:4px;border-radius:50%;background:var(--red);flex-shrink:0;}
.hero-eyebrow-en{font-size:10px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:var(--gray);}
.hero-title{margin-bottom:1.6rem;line-height:1;}
.ht-line-en{display:block;font-family:'Playfair Display',serif;font-size:clamp(3rem,5.5vw,5.6rem);font-weight:900;letter-spacing:-.03em;color:var(--ink);line-height:.95;}
.ht-line-en .hl-g{color:var(--green);}
.ht-line-en .hl-r{color:var(--red);font-style:italic;}
.ht-line-bn{display:block;font-family:'Noto Serif Bengali',serif;font-size:clamp(1.5rem,2.8vw,2.6rem);font-weight:700;color:var(--gray);line-height:1.4;margin-top:.35rem;letter-spacing:.01em;}
.ht-line-bn strong{font-weight:900;color:var(--green);}
.hero-rule{display:flex;align-items:center;gap:.8rem;margin:1.6rem 0;}
.hero-rule-line{height:2px;background:linear-gradient(90deg,var(--green),transparent);flex:1;max-width:120px;}
.hero-rule-circle{width:10px;height:10px;border-radius:50%;background:var(--red);flex-shrink:0;box-shadow:0 0 0 4px rgba(244,42,65,.15);}
.hero-sub{margin-bottom:2.2rem;}
.hero-sub-en{font-size:.96rem;font-weight:500;color:var(--gray);line-height:1.7;margin-bottom:.5rem;}
.hero-sub-bn{font-family:'Noto Serif Bengali',sans-serif;font-size:.88rem;color:var(--gray-l);line-height:1.75;}
.hero-btns{display:flex;gap:.9rem;flex-wrap:wrap;}
.btn-g{background:var(--green);color:#fff;padding:13px 26px;font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;border-radius:var(--radius-sm);border:2px solid var(--green);display:inline-flex;align-items:center;gap:7px;transition:all var(--T);box-shadow:0 4px 14px rgba(0,106,78,.2);}
.btn-g:hover{background:var(--green-d);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,106,78,.3);}
.btn-ghost-w{background:transparent;color:var(--ink);padding:13px 26px;font-size:11px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;border-radius:var(--radius-sm);border:2px solid var(--ink);display:inline-flex;align-items:center;gap:7px;transition:all var(--T);}
.btn-ghost-w:hover{border-color:var(--green);color:var(--green);transform:translateY(-2px);}
.hero-right{padding-left:3.5rem;display:flex;flex-direction:column;gap:1.2rem;}
.hero-stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;}
.hstat{background:var(--white);border:1.5px solid var(--green-l);border-radius:var(--radius);padding:1.2rem .8rem;text-align:center;transition:all var(--T);position:relative;overflow:hidden;}
.hstat::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--green);transform:scaleX(0);transform-origin:left;transition:transform .3s ease;}
.hstat:hover{border-color:var(--green);box-shadow:0 6px 18px rgba(0,106,78,.1);transform:translateY(-3px);}
.hstat:hover::after{transform:scaleX(1);}
.hstat-n{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--green);line-height:1;}
.hstat-n sup{font-size:.9rem;color:var(--red);}
.hstat-l{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gray);margin-top:.3rem;}
.hero-feat-cards{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
.hfc{background:var(--white);border:1.5px solid var(--green-l);border-radius:var(--radius);padding:1.2rem 1rem;transition:all var(--T);position:relative;overflow:hidden;}
.hfc::before{content:'';position:absolute;top:0;left:0;width:3px;height:0;background:var(--green);transition:height .3s ease;}
.hfc:hover::before{height:100%;}
.hfc:hover{border-color:var(--green);box-shadow:0 6px 18px rgba(0,106,78,.1);transform:translateY(-3px);}
.hfc-icon{font-size:1.4rem;margin-bottom:.5rem;}
.hfc-num{font-size:9px;font-weight:900;letter-spacing:.16em;color:var(--red);margin-bottom:.3rem;}
.hfc-t{font-size:.84rem;font-weight:800;color:var(--ink);margin-bottom:.2rem;}
.hfc-d{font-size:.74rem;color:var(--gray);line-height:1.45;font-family:'Noto Serif Bengali',sans-serif;}
.hero-live-tag{display:inline-flex;align-items:center;gap:7px;background:var(--red-l);border:1px solid rgba(244,42,65,.25);color:var(--red);font-size:9px;font-weight:900;letter-spacing:.16em;text-transform:uppercase;padding:.38rem .9rem;border-radius:20px;margin-bottom:1rem;}
.hero-live-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--red);flex-shrink:0;animation:pls 1.5s ease infinite;}
@keyframes pls{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(1.6);}}

/* ═══ TICKER ═══ */
.ticker{background:var(--green);overflow:hidden;height:36px;display:flex;align-items:center;border-bottom:2px solid var(--green-d);position:relative;}
.ticker-label{flex-shrink:0;background:var(--red);color:#fff;font-size:9px;font-weight:900;letter-spacing:.2em;text-transform:uppercase;padding:0 1.2rem;height:100%;display:flex;align-items:center;gap:6px;white-space:nowrap;z-index:2;}
.ticker-label::after{content:'';position:absolute;left:68px;top:0;bottom:0;width:24px;background:linear-gradient(90deg,var(--red),transparent);pointer-events:none;}
.ticker-track{overflow:hidden;flex:1;}
.ticker-inner{display:inline-flex;white-space:nowrap;animation:ticker 36s linear infinite;gap:0;}
.ticker-inner span{font-size:11px;font-weight:700;letter-spacing:.06em;color:rgba(255,255,255,.92);padding:0 28px;display:flex;align-items:center;gap:8px;}
.ticker-inner span::before{content:'●';font-size:6px;color:var(--red);opacity:.8;}
@keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ═══ IMPACT BAR ═══ */
.impact-bar{background:var(--green);border-bottom:3px solid var(--green-d);}
.impact-inner{max-width:1360px;width:92%;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);}
.impact-item{padding:2rem 1.5rem;text-align:center;border-right:1px solid rgba(255,255,255,.15);position:relative;}
.impact-item:last-child{border-right:none;}
.impact-num{font-family:'Playfair Display',serif;font-size:2.6rem;font-weight:900;color:#fff;line-height:1;}
.impact-num span{color:#a8f3d8;}
.impact-lbl{font-size:9px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-top:.35rem;}
.impact-desc{font-family:'Noto Serif Bengali',sans-serif;font-size:.76rem;color:rgba(255,255,255,.4);margin-top:.3rem;line-height:1.4;}

/* ═══ SCROLL TOP ═══ */
#scrollTopBtn{position:fixed;bottom:1.8rem;right:1.8rem;width:44px;height:44px;border-radius:var(--radius-sm);background:var(--green);color:#fff;border:none;font-size:1rem;font-weight:900;display:flex;align-items:center;justify-content:center;opacity:0;transform:translateY(12px);transition:all var(--T);z-index:900;box-shadow:0 4px 16px rgba(0,106,78,.35);}
#scrollTopBtn.vis{opacity:1;transform:none;}
#scrollTopBtn:hover{background:var(--green-d);transform:translateY(-2px)!important;}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1024px){.hero-grid{grid-template-columns:1fr;gap:2.5rem;padding:3rem 0;}.hero-left{padding-right:0;border-right:none;border-bottom:1.5px solid var(--green-l);padding-bottom:2.5rem;}.hero-right{padding-left:0;}.impact-inner{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){:root{--header-h:66px;--header-s:58px;}body{padding-top:var(--header-h);}.hdr-nav,.hdr-cta{display:none;}.hdr-inner{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:0;width:94%;}.mob-wa-btn{display:flex;justify-self:start;}.hdr-logo{justify-self:center;}.hdr-logo img{height:40px;}#hdr.scrolled .hdr-logo img{height:36px;filter:none;}.ham-btn{display:flex;justify-self:end;}.hero-stat-row{grid-template-columns:repeat(3,1fr);}.hero-feat-cards{grid-template-columns:1fr 1fr;}}
.mob-wa-num{display:none;}.mob-wa-btn{padding:8px;border-radius:50%;}
@media(max-width:480px){.hero-stat-row{grid-template-columns:1fr 1fr;}.hero-feat-cards{grid-template-columns:1fr;}.impact-inner{grid-template-columns:1fr;}.hero-btns{flex-direction:column;}.hero-btns a{justify-content:center;}}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════
     HEADER
═══════════════════════════════════════ -->
<header id="hdr">
