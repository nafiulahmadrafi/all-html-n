<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PIBBD \u2014 Hero</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;700;800&family=Noto+Serif+Bengali:wght@400;600;700&display=swap" rel="stylesheet">
<style>

:root {
  --green:    #006A4E;
  --green-d:  #004f3a;
  --green-l:  #e6f2ee;
  --red:      #F42A41;
  --red-d:    #c41f31;
  --red-l:    #fff0f1;
  --white:    #ffffff;
  --ink:      #0d1117;
  --ink-soft: #1a2332;
  --gray:     #5a6474;
  --gray-l:   #8a95a3;
  --T:        0.3s cubic-bezier(.4,0,.2,1);
  --radius-sm:4px;
  --radius:   8px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); overflow-x: hidden; }
a { color: inherit; text-decoration: none; }

/* \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550
   HERO SECTION
\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550 */
#hero {
  background: var(--white);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  border-bottom: 3px solid var(--green);
}

/* Multi-layer gradient bg */
#hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 70% at 85% 30%, rgba(0,106,78,.09) 0%, transparent 70%),
    radial-gradient(ellipse 45% 55% at 10% 80%, rgba(244,42,65,.06) 0%, transparent 65%),
    radial-gradient(circle 400px at 70% 60%, rgba(0,106,78,.04) 0%, transparent 100%),
    radial-gradient(circle 300px at 20% 30%, rgba(244,42,65,.03) 0%, transparent 100%);
  pointer-events: none;
  z-index: 0;
}

/* PIBD watermark */
#hero::after {
  content: 'PIBD';
  position: absolute;
  right: -2rem;
  bottom: -1rem;
  font-family: 'Playfair Display', serif;
  font-size: clamp(8rem, 18vw, 18rem);
  font-weight: 900;
  color: rgba(0,106,78,.04);
  line-height: 1;
  pointer-events: none;
  z-index: 0;
  letter-spacing: -.04em;
}

/* \u2500\u2500 BG GRAPHICS \u2500\u2500 */
.hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }

.hero-bg-c1 { position: absolute; top: 8%;  right: 5%;  width: 420px; height: 420px; border-radius: 50%; border: 1.5px solid rgba(0,106,78,.06); animation: hRot 60s linear infinite; }
.hero-bg-c2 { position: absolute; top: 12%; right: 9%;  width: 340px; height: 340px; border-radius: 50%; border: 1.5px dashed rgba(0,106,78,.05); animation: hRot 45s linear infinite reverse; }
.hero-bg-c3 { position: absolute; bottom: 10%; left: 3%; width: 280px; height: 280px; border-radius: 50%; border: 1.5px solid rgba(244,42,65,.05); animation: hRot 50s linear infinite; }
.hero-bg-rc { position: absolute; top: 18%; right: 14%; width: 180px; height: 180px; border-radius: 50%; background: radial-gradient(circle, rgba(244,42,65,.06) 0%, transparent 70%); animation: hPulse 8s ease-in-out infinite; }

.hero-grid-lines {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(0,106,78,.025) 1px, transparent 1px), linear-gradient(90deg, rgba(0,106,78,.025) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse 70% 60% at 75% 40%, black 0%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at 75% 40%, black 0%, transparent 70%);
}

.hero-corner-tl { position: absolute; top: 0; left: 0; width: 0; height: 0; border-left: 120px solid rgba(0,106,78,.04); border-bottom: 120px solid transparent; }
.hero-corner-br { position: absolute; bottom: 0; right: 0; width: 0; height: 0; border-right: 160px solid rgba(244,42,65,.03); border-top: 160px solid transparent; }
.hero-diag      { position: absolute; top: 0; right: 38%; width: 1px; height: 100%; background: linear-gradient(180deg, transparent 0%, rgba(0,106,78,.06) 30%, rgba(0,106,78,.06) 70%, transparent 100%); transform: rotate(15deg); transform-origin: top center; }

.hero-dot { position: absolute; border-radius: 50%; animation: hFloat 6s ease-in-out infinite; }
.hd1 { width:8px;  height:8px;  background:rgba(0,106,78,.12);  top:20%; left:12%;  animation-duration:7s;   animation-delay:0s; }
.hd2 { width:6px;  height:6px;  background:rgba(244,42,65,.15); top:35%; right:20%; animation-duration:5s;   animation-delay:1s; }
.hd3 { width:10px; height:10px; background:rgba(0,106,78,.08);  bottom:25%; left:8%; animation-duration:8s;  animation-delay:2s; }
.hd4 { width:5px;  height:5px;  background:rgba(244,42,65,.1);  top:60%; right:8%;  animation-duration:6s;   animation-delay:.5s; }
.hd5 { width:7px;  height:7px;  background:rgba(0,106,78,.1);   top:15%; left:45%;  animation-duration:9s;   animation-delay:3s; }
.hd6 { width:4px;  height:4px;  background:rgba(244,42,65,.12); bottom:35%; right:35%; animation-duration:7s; animation-delay:1.5s; }
.hd7 { width:9px;  height:9px;  background:rgba(0,106,78,.06);  bottom:15%; left:40%; animation-duration:6.5s; animation-delay:4s; }

.hero-cross { position: absolute; width: 16px; height: 16px; opacity: .12; }
.hero-cross::before, .hero-cross::after { content: ''; position: absolute; background: var(--green); }
.hero-cross::before { width: 16px; height: 1.5px; top: 50%; left: 0; transform: translateY(-50%); }
.hero-cross::after  { width: 1.5px; height: 16px; left: 50%; top: 0; transform: translateX(-50%); }
.hc1 { top: 25%; left: 25%; }
.hc2 { top: 70%; left: 55%; opacity: .08; }
.hc3 { top: 45%; right: 12%; opacity: .1; }

.hero-diamond { position: absolute; width: 10px; height: 10px; border: 1.5px solid rgba(0,106,78,.1); transform: rotate(45deg); animation: hFloat 7s ease-in-out infinite; }
.hdm1 { top: 30%; right: 28%; animation-delay: 2s; }
.hdm2 { bottom: 20%; left: 18%; animation-delay: 0s; border-color: rgba(244,42,65,.1); }
.hdm3 { top: 55%; left: 35%; animation-delay: 3.5s; width: 7px; height: 7px; }

@keyframes hRot   { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes hPulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.15); opacity: .6; } }
@keyframes hFloat { 0%,100% { transform: translateY(0) translateX(0); } 25% { transform: translateY(-12px) translateX(5px); } 50% { transform: translateY(-6px) translateX(-4px); } 75% { transform: translateY(-15px) translateX(3px); } }

/* BD flag top stripe */
.hero-flag-stripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--green) 60%, var(--red) 60%);
  z-index: 1;
}

/* \u2500\u2500 CONTENT GRID \u2500\u2500 */
.hero-inner {
  max-width: 1360px;
  width: 92%;
  margin: 0 auto;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-grid {
  flex: 1;
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  align-items: center;
  padding: 5rem 0 4rem;
  position: relative;
  z-index: 1;
  gap: 0;
}

/* \u2500\u2500 LEFT \u2500\u2500 */
.hero-left {
  padding-right: 4.5rem;
  border-right: 1.5px solid var(--green-l);
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: .7rem;
  margin-bottom: 1.6rem;
  flex-wrap: wrap;
}
.hero-eyebrow-bn {
  font-family: 'Noto Serif Bengali', serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--green);
  letter-spacing: .02em;
}
.hero-eyebrow-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--red); flex-shrink: 0; }
.hero-eyebrow-en  { font-size: 10px; font-weight: 900; letter-spacing: .18em; text-transform: uppercase; color: var(--gray); }

.hero-title { margin-bottom: 1.6rem; line-height: 1; }
.ht-en {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 5.5vw, 5.6rem);
  font-weight: 900;
  letter-spacing: -.03em;
  color: var(--ink);
  line-height: .95;
}
.ht-en .hl-g { color: var(--green); }
.ht-en .hl-r { color: var(--red); font-style: italic; }
.ht-bn {
  display: block;
  font-family: 'Noto Serif Bengali', serif;
  font-size: clamp(1.5rem, 2.8vw, 2.6rem);
  font-weight: 700;
  color: var(--gray);
  line-height: 1.4;
  margin-top: .35rem;
  letter-spacing: .01em;
}
.ht-bn strong { font-weight: 900; color: var(--green); }
.ht-bn .red   { color: var(--red); }

.hero-rule { display: flex; align-items: center; gap: .8rem; margin: 1.6rem 0; }
.hero-rule-line   { height: 2px; background: linear-gradient(90deg, var(--green), transparent); flex: 1; max-width: 120px; }
.hero-rule-circle { width: 10px; height: 10px; border-radius: 50%; background: var(--red); flex-shrink: 0; box-shadow: 0 0 0 4px rgba(244,42,65,.15); }

.hero-sub { margin-bottom: 2.2rem; }
.hero-sub-en { font-size: .96rem; font-weight: 500; color: var(--gray); line-height: 1.7; margin-bottom: .5rem; }
.hero-sub-bn { font-family: 'Noto Serif Bengali', serif; font-size: .88rem; color: var(--gray-l); line-height: 1.75; }

.hero-btns { display: flex; gap: .9rem; flex-wrap: wrap; }
.btn-g {
  background: var(--green);
  color: #fff;
  padding: 13px 26px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: var(--radius-sm);
  border: 2px solid var(--green);
  display: inline-flex;
  align-items: center;
  gap: 7px;
  transition: all var(--T);
  box-shadow: 0 4px 14px rgba(0,106,78,.2);
}
.btn-g:hover { background: var(--green-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,106,78,.3); }

.btn-out {
  background: transparent;
  color: var(--ink);
  padding: 13px 26px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: var(--radius-sm);
  border: 2px solid var(--ink);
  display: inline-flex;
  align-items: center;
  gap: 7px;
  transition: all var(--T);
}
.btn-out:hover