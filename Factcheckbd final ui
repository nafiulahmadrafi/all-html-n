<script>
'use strict';

/* ══ CONFIGURATION ══ */
const WP_URL = window.location.origin;

const SITE_CONFIG = {
  name: 'FactCheckBD',
  tagline: 'First AI-Powered Fact-Checking Tool in BD',
  homeUrl: WP_URL,
  location: 'বাংলাদেশ',
};

/* ══ STATE ══ */
const STATE = {
  factsLoaded: false,
  menuLoaded: false,
  activeSheet: null,
  allFacts: [],
  allLinks: [],
  isLoggedIn: false,
  user: null,
};

/* ══ INITIALIZE ══ */
(function init() {
  // Site branding (CSS logos are auto-generated, no need to load images)
  
  document.getElementById('menuSiteUrl').textContent = WP_URL.replace('https://', '');
  document.getElementById('brandLink').href = SITE_CONFIG.homeUrl || '/';

  checkLoginStatus();
  window.addEventListener('scroll', handleScroll);
  document.addEventListener('click', handleOutsideClick);
})();

/* ══ STICKY HEADER ══ */
function handleScroll() {
  const header = document.getElementById('topHeader');
  if (window.scrollY > 20) {
    header.classList.add('scrolled');
  } else {
    header.classList.remove('scrolled');
  }
}

/* ══ LOGIN SYSTEM ══ */
function checkLoginStatus() {
  const userData = localStorage.getItem('user');
  if (userData) {
    try {
      STATE.user = JSON.parse(userData);
      STATE.isLoggedIn = true;
      document.body.classList.remove('logged-out');
      document.body.classList.add('logged-in');
      updateUserUI();
    } catch(e) {
      localStorage.removeItem('user');
    }
  }
}

function updateUserUI() {
  if (!STATE.user) return;
  const userName = STATE.user.name || 'User';
  const userEmail = STATE.user.email || '';
  document.getElementById('userName').textContent = userName;
  document.getElementById('dropdownUserName').textContent = userName;
  document.getElementById('dropdownUserEmail').textContent = userEmail;
  const parts = userName.split(/\s+/);
  const initials = parts.length >= 2
    ? parts[0][0].toUpperCase() + parts[1][0].toUpperCase()
    : userName.slice(0, 2).toUpperCase();
  document.getElementById('avatarText').textContent = initials;
}

function openLogin() {
  document.getElementById('loginOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLogin() {
  document.getElementById('loginOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function handleLogin(e) {
  e.preventDefault();
  const username = document.getElementById('loginUsername').value;
  const password = document.getElementById('loginPassword').value;
  const remember = document.getElementById('rememberMe').checked;
  
  const userData = {
    name: 'Ahmad Rafi',
    email: 'rafi@factcheckbd.org',
    username: username,
  };
  
  if (remember) {
    localStorage.setItem('user', JSON.stringify(userData));
  } else {
    sessionStorage.setItem('user', JSON.stringify(userData));
  }
  
  STATE.user = userData;
  STATE.isLoggedIn = true;
  document.body.classList.remove('logged-out');
  document.body.classList.add('logged-in');
  updateUserUI();
  closeLogin();
}

function logout() {
  localStorage.removeItem('user');
  sessionStorage.removeItem('user');
  STATE.user = null;
  STATE.isLoggedIn = false;
  document.body.classList.remove('logged-in');
  document.body.classList.add('logged-out');
  closeProfileMenu();
  if (window.location.pathname !== '/') {
    window.location.href = '/';
  }
}

function loginWithGoogle() {
  alert('Google লগইন শীঘ্রই আসছে!');
}

function loginWithFacebook() {
  alert('Facebook লগইন শীঘ্রই আসছে!');
}

function toggleProfileMenu() {
  document.getElementById('profileBtn').classList.toggle('active');
}

function closeProfileMenu() {
  document.getElementById('profileBtn').classList.remove('active');
}

function handleOutsideClick(e) {
  const profileBtn = document.getElementById('profileBtn');
  if (profileBtn && !profileBtn.contains(e.target)) {
    closeProfileMenu();
  }
}

/* ══ NAVIGATION ══ */
function activateNav(id, event) {
  if (event) event.preventDefault();
  document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
  document.getElementById(id)?.classList.add('active');
}

function openSheet(type) {
  if (STATE.activeSheet === type) {
    closeSheet(type);
    return;
  }
  if (STATE.activeSheet) closeSheet(STATE.activeSheet);
  STATE.activeSheet = type;
  document.getElementById(type + 'Overlay').classList.add('open');
  activateNav('nb-' + type);
  if (type === 'facts') loadFacts();
  if (type === 'menu') loadMenu();
}

function closeSheet(type) {
  document.getElementById(type + 'Overlay').classList.remove('open');
  STATE.activeSheet = null;
  document.getElementById('nb-' + type)?.classList.remove('active');
  if (type === 'facts') document.getElementById('factsSearchInput').value = '';
  if (type === 'menu') document.getElementById('menuSearchInput').value = '';
}

/* ══ DATA FETCHING ══ */
async function fetchData(url, timeout = 8000) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeout);
  try {
    const response = await fetch(url, { 
      headers: { 'Accept': 'application/json' },
      signal: controller.signal 
    });
    clearTimeout(timer);
    return response.ok ? await response.json() : null;
  } catch(e) {
    clearTimeout(timer);
    return null;
  }
}

function sanitize(str) {
  const div = document.createElement('div');
  div.textContent = String(str || '');
  return div.innerHTML;
}

const ICONS = {
  fact: '✅', check: '✅', verify: '🔍', truth: '✅',
  home: '🏠', about: 'ℹ️', service: '📋', contact: '📞',
  blog: '✍️', news: '📰', post: '📝', page: '📄',
  category: '🏷️', search: '🔍', menu: '☰'
};

function getIconForItem(slug, title) {
  const text = ((slug || '') + ' ' + (title || '')).toLowerCase();
  const key = Object.keys(ICONS).find(k => text.includes(k));
  return ICONS[key] || '📄';
}

function getIconClass(type) {
  const classes = {
    fact: 'ic-fact', page: 'ic-page', post: 'ic-post',
    category: 'ic-category', home: 'ic-home', about: 'ic-about',
    service: 'ic-service', contact: 'ic-contact'
  };
  return classes[type] || 'ic-page';
}

async function fetchFactChecks() {
  try {
    let catParam = '';
    const catRes = await fetchData(`${WP_URL}/wp-json/wp/v2/categories?slug=fact-check&_fields=id`);
    if (catRes && catRes.length > 0) catParam = `&categories=${catRes[0].id}`;
    const posts = await fetchData(`${WP_URL}/wp-json/wp/v2/posts?per_page=100&status=publish&orderby=date&order=desc&_fields=id,title,link,slug${catParam}`);
    return posts || [];
  } catch(e) {
    return [
      { id: 1, title: { rendered: 'ভাইরাল ছবির সত্যতা যাচাই' }, link: '#', slug: 'viral' },
      { id: 2, title: { rendered: 'ফেসবুক পোস্ট যাচাই' }, link: '#', slug: 'fb' },
    ];
  }
}

async function fetchAllLinks() {
  const links = [];
  try {
    const [pages, posts, cats] = await Promise.all([
      fetchData(`${WP_URL}/wp-json/wp/v2/pages?per_page=100&status=publish&_fields=id,title,link,slug`),
      fetchData(`${WP_URL}/wp-json/wp/v2/posts?per_page=100&status=publish&_fields=id,title,link,slug`),
      fetchData(`${WP_URL}/wp-json/wp/v2/categories?per_page=50&_fields=id,name,link,slug`)
    ]);
    if (pages) links.push(...pages.map(p => ({ ...p, type: 'page', title: p.title?.rendered || p.title })));
    if (posts) links.push(...posts.map(p => ({ ...p, type: 'post', title: p.title?.rendered || p.title })));
    if (cats) links.push(...cats.filter(c => c.name !== 'Uncategorized').map(c => ({ ...c, type: 'category', title: c.name, slug: c.slug || '' })));
    return links.length > 0 ? links : [
      { title: 'হোম', link: '/', slug: 'home', type: 'page' },
      { title: 'সম্পর্কে', link: '/about/', slug: 'about', type: 'page' },
    ];
  } catch(e) {
    return [];
  }
}

function renderFacts(facts) {
  document.getElementById('factsSkeletons').style.display = 'none';
  const listEl = document.getElementById('factsList');
  listEl.innerHTML = '';
  if (!facts || facts.length === 0) {
    document.getElementById('factsEmpty').classList.add('show');
    return;
  }
  STATE.allFacts = facts;
  document.getElementById('factsCount').textContent = `${facts.length}টি`;
  document.getElementById('factsBadge').textContent = facts.length > 99 ? '99+' : facts.length;
  if (facts.length > 0) document.getElementById('factsBadge').classList.add('show');
  
  facts.forEach(fact => {
    const title = sanitize(fact.title?.rendered || fact.title || 'ফ্যাক্ট');
    const url = fact.link || '#';
    const slug = fact.slug || '';
    const icon = getIconForItem(slug, title);
    const card = document.createElement('a');
    card.href = url;
    card.className = 'link-card';
    card.dataset.search = (title + ' ' + slug).toLowerCase();
    card.innerHTML = `
      <div class="link-icon ic-fact">${icon}</div>
      <div class="link-info">
        <div class="link-title">${title}</div>
        <div class="link-subtitle">${url.replace(WP_URL, '').slice(0, 50) || '/'}</div>
      </div>
      <span class="link-arrow">→</span>
    `;
    listEl.appendChild(card);
  });
}

function renderMenu(links) {
  document.getElementById('menuSkeletons').style.display = 'none';
  const contentEl = document.getElementById('menuContent');
  contentEl.innerHTML = '';
  if (!links || links.length === 0) {
    document.getElementById('menuEmpty').classList.add('show');
    return;
  }
  STATE.allLinks = links;
  document.getElementById('menuCount').textContent = `${links.length}টি`;
  
  const pages = links.filter(l => l.type === 'page');
  const posts = links.filter(l => l.type === 'post');
  const cats = links.filter(l => l.type === 'category');
  
  function renderSection(items, label, type) {
    if (items.length === 0) return;
    const section = document.createElement('div');
    const labelEl = document.createElement('span');
    labelEl.className = 'section-label';
    labelEl.textContent = label;
    section.appendChild(labelEl);
    const cardsEl = document.createElement('div');
    cardsEl.className = 'link-cards';
    items.forEach(item => {
      const title = sanitize(item.title || 'লিংক');
      const url = item.link || '#';
      const slug = item.slug || '';
      const icon = getIconForItem(slug, title);
      const card = document.createElement('a');
      card.href = url;
      card.className = 'link-card';
      card.dataset.search = (title + ' ' + slug).toLowerCase();
      card.dataset.section = type;
      card.innerHTML = `
        <div class="link-icon ${getIconClass(type)}">${icon}</div>
        <div class="link-info">
          <div class="link-title">${title}</div>
          <div class="link-subtitle">${url.replace(WP_URL, '').slice(0, 50) || '/'}</div>
        </div>
        <span class="link-arrow">→</span>
      `;
      cardsEl.appendChild(card);
    });
    section.appendChild(cardsEl);
    contentEl.appendChild(section);
  }
  
  renderSection(pages, '📄 পাতা', 'page');
  renderSection(posts, '📰 পোস্ট', 'post');
  renderSection(cats, '🏷️ ক্যাটাগরি', 'category');
}

function searchFacts(query) {
  const q = query.toLowerCase().trim();
  const cards = document.querySelectorAll('#factsList .link-card');
  let visible = 0;
  cards.forEach(card => {
    const match = !q || card.dataset.search.includes(q);
    card.classList.toggle('hidden', !match);
    if (match) visible++;
  });
  document.getElementById('factsEmpty').classList.toggle('show', visible === 0 && q.length > 0);
}

function searchMenu(query) {
  const q = query.toLowerCase().trim();
  const cards = document.querySelectorAll('#menuContent .link-card');
  const sections = document.querySelectorAll('#menuContent .section-label');
  let visible = 0;
  cards.forEach(card => {
    const match = !q || card.dataset.search.includes(q);
    card.classList.toggle('hidden', !match);
    if (match) visible++;
  });
  sections.forEach(section => {
    const nextCards = [];
    let el = section.nextElementSibling;
    while (el && el.classList.contains('link-cards')) {
      nextCards.push(...el.querySelectorAll('.link-card:not(.hidden)'));
      el = el.nextElementSibling;
    }
    section.style.display = nextCards.length > 0 ? 'block' : 'none';
  });
  document.getElementById('menuEmpty').classList.toggle('show', visible === 0 && q.length > 0);
}

async function loadFacts() {
  if (STATE.factsLoaded) return;
  STATE.factsLoaded = true;
  const facts = await fetchFactChecks();
  renderFacts(facts);
}

async function loadMenu() {
  if (STATE.menuLoaded) return;
  STATE.menuLoaded = true;
  const links = await fetchAllLinks();
  renderMenu(links);
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (STATE.activeSheet) closeSheet(STATE.activeSheet);
    else if (document.getElementById('loginOverlay').classList.contains('open')) closeLogin();
    else if (document.getElementById('profileBtn').classList.contains('active')) closeProfileMenu();
  }
});
</script>
