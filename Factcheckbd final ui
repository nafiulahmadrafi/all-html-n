<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FactCheckBD - Universal Navigation</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=DM+Sans:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #3b82f6;
  --blue-dark: #2563eb;
  --blue-light: #60a5fa;
  --teal: #14b8a6;
  --green: #10b981;
  --text: #1e293b;
  --text-soft: #64748b;
  --bg: #f8fafc;
  --bg-light: #ffffff;
  --border: rgba(59,130,246,0.12);
  --shadow: rgba(59,130,246,0.08);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { 
  font-family: 'Hind Siliguri', sans-serif; 
  background: var(--bg);
  color: var(--text);
}

/* ══ STICKY TOP HEADER ══ */
.top-header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 10001;
  height: 58px; display: flex; align-items: center; justify-content: space-between;
  padding: 0 5%;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 2px 16px var(--shadow);
  transition: all 0.3s ease;
}

.top-header.scrolled {
  height: 54px;
  box-shadow: 0 4px 24px rgba(59,130,246,0.12);
  background: rgba(255,255,255,0.98);
}

.brand-section { display: flex; align-items: center; gap: 12px; text-decoration: none; }

/* Logo with CSS-generated design */
.brand-logo {
  width: 40px; height: 40px; border-radius: 11px;
  overflow: visible; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s;
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  box-shadow: 0 4px 16px rgba(59,130,246,0.3);
  position: relative;
}
.top-header.scrolled .brand-logo { 
  width: 36px; height: 36px; 
  box-shadow: 0 2px 12px rgba(59,130,246,0.25);
}

/* Checkmark inside logo */
.brand-logo::before {
  content: '✓';
  font-size: 28px;
  color: white;
  font-weight: bold;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.top-header.scrolled .brand-logo::before {
  font-size: 25px;
}

/* Hide image if present */
.brand-logo img { 
  display: none;
}

/* FactCheckBD Branding */
.brand-title {
  font-family: 'DM Sans', sans-serif; 
  font-size: 1.1rem; 
  font-weight: 700;
  color: var(--text); 
  letter-spacing: -0.02em; 
  transition: all 0.3s;
}
.top-header.scrolled .brand-title { font-size: 1rem; }

.brand-title .fact { color: var(--text); }
.brand-title .check { color: var(--blue); }
.brand-title .bd { 
  color: var(--blue); 
  font-weight: 800;
}

/* Tagline (hidden on mobile) */
.brand-tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  color: var(--text-soft);
  display: none;
}

/* ══ LOGIN/PROFILE SECTION ══ */
.auth-section {
  display: flex; align-items: center; gap: 10px;
}

.login-btn {
  display: flex; align-items: center; gap: 8px;
  padding: 7px 16px; border-radius: 50px;
  background: linear-gradient(135deg, var(--blue), var(--teal));
  border: none; cursor: pointer; text-decoration: none;
  color: #fff; font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem; font-weight: 600;
  box-shadow: 0 2px 12px rgba(59,130,246,0.25);
  transition: all 0.2s;
}
.login-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(59,130,246,0.35);
}
.login-btn svg {
  width: 18px; height: 18px; stroke: #fff;
  fill: none; stroke-width: 2;
}

.profile-btn {
  display: flex; align-items: center; gap: 10px; cursor: pointer;
  padding: 5px 12px 5px 6px; border-radius: 50px;
  border: 1px solid var(--border); background: var(--bg-light);
  transition: all 0.2s; text-decoration: none; position: relative;
}
.profile-btn:hover { 
  background: var(--bg); 
  border-color: var(--blue);
  transform: scale(1.02); 
}

.user-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, var(--blue), var(--teal));
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Sans', sans-serif; font-size: 0.7rem; font-weight: 700; 
  color: #fff; position: relative; border: 2px solid rgba(255,255,255,0.95);
  flex-shrink: 0;
}
.online-dot { 
  position: absolute; bottom: 0; right: 0; 
  width: 9px; height: 9px; background: var(--green); 
  border-radius: 50%; border: 2px solid #fff; 
}

.user-details { display: flex; flex-direction: column; gap: 1px; }
.user-name { 
  font-family: 'DM Sans', sans-serif; font-size: 0.8rem; 
  font-weight: 700; color: var(--text); max-width: 120px; 
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; 
}
.user-location { 
  font-family: 'DM Sans', sans-serif; font-size: 0.62rem; 
  color: var(--text-soft); 
}

/* Profile Dropdown Menu */
.profile-dropdown {
  position: absolute; top: calc(100% + 8px); right: 0;
  min-width: 220px; background: var(--bg-light);
  border: 1px solid var(--border); border-radius: 14px;
  box-shadow: 0 8px 32px rgba(59,130,246,0.15);
  opacity: 0; visibility: hidden; transform: translateY(-10px);
  transition: all 0.25s ease;
  z-index: 10002;
}
.profile-btn.active .profile-dropdown {
  opacity: 1; visibility: visible; transform: translateY(0);
}

.dropdown-header {
  padding: 1rem 1.1rem; border-bottom: 1px solid var(--border);
}
.dropdown-user-name {
  font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
  font-weight: 700; color: var(--text); margin-bottom: 3px;
}
.dropdown-user-email {
  font-family: 'DM Sans', sans-serif; font-size: 0.72rem;
  color: var(--text-soft);
}

.dropdown-menu {
  padding: 0.5rem;
}
.dropdown-item {
  display: flex; align-items: center; gap: 12px;
  padding: 0.75rem 1rem; border-radius: 10px;
  text-decoration: none; color: var(--text);
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 0.85rem; font-weight: 600;
  transition: all 0.18s; cursor: pointer;
  border: none; background: transparent;
  width: 100%; text-align: left;
}
.dropdown-item:hover {
  background: rgba(59,130,246,0.08);
  color: var(--blue);
}
.dropdown-item svg {
  width: 20px; height: 20px; stroke: var(--text-soft);
  fill: none; stroke-width: 2; flex-shrink: 0;
}
.dropdown-item:hover svg { stroke: var(--blue); }

.dropdown-divider {
  height: 1px; background: var(--border);
  margin: 0.5rem 0.8rem;
}

.dropdown-logout {
  color: #ef4444;
}
.dropdown-logout:hover {
  background: rgba(239,68,68,0.08);
  color: #ef4444;
}
.dropdown-logout svg { stroke: #ef4444; }

/* ══ BOTTOM NAVIGATION ══ */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 10001;
  height: 68px; display: flex; align-items: center; justify-content: space-around;
  padding: 8px 3% calc(8px + env(safe-area-inset-bottom, 0px));
  background: rgba(255,255,255,0.98);
  backdrop-filter: blur(28px) saturate(200%);
  -webkit-backdrop-filter: blur(28px) saturate(200%);
  border-top: 1px solid var(--border);
  box-shadow: 0 -4px 20px var(--shadow);
}

.nav-btn {
  flex: 1; display: flex; flex-direction: column; 
  align-items: center; justify-content: center;
  gap: 4px; padding: 8px 6px; border-radius: 16px; 
  border: none; background: transparent; cursor: pointer; 
  text-decoration: none; transition: all 0.2s; position: relative;
  max-width: 90px;
}
.nav-btn:hover { background: rgba(59,130,246,0.08); transform: translateY(-2px); }
.nav-btn.active { background: rgba(59,130,246,0.12); }
.nav-btn.active::before { 
  content: ''; position: absolute; top: 6px; 
  width: 5px; height: 5px; background: var(--blue); 
  border-radius: 50%; 
}

.nav-icon-wrap { 
  width: 42px; height: 42px; display: flex; 
  align-items: center; justify-content: center; 
  border-radius: 12px; transition: all 0.2s;
  position: relative;
}
.nav-btn:hover .nav-icon-wrap { transform: scale(1.08); }
.nav-btn.active .nav-icon-wrap { 
  background: linear-gradient(135deg, var(--blue-light), var(--teal));
  box-shadow: 0 4px 16px rgba(59,130,246,0.3);
}

.nav-icon-wrap svg { 
  width: 24px; height: 24px; stroke: var(--text-soft); 
  fill: none; stroke-width: 2; stroke-linecap: round; 
  stroke-linejoin: round; transition: stroke 0.2s; 
}
.nav-btn:hover .nav-icon-wrap svg { stroke: var(--blue); }
.nav-btn.active .nav-icon-wrap svg { stroke: #fff; }

.nav-label { 
  font-family: 'Hind Siliguri', sans-serif; 
  font-size: 0.68rem; font-weight: 600; 
  color: var(--text-soft); transition: color 0.2s; 
}
.nav-btn.active .nav-label, 
.nav-btn:hover .nav-label { color: var(--blue); }

.count-badge {
  position: absolute; top: -4px; right: -4px;
  min-width: 18px; height: 18px; background: #ef4444;
  border-radius: 50%; border: 2px solid #fff;
  font-family: 'DM Sans', sans-serif; font-size: 0.6rem;
  font-weight: 700; color: #fff; display: none;
  align-items: center; justify-content: center; padding: 0 4px;
}
.count-badge.show { display: flex; }

/* ══ SHEET OVERLAY ══ */
.sheet-overlay { 
  position: fixed; inset: 0; z-index: 10000; 
  pointer-events: none; opacity: 0; 
  transition: opacity 0.25s ease-in-out; 
}
.sheet-overlay.open { pointer-events: all; opacity: 1; }
.sheet-bg { 
  position: absolute; inset: 0; 
  background: rgba(15,23,42,0.4); 
  backdrop-filter: blur(4px); 
}

.sheet-content {
  position: absolute; bottom: 68px; left: 0; right: 0;
  background: rgba(255,255,255,0.98); 
  backdrop-filter: blur(28px);
  border-radius: 28px 28px 0 0; 
  border-top: 1px solid var(--border);
  box-shadow: 0 -8px 40px rgba(59,130,246,0.15);
  padding: 1.4rem 1.2rem 2rem; 
  max-height: 82vh; overflow-y: auto;
  transform: translateY(40px); 
  transition: transform 0.3s cubic-bezier(.23,1,.32,1);
}
.sheet-overlay.open .sheet-content { transform: translateY(0); }

.sheet-handle { 
  width: 40px; height: 5px; background: rgba(100,116,139,0.2); 
  border-radius: 3px; margin: 0 auto 1.4rem; 
}

.sheet-header { 
  display: flex; align-items: center; 
  justify-content: space-between; margin-bottom: 1.2rem; 
  padding: 0 0.3rem; 
}
.sheet-title { 
  font-family: 'DM Sans', sans-serif; font-size: 1rem; 
  font-weight: 700; color: var(--text); 
  display: flex; align-items: center; gap: 10px; 
}
.title-count { 
  font-family: 'DM Sans', sans-serif; font-size: 0.65rem; 
  font-weight: 700; color: var(--blue); 
  background: rgba(59,130,246,0.12); 
  border-radius: 50px; padding: 3px 9px; 
}

.close-sheet-btn { 
  width: 32px; height: 32px; border-radius: 50%; 
  background: rgba(100,116,139,0.08); border: none; 
  cursor: pointer; font-size: 1rem; color: var(--text-soft); 
  display: flex; align-items: center; justify-content: center; 
  transition: all 0.18s; 
}
.close-sheet-btn:hover { 
  background: rgba(59,130,246,0.15); 
  color: var(--blue); transform: rotate(90deg); 
}

/* ══ LOGIN SHEET (Full Screen Modal) ══ */
.login-overlay {
  position: fixed; inset: 0; z-index: 10003;
  pointer-events: none; opacity: 0;
  transition: opacity 0.3s ease;
}
.login-overlay.open { pointer-events: all; opacity: 1; }

.login-bg {
  position: absolute; inset: 0;
  background: rgba(15,23,42,0.6);
  backdrop-filter: blur(8px);
}

.login-modal {
  position: absolute;
  top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.95);
  width: 90%; max-width: 420px;
  background: var(--bg-light);
  border-radius: 24px;
  box-shadow: 0 20px 60px rgba(59,130,246,0.25);
  padding: 2rem 1.8rem;
  transition: transform 0.3s cubic-bezier(.23,1,.32,1);
}
.login-overlay.open .login-modal {
  transform: translate(-50%, -50%) scale(1);
}

.login-header {
  text-align: center; margin-bottom: 2rem;
}

/* Login Logo - FactCheckBD Style with CSS */
.login-logo {
  width: 80px; height: 80px; margin: 0 auto 1.2rem;
  border-radius: 18px;
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  display: flex; align-items: center; justify-content: center;
  overflow: visible;
  box-shadow: 0 8px 32px rgba(59,130,246,0.35);
  position: relative;
}
.login-logo::before {
  content: '✓';
  font-size: 50px;
  color: white;
  font-weight: bold;
  line-height: 1;
}
.login-logo img {
  display: none;
}

.login-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 1.5rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.5rem;
}
.login-title .fact { color: var(--text); }
.login-title .check { color: var(--blue); }
.login-title .bd { color: var(--blue); font-weight: 800; }

.login-subtitle {
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 0.9rem; color: var(--text-soft);
}

.login-form {
  display: flex; flex-direction: column; gap: 1.2rem;
}

.form-group {
  display: flex; flex-direction: column; gap: 0.5rem;
}
.form-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem; font-weight: 600;
  color: var(--text);
}
.form-input {
  padding: 0.9rem 1.1rem;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  background: var(--bg);
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 0.9rem; color: var(--text);
  transition: all 0.2s;
  outline: none;
}
.form-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
  background: var(--bg-light);
}
.form-input::placeholder {
  color: var(--text-soft);
}

.form-options {
  display: flex; justify-content: space-between;
  align-items: center; margin-top: -0.5rem;
}
.remember-me {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 0.8rem; color: var(--text);
  cursor: pointer;
}
.remember-me input[type="checkbox"] {
  width: 18px; height: 18px;
  cursor: pointer;
}
.forgot-password {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem; font-weight: 600;
  color: var(--blue);
  text-decoration: none;
  transition: all 0.2s;
}
.forgot-password:hover {
  color: var(--blue-light);
  text-decoration: underline;
}

.submit-btn {
  padding: 1rem;
  background: linear-gradient(135deg, var(--blue), var(--teal));
  border: none; border-radius: 12px;
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem; font-weight: 700;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(59,130,246,0.25);
  transition: all 0.2s;
}
.submit-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(59,130,246,0.35);
}
.submit-btn:active {
  transform: translateY(0);
}

.divider {
  display: flex; align-items: center;
  gap: 1rem; margin: 1.5rem 0;
}
.divider-line {
  flex: 1; height: 1px;
  background: var(--border);
}
.divider-text {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem; color: var(--text-soft);
}

.social-login {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
}
.social-btn {
  display: flex; align-items: center; justify-content: center;
  gap: 8px; padding: 0.85rem;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  background: var(--bg-light);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem; font-weight: 600;
  color: var(--text);
  cursor: pointer;
  transition: all 0.2s;
}
.social-btn:hover {
  border-color: var(--blue);
  background: rgba(59,130,246,0.05);
}
.social-btn svg {
  width: 20px; height: 20px;
}

.signup-link {
  text-align: center;
  margin-top: 1.5rem;
  font-family: 'Hind Siliguri', sans-serif;
  font-size: 0.85rem;
  color: var(--text-soft);
}
.signup-link a {
  color: var(--blue);
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s;
}
.signup-link a:hover {
  color: var(--blue-light);
  text-decoration: underline;
}

.close-login-btn {
  position: absolute;
  top: 1.2rem; right: 1.2rem;
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(100,116,139,0.1);
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; color: var(--text-soft);
  transition: all 0.2s;
}
.close-login-btn:hover {
  background: rgba(239,68,68,0.1);
  color: #ef4444;
  transform: rotate(90deg);
}

/* Site Info Card */
.site-info-card {
  display: flex; align-items: center; gap: 12px;
  background: var(--bg); border: 1px solid var(--border); 
  border-radius: 14px; padding: 0.8rem 1.1rem; 
  margin-bottom: 1.4rem;
}
.site-info-logo { 
  width: 32px; height: 32px; border-radius: 9px; 
  overflow: visible; flex-shrink: 0;
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 3px 12px rgba(59,130,246,0.25);
  position: relative;
}
.site-info-logo::before {
  content: '✓';
  font-size: 20px;
  color: white;
  font-weight: bold;
  line-height: 1;
}
.site-info-logo img { 
  display: none;
}
.site-info-text { flex: 1; }
.site-info-name { 
  font-family: 'DM Sans', sans-serif; font-size: 0.88rem; 
  font-weight: 700; color: var(--text); 
}
.site-info-url { 
  font-family: 'DM Sans', sans-serif; font-size: 0.65rem; 
  color: var(--text-soft); 
}
.site-status-dot { 
  width: 8px; height: 8px; background: var(--green); 
  border-radius: 50%; flex-shrink: 0; 
}

/* Search Box */
.search-box {
  display: flex; align-items: center; gap: 10px;
  background: var(--bg-light); 
  border: 1.5px solid var(--border); 
  border-radius: 14px; padding: 0.7rem 1rem; 
  margin-bottom: 1.4rem; transition: all 0.2s;
}
.search-box:focus-within { 
  border-color: var(--blue); 
  box-shadow: 0 0 0 3px rgba(59,130,246,0.1); 
}
.search-box svg { 
  width: 18px; height: 18px; stroke: var(--text-soft); 
  fill: none; stroke-width: 2; flex-shrink: 0; 
}
.search-box input { 
  flex: 1; border: none; background: transparent; 
  outline: none; font-family: 'Hind Siliguri', sans-serif; 
  font-size: 0.9rem; color: var(--text); 
}
.search-box input::placeholder { color: var(--text-soft); }

/* Section Label */
.section-label { 
  font-family: 'DM Sans', sans-serif; font-size: 0.65rem; 
  font-weight: 700; letter-spacing: 0.08em; 
  text-transform: uppercase; color: var(--text-soft); 
  display: block; margin-bottom: 0.8rem; padding: 0 0.3rem; 
}

/* Link Cards */
.link-cards { 
  display: flex; flex-direction: column; 
  gap: 0.6rem; margin-bottom: 1.6rem; 
}
.link-card {
  display: flex; align-items: center; gap: 14px;
  padding: 0.9rem 1.1rem; border-radius: 14px;
  background: var(--bg-light); border: 1px solid var(--border);
  text-decoration: none; transition: all 0.2s;
}
.link-card:hover { 
  background: rgba(59,130,246,0.05); 
  border-color: var(--blue); 
  transform: translateX(4px); 
  box-shadow: 0 2px 12px rgba(59,130,246,0.12);
}
.link-card.hidden { display: none; }

.link-icon {
  width: 40px; height: 40px; border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.15rem; flex-shrink: 0;
}
.link-info { flex: 1; min-width: 0; }
.link-title {
  font-family: 'Hind Siliguri', sans-serif; font-size: 0.9rem;
  font-weight: 600; color: var(--text); line-height: 1.35;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-bottom: 2px;
}
.link-subtitle {
  font-family: 'DM Sans', sans-serif; font-size: 0.65rem;
  color: var(--text-soft); overflow: hidden; 
  text-overflow: ellipsis; white-space: nowrap;
}
.link-arrow { 
  font-size: 1rem; color: var(--text-soft); 
  transition: transform 0.2s; 
}
.link-card:hover .link-arrow { 
  transform: translateX(3px); color: var(--blue); 
}

/* Skeleton Loading */
@keyframes shimmer { 
  0%{background-position:200% 0} 
  100%{background-position:-200% 0} 
}
.skeleton { 
  background: linear-gradient(90deg,#e2e8f0 25%,#f1f5f9 50%,#e2e8f0 75%); 
  background-size: 200% 100%; animation: shimmer 1.5s infinite; 
  border-radius: 10px; 
}
.skel-cards { margin-bottom: 1.6rem; }
.skel-card { 
  display: flex; gap: 14px; padding: 0.9rem 1.1rem; 
  border-radius: 14px; background: var(--bg-light); 
  border: 1px solid var(--border); margin-bottom: 0.6rem; 
}
.skel-icon { width: 40px; height: 40px; border-radius: 11px; }
.skel-text { flex: 1; display: flex; flex-direction: column; gap: 8px; }
.skel-line { height: 12px; border-radius: 6px; }
.skel-line.w80 { width: 80%; } 
.skel-line.w50 { width: 50%; }

/* Empty State */
.empty-state { 
  text-align: center; padding: 2.5rem 1rem; 
  color: var(--text-soft); display: none; 
}
.empty-state.show { display: block; }
.empty-icon { font-size: 2.8rem; margin-bottom: 0.8rem; }
.empty-text { font-size: 0.9rem; line-height: 1.6; }

/* Body Padding */
body {
  padding-top: 58px;
  padding-bottom: calc(68px + env(safe-area-inset-bottom, 0px));
}

/* Scrollbar */
.sheet-content::-webkit-scrollbar { width: 5px; }
.sheet-content::-webkit-scrollbar-thumb { 
  background: rgba(100,116,139,0.2); border-radius: 3px; 
}

/* ══ RESPONSIVE — MOBILE ══ */
@media (max-width: 480px) {
  .top-header { padding: 0 4%; height: 54px; }
  .brand-logo { width: 36px; height: 36px; }
  .brand-title { font-size: 0.95rem; }
  .user-name { max-width: 90px; font-size: 0.75rem; }
  .user-location { display: none; }
  .user-avatar { width: 28px; height: 28px; font-size: 0.65rem; }
  .login-btn { padding: 6px 14px; font-size: 0.8rem; }
  
  .bottom-nav { padding: 6px 2% calc(6px + env(safe-area-inset-bottom, 0px)); }
  .nav-btn { padding: 6px 4px; max-width: 80px; }
  .nav-icon-wrap { width: 38px; height: 38px; }
  .nav-icon-wrap svg { width: 22px; height: 22px; }
  .nav-label { font-size: 0.64rem; }
  
  .sheet-content { padding: 1.2rem 1rem 1.8rem; border-radius: 24px 24px 0 0; }
  .link-card { padding: 0.8rem 1rem; }
  .link-icon { width: 36px; height: 36px; font-size: 1rem; }
  .link-title { font-size: 0.85rem; }
  
  .login-modal { 
    width: 94%; max-width: none;
    padding: 1.8rem 1.4rem; 
  }
  .login-title { font-size: 1.3rem; }
  .profile-dropdown { min-width: 200px; }
}

/* ══ RESPONSIVE — DESKTOP ══ */
@media (min-width: 769px) {
  .bottom-nav {
    max-width: 640px; left: 50%; right: auto;
    transform: translateX(-50%); border-radius: 24px 24px 0 0;
  }
  .sheet-content { 
    max-width: 720px; margin: 0 auto; 
    left: 0; right: 0; border-radius: 32px 32px 0 0; 
  }
  .nav-btn { max-width: 100px; }
  .brand-tagline { display: block; }
}

