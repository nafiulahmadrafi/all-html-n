<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>আমাদের সম্পর্কে — নাগরিক পোর্টাল</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Noto+Serif+Bengali:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --green-deep: #1a5c3a;
    --green-mid: #2d7d52;
    --green-light: #4caf80;
    --green-pale: #e8f5ee;
    --green-mist: #f4faf7;
    --gold: #c8a84b;
    --gold-pale: #fdf8ec;
    --red-bd: #c0392b;
    --white: #ffffff;
    --off-white: #f8faf9;
    --text-dark: #0f2318;
    --text-mid: #2e4d3a;
    --text-muted: #6b8576;
    --border: #d5e8dc;
    --border-light: #eaf3ed;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Hind Siliguri', sans-serif;
    background: var(--off-white);
    color: var(--text-dark);
    line-height: 1.7;
  }

  /* ── HERO ─────────────────────────────── */
  .about-hero {
    background: linear-gradient(160deg, var(--green-deep) 0%, #0f3d24 55%, #1a2e0f 100%);
    padding: 72px 40px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,168,75,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .about-hero::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(76,175,128,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(200,168,75,0.15);
    border: 1px solid rgba(200,168,75,0.35);
    border-radius: 20px;
    padding: 5px 16px;
    font-size: 12px;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    margin-bottom: 22px;
    animation: fadeUp 0.6s ease both;
  }
  .about-hero h1 {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 42px;
    font-weight: 900;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 18px;
    animation: fadeUp 0.6s 0.1s ease both;
  }
  .about-hero h1 span { color: var(--gold); }
  .about-hero p {
    font-size: 16px;
    color: rgba(255,255,255,0.75);
    max-width: 620px;
    margin: 0 auto;
    animation: fadeUp 0.6s 0.2s ease both;
  }
  .hero-line {
    width: 60px; height: 3px;
    background: linear-gradient(to right, var(--gold), transparent);
    margin: 24px auto 0;
    border-radius: 2px;
    animation: fadeUp 0.6s 0.3s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── WRAPPER ────────────────────────── */
  .page-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 28px 80px;
  }

  /* ── SECTION LABEL ───────────────────── */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--green-mid);
    background: var(--green-pale);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.4;
    margin-bottom: 14px;
  }
  .section-sub {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 640px;
    line-height: 1.8;
  }

  /* ── INTRO SPLIT ─────────────────────── */
  .intro-section {
    margin-top: -44px;
    position: relative;
    z-index: 10;
  }
  .intro-card {
    background: var(--white);
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(26,92,58,0.13);
    padding: 44px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    border: 1px solid var(--border-light);
  }
  .intro-text p {
    font-size: 15px;
    color: var(--text-mid);
    line-height: 1.85;
    margin-bottom: 14px;
  }
  .intro-highlight {
    background: var(--green-mist);
    border-left: 4px solid var(--green-mid);
    border-radius: 0 12px 12px 0;
    padding: 14px 20px;
    font-size: 14.5px;
    color: var(--text-mid);
    font-style: italic;
    margin-top: 8px;
  }
  .intro-visual {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .stat-pill {
    background: var(--green-mist);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .stat-pill-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--white);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(26,92,58,0.08);
  }
  .stat-pill-num {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--green-deep);
    line-height: 1;
  }
  .stat-pill-label {
    font-size: 12.5px;
    color: var(--text-muted);
    margin-top: 3px;
  }

  /* ── MISSION VISION ──────────────────── */
  .mv-section {
    margin-top: 60px;
  }
  .mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 28px;
  }
  .mv-card {
    border-radius: 18px;
    padding: 32px 30px;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .mv-card.mission {
    background: linear-gradient(135deg, var(--green-deep) 0%, #1e6b42 100%);
    color: white;
  }
  .mv-card.vision {
    background: var(--white);
  }
  .mv-card.values {
    background: var(--gold-pale);
    border-color: #e8d5a0;
  }
  .mv-card.approach {
    background: var(--white);
    border-color: var(--border);
  }
  .mv-card::before {
    content: '';
    position: absolute;
    top: -30px; right: -30px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }
  .mv-icon {
    font-size: 32px;
    margin-bottom: 14px;
    display: block;
  }
  .mv-title {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .mv-card.mission .mv-title { color: rgba(255,255,255,0.95); }
  .mv-card.vision .mv-title, .mv-card.approach .mv-title { color: var(--text-dark); }
  .mv-card.values .mv-title { color: #5c3d00; }
  .mv-text {
    font-size: 14px;
    line-height: 1.8;
  }
  .mv-card.mission .mv-text { color: rgba(255,255,255,0.8); }
  .mv-card.vision .mv-text, .mv-card.approach .mv-text { color: var(--text-mid); }
  .mv-card.values .mv-text { color: #6b4c00; }

  /* ── WHAT WE DO ──────────────────────── */
  .what-section { margin-top: 64px; }
  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 32px;
  }
  .what-card {
    background: var(--white);
    border-radius: 16px;
    border: 1px solid var(--border-light);
    padding: 26px 22px;
    transition: all 0.22s;
    box-shadow: 0 2px 8px rgba(26,92,58,0.06);
  }
  .what-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(26,92,58,0.12);
    border-color: var(--green-light);
  }
  .what-card-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    margin-bottom: 16px;
  }
  .what-card h4 {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .what-card p {
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.75;
  }

  /* ── SISTER ORGS ─────────────────────── */
  .orgs-section { margin-top: 64px; }
  .org-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-top: 32px;
  }
  .org-card {
    border-radius: 20px;
    padding: 34px 32px;
    border: 1px solid var(--border);
    background: var(--white);
    display: flex;
    flex-direction: column;
    gap: 14px;
    box-shadow: 0 4px 16px rgba(26,92,58,0.07);
    transition: box-shadow 0.2s;
  }
  .org-card:hover { box-shadow: 0 10px 40px rgba(26,92,58,0.13); }
  .org-card.political { border-top: 4px solid var(--green-mid); }
  .org-card.fact { border-top: 4px solid #2980b9; }
  .org-logo-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .org-logo-box {
    width: 56px; height: 56px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    flex-shrink: 0;
  }
  .org-card.political .org-logo-box { background: var(--green-pale); }
  .org-card.fact .org-logo-box { background: #eaf4fb; }
  .org-name {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.3;
  }
  .org-tag {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 2px;
  }
  .org-desc {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.8;
  }
  .org-badge-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .org-badge {
    font-size: 11.5px;
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 600;
  }
  .org-card.political .org-badge { background: var(--green-pale); color: var(--green-deep); }
  .org-card.fact .org-badge { background: #eaf4fb; color: #1a5276; }
  .org-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 13.5px;
    font-weight: 700;
    font-family: 'Hind Siliguri', sans-serif;
    text-decoration: none;
    transition: all 0.2s;
    width: fit-content;
    margin-top: 4px;
  }
  .org-card.political .org-btn {
    background: var(--green-deep);
    color: #fff;
  }
  .org-card.political .org-btn:hover { background: var(--green-mid); }
  .org-card.fact .org-btn {
    background: #2980b9;
    color: #fff;
  }
  .org-card.fact .org-btn:hover { background: #1a6694; }

  /* ── TEAM / PRINCIPLES ───────────────── */
  .principles-section { margin-top: 64px; }
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  .principle-card {
    background: var(--white);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 24px 18px;
    text-align: center;
    transition: all 0.2s;
  }
  .principle-card:hover {
    border-color: var(--green-light);
    box-shadow: 0 6px 24px rgba(26,92,58,0.1);
  }
  .principle-num {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: var(--green-pale);
    color: var(--green-deep);
    font-weight: 800;
    font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
    font-family: 'Noto Serif Bengali', serif;
  }
  .principle-card h4 {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 14.5px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 7px;
  }
  .principle-card p {
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── TIMELINE ────────────────────────── */
  .timeline-section { margin-top: 64px; }
  .timeline {
    margin-top: 32px;
    position: relative;
    padding-left: 32px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 10px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--green-mid), var(--border));
    border-radius: 2px;
  }
  .tl-item {
    position: relative;
    margin-bottom: 32px;
    padding-left: 28px;
  }
  .tl-dot {
    position: absolute;
    left: -32px; top: 4px;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--white);
    border: 3px solid var(--green-mid);
    display: flex; align-items: center; justify-content: center;
  }
  .tl-dot-inner {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green-mid);
  }
  .tl-year {
    font-size: 11px;
    font-weight: 700;
    color: var(--green-mid);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .tl-title {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 5px;
  }
  .tl-text {
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.75;
  }

  /* ── CTA ─────────────────────────────── */
  .cta-section {
    margin-top: 64px;
    background: linear-gradient(135deg, var(--green-deep) 0%, #0f3d24 100%);
    border-radius: 22px;
    padding: 52px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: rgba(200,168,75,0.1);
    pointer-events: none;
  }
  .cta-section h3 {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .cta-section p {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    margin-bottom: 28px;
    max-width: 520px;
    margin-left: auto; margin-right: auto;
  }
  .cta-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    font-family: 'Hind Siliguri', sans-serif;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
  }
  .cta-btn.primary {
    background: var(--gold);
    color: #1a2000;
  }
  .cta-btn.primary:hover { background: #d4b560; }
  .cta-btn.secondary {
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
  }
  .cta-btn.secondary:hover { background: rgba(255,255,255,0.2); }

  /* ── CONTACT STRIP ───────────────────── */
  .contact-strip {
    margin-top: 28px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .contact-strip h4 {
    font-family: 'Noto Serif Bengali', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 4px;
  }
  .contact-strip p {
    font-size: 13px;
    color: var(--text-muted);
  }
  .contact-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .contact-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .contact-chip.green {
    background: var(--green-pale);
    color: var(--green-deep);
    border: 1px solid var(--border);
  }
  .contact-chip.green:hover { background: var(--border); }
  .contact-chip.blue {
    background: #eaf4fb;
    color: #1a5276;
    border: 1px solid #c2dff0;
  }
  .contact-chip.blue:hover { background: #d5ebf7; }

  @media (max-width: 860px) {
    .intro-card { grid-template-columns: 1fr; gap: 28px; padding: 28px 24px; }
    .mv-grid, .org-cards { grid-template-columns: 1fr; }
    .what-grid { grid-template-columns: 1fr 1fr; }
    .principles-grid { grid-template-columns: 1fr 1fr; }
    .about-hero h1 { font-size: 28px; }
    .cta-section { padding: 36px 24px; }
    .contact-strip { flex-direction: column; align-items: flex-start; }
    .page-wrap { padding: 0 16px 60px; }
    .about-hero { padding: 48px 20px 64px; }
  }
  @media (max-width: 560px) {
    .what-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<!-- HERO -->
<section class="about-hero">
  <div class="hero-eyebrow">🏛️ আমাদের সম্পর্কে</div>
  <h1>নাগরিকের পাশে,<br><span>সত্যের সন্ধানে</span></h1>
  <p>দুর্নীতিমুক্ত, স্বচ্ছ ও জবাবদিহিমূলক বাংলাদেশ গড়তে নাগরিক পোর্টাল প্রতিদিন কাজ করে যাচ্ছে।</p>
  <div class="hero-line"></div>
</section>

<div class="page-wrap">

  <!-- INTRO -->
  <section class="intro-section">
    <div class="intro-card">
      <div class="intro-text">
        <div class="section-label">🌿 আমরা কারা</div>
        <div class="section-heading">নাগরিক পোর্টাল</div>
        <p><strong>নাগরিক পোর্টাল</strong> হলো <em>Political Insights BD</em>-এর একটি অঙ্গ প্রতিষ্ঠান। দেশের প্রতিটি সাধারণ নাগরিকের কাছে সরকারি সেবার সঠিক তথ্য পৌঁছে দেওয়া এবং নাগরিক অধিকার সম্পর্কে সচেতনতা তৈরি করাই আমাদের মূল উদ্দেশ্য।</p>
        <p>আমরা বিশ্বাস করি — একজন সচেতন নাগরিকই পারেন দুর্নীতি ও অনিয়মের বিরুদ্ধে রুখে দাঁড়াতে। তাই সরকারের সহযোগী হিসেবে দেশের সার্বিক উন্নয়নে ও দুর্নীতি দূরীকরণে আমরা নিরলসভাবে কাজ করে যাচ্ছি।</p>
        <div class="intro-highlight">
          "তথ্যই শক্তি — সঠিক তথ্য জানলে প্রতিটি নাগরিক তার ন্যায্য অধিকার আদায় করতে পারবেন।"
        </div>
      </div>
      <div class="intro-visual">
        <div class="stat-pill">
          <div class="stat-pill-icon">🏛️</div>
          <div>
            <div class="stat-pill-num">১৫+</div>
            <div class="stat-pill-label">উপজেলা সেবা বিভাগ</div>
